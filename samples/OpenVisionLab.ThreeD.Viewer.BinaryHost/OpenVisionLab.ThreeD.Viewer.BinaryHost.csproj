<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ViewerBundlePath Condition="'$(ViewerBundlePath)' == ''">$(MSBuildThisFileDirectory)..\..\artifacts\viewer-dll\net10.0-windows</ViewerBundlePath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="$(ViewerBundlePath)\*.dll" />
    <Content Include="$(ViewerBundlePath)\viewer-dll-manifest.json"
             Link="viewer-dll-manifest.json"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <Target Name="ValidateViewerBundle" BeforeTargets="ResolveReferences">
    <Error Condition="!Exists('$(ViewerBundlePath)\OpenVisionLab.ThreeD.Viewer.dll')"
           Text="Build the Viewer DLL bundle first: scripts\build-viewer-dll.ps1" />
  </Target>
</Project>
