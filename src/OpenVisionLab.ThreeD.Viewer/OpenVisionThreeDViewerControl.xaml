<UserControl x:Class="OpenVisionLab.ThreeD.Viewer.OpenVisionThreeDViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sharpgl="clr-namespace:SharpGL.WPF;assembly=SharpGL.WPF"
             Background="#f3f4f6">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#ffffff" BorderBrush="#d1d5db" BorderThickness="0,0,0,1">
            <Grid Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Fit All" Width="72" Margin="0,0,8,0" Command="{Binding FitAllCommand}" />
                    <Button Content="Fit Selection" Width="112" Margin="0,0,8,0" Command="{Binding FitSelectionCommand}" />
                    <Button Content="Reset" Width="72" Margin="0,0,8,0" Command="{Binding ResetCommand}" />
                    <Button Content="Screenshot" Width="104" Margin="0,0,8,0" Command="{Binding ScreenshotCommand}" />
                    <Button Content="Open Recipe" Width="104" Margin="0,0,8,0" Command="{Binding OpenRecipeCommand}" />
                    <Button Content="Save Recipe" Width="104" Margin="0,0,12,0" Command="{Binding SaveRecipeCommand}" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Foreground="#6b7280"
                               Text="Mode" />
                    <ComboBox Width="150"
                              ItemsSource="{Binding SelectionModes}"
                              SelectedItem="{Binding SelectedSelectionMode, Mode=TwoWay}" />
                    <CheckBox Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Content="HUD Details"
                              IsChecked="{Binding HudDetailsVisible, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           Foreground="#374151"
                           Text="{Binding ViewerStatus}" />

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#6b7280"
                           Text="SharpGL WPF MVP" />
            </Grid>
        </Border>

        <Border x:Name="LeftSidePanel"
                DockPanel.Dock="Left"
                Width="240"
                Background="#ffffff"
                BorderBrush="#d1d5db"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Entities" />
                <CheckBox Margin="0,12,0,0"
                          Content="Generated Unit Cube"
                          IsChecked="{Binding CubeVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Generated Point Cloud"
                          IsChecked="{Binding PointCloudVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="C3D Thickness Sample"
                          IsChecked="{Binding C3DSampleVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="{Binding ImportedMeshLayerLabel}"
                          IsChecked="{Binding GlbSampleVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Public LAZ/LAS Point Cloud"
                          IsChecked="{Binding LazSampleVisible, Mode=TwoWay}" />
                <Separator Margin="0,14,0,10" />
                <StackPanel DataContext="{Binding NominalActual}">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="Nominal / Actual" />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding ActualSourceSummary, FallbackValue='Actual: not loaded'}" />
                    <TextBlock Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding NominalSourceSummary, FallbackValue='Nominal: not loaded'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding QuerySourceSummary, FallbackValue='Validation query: not loaded'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding FrameSummary, FallbackValue='Frame: not set | Units: not set'}" />
                    <WrapPanel Margin="0,7,0,0">
                        <CheckBox Margin="0,0,12,0"
                                  Content="Actual"
                                  IsChecked="{Binding ActualVisible, Mode=TwoWay, FallbackValue=False}"
                                  IsEnabled="{Binding InputsReady, FallbackValue=False}" />
                        <CheckBox Content="Nominal"
                                  IsChecked="{Binding NominalVisible, Mode=TwoWay, FallbackValue=False}"
                                  IsEnabled="{Binding InputsReady, FallbackValue=False}" />
                    </WrapPanel>
                </StackPanel>
                <Separator Margin="0,14,0,10" />
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Display" />
                <TextBlock Margin="0,10,0,4" Foreground="#6b7280" Text="Geometry Style" />
                <ComboBox ItemsSource="{Binding Display.AvailableGeometryStyles}"
                          SelectedItem="{Binding Display.SelectedGeometryStyle, Mode=TwoWay}"
                          IsEnabled="{Binding Display.CanSelectGeometryStyle, FallbackValue=False}">
                </ComboBox>
                <TextBlock Margin="0,10,0,4" Foreground="#6b7280" Text="Color Map" />
                <ComboBox ItemsSource="{Binding Display.AvailableColorMaps}"
                          SelectedItem="{Binding Display.SelectedColorMap, Mode=TwoWay}"
                          IsEnabled="{Binding Display.CanSelectColorMap}" />
                <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Point Size" />
                <Slider Minimum="1"
                        Maximum="6"
                        TickFrequency="0.5"
                        IsSnapToTickEnabled="True"
                        Value="{Binding PointSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,2,0,0"
                           Text="{Binding PointSize, StringFormat=Point size: {0:F1}px}" />
                <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Render Density" />
                <ComboBox ItemsSource="{Binding RenderDensityModes}"
                          SelectedItem="{Binding SelectedRenderDensity, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#6b7280"
                           TextWrapping="Wrap"
                           Text="{Binding RenderDensitySummary}" />
                <StackPanel Margin="0,5,0,0"
                            DataContext="{Binding NominalActual}"
                            Visibility="{Binding InputsReady, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                    <TextBlock Foreground="#374151"
                               TextWrapping="Wrap"
                               Text="{Binding CurrentDisplaySamplingSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding NextPreviewSamplingSummary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#6b7280" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                        <Setter Property="Foreground" Value="#b45309" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <CheckBox Margin="0,12,0,0"
                          Content="Measurement Overlay"
                          IsChecked="{Binding MeasurementVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Result Overlay"
                          IsChecked="{Binding ResultOverlayVisible, Mode=TwoWay}" />
                <Button Margin="0,8,0,0"
                        Content="Publish Result"
                        Command="{Binding PublishResultCommand}" />
                <Separator Margin="0,16,0,12" />
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Selection" />
                <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="Mode" />
                <ComboBox ItemsSource="{Binding SelectionModes}"
                          SelectedItem="{Binding SelectedSelectionMode, Mode=TwoWay}" />
                <CheckBox Margin="0,12,0,0"
                          Content="Selection Overlay"
                          IsChecked="{Binding SelectionOverlayVisible, Mode=TwoWay}" />
                <Separator Margin="0,16,0,12" />
                <TextBlock Foreground="#6b7280" TextWrapping="Wrap">
                    Drag to orbit. Middle drag or Shift+drag pans. Mouse wheel zooms. Left click the cube to pick the nearest face.
                </TextBlock>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <Border x:Name="RightSidePanel"
                DockPanel.Dock="Right"
                Width="300"
                Background="#ffffff"
                BorderBrush="#d1d5db"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Inspection" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Selected Entity" />
                <TextBlock FontWeight="SemiBold"
                           Text="{Binding SelectedEntity}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Pick Coordinate" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding PickCoordinate}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Measurement" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding MeasurementSummary}" />
                <Button Margin="0,8,0,0"
                        Content="Fit C3D Plane"
                        Command="{Binding FitPlaneCommand}" />
                <Separator Margin="0,14,0,10" />
                <StackPanel DataContext="{Binding NominalActual}">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="Surface Deviation" />
                    <TextBlock Margin="0,5,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Text="{Binding StateSummary, FallbackValue='Status: No inputs'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding DirectionSummary, FallbackValue='Direction: Actual to Nominal'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding AlignmentSummary, FallbackValue='Alignment: not set'}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#374151"
                               TextWrapping="Wrap"
                               Text="{Binding CurrentDisplaySamplingSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding NextPreviewSamplingSummary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#6b7280" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                        <Setter Property="Foreground" Value="#b45309" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Lower tolerance" />
                            <TextBox Text="{Binding LowerTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, FallbackValue='-'}"
                                     IsEnabled="{Binding CanEdit, FallbackValue=False}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Upper tolerance" />
                            <TextBox Text="{Binding UpperTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, FallbackValue='-'}"
                                     IsEnabled="{Binding CanEdit, FallbackValue=False}" />
                        </StackPanel>
                    </Grid>
                    <ProgressBar Height="6"
                                 Margin="0,9,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressPercent, Mode=OneWay, FallbackValue=0}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding ProgressSummary, FallbackValue='Progress: not started'}" />
                    <WrapPanel Margin="0,8,0,0">
                        <Button Margin="0,0,6,0"
                                Content="Preview Comparison"
                                Command="{Binding PreviewCommand}"
                                IsEnabled="{Binding CanPreview, FallbackValue=False}" />
                        <Button Margin="0,0,6,0"
                                Content="Cancel"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding CanCancel, FallbackValue=False}" />
                        <Button Content="Publish"
                                Command="{Binding PublishCommand}"
                                IsEnabled="{Binding CanPublish, FallbackValue=False}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding ResultSummary, FallbackValue='No comparison preview.'}" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#6b7280"
                               Text="Selected Deviation Point" />
                    <TextBlock Margin="0,3,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedDeviationSummary, FallbackValue='Selected point: none'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasSelectedDeviation, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                               Text="{Binding SelectedDeviationDetails}" />
                </StackPanel>
                <StackPanel Visibility="{Binding C3DSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="Point Pair Dimensions" />
                    <WrapPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp D" />
                            <TextBox Text="{Binding PointPairExpectedDistance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol D" />
                            <TextBox Text="{Binding PointPairDistanceTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp W" />
                            <TextBox Text="{Binding PointPairExpectedWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol W" />
                            <TextBox Text="{Binding PointPairWidthTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp A" />
                            <TextBox Text="{Binding PointPairExpectedAngleDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol A" />
                            <TextBox Text="{Binding PointPairAngleToleranceDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Margin="0,0,6,0"
                                Content="Preview Dimensions"
                                Command="{Binding PreviewPointPairDimensionsCommand}" />
                        <Button Content="Publish Result"
                                Command="{Binding PublishResultCommand}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding PointPairDimensionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PointPairDimensionsSummary}" />
                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="Gap / Flush" />
                    <WrapPanel>
                        <StackPanel Width="70" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp Gap" />
                            <TextBox Text="{Binding GapFlushExpectedGap, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="70" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol Gap" />
                            <TextBox Text="{Binding GapFlushGapTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="70" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp Flush" />
                            <TextBox Text="{Binding GapFlushExpectedFlush, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="70" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol Flush" />
                            <TextBox Text="{Binding GapFlushFlushTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Margin="0,0,6,0"
                                Content="Preview Gap / Flush"
                                Command="{Binding PreviewGapFlushCommand}" />
                        <Button Content="Publish Result"
                                Command="{Binding PublishResultCommand}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding GapFlushVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding GapFlushSummary}" />
                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Volume" />
                    <WrapPanel>
                        <StackPanel Width="94" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Expected Net" />
                            <TextBox Text="{Binding VolumeExpectedNet, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="94" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tolerance" />
                            <TextBox Text="{Binding VolumeTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Margin="0,0,6,0" Content="Preview Volume" Command="{Binding PreviewVolumeCommand}" />
                        <Button Content="Publish Result" Command="{Binding PublishResultCommand}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding VolumeVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding VolumeSummary}" />
                    <TextBlock Margin="0,12,0,4" FontWeight="SemiBold" Text="Cross-section Dimensions" />
                    <WrapPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Row" />
                            <TextBox Text="{Binding CrossSectionRow, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Start Col" />
                            <TextBox Text="{Binding CrossSectionStartColumn, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="End Col" />
                            <TextBox Text="{Binding CrossSectionEndColumn, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <StackPanel Width="70" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp Width" />
                            <TextBox Text="{Binding CrossSectionExpectedWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="70" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol Width" />
                            <TextBox Text="{Binding CrossSectionWidthTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="70" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp Height" />
                            <TextBox Text="{Binding CrossSectionExpectedHeightRange, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="70" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol Height" />
                            <TextBox Text="{Binding CrossSectionHeightTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Margin="0,0,6,0" Content="Preview Cross-section" Command="{Binding PreviewCrossSectionCommand}" />
                        <Button Content="Publish Result" Command="{Binding PublishResultCommand}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0" TextWrapping="Wrap"
                               Visibility="{Binding CrossSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding CrossSectionSummary}" />
                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="Reference Plane + Flatness" />
                    <WrapPanel>
                        <StackPanel Width="50" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Center X" />
                            <TextBox Text="{Binding PlaneFlatnessReferenceCenterX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="50" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Center Z" />
                            <TextBox Text="{Binding PlaneFlatnessReferenceCenterZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="50" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Half W" />
                            <TextBox Text="{Binding PlaneFlatnessReferenceHalfWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="50" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Half D" />
                            <TextBox Text="{Binding PlaneFlatnessReferenceHalfDepth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tolerance" />
                            <TextBox Text="{Binding PlaneFlatnessTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Margin="0,0,6,0"
                                Content="Preview Flatness"
                                Command="{Binding PreviewPlaneFlatnessCommand}" />
                        <Button Content="Publish Result"
                                Command="{Binding PublishResultCommand}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding PlaneFlatnessVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PlaneFlatnessSummary}" />
                </StackPanel>
                <StackPanel Visibility="{Binding LazSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding LazTwoPointAcceptanceSummary}" />
                    <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="LAZ/LAS Acceptance" />
                    <WrapPanel>
                        <StackPanel Width="78" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp D" />
                            <TextBox Text="{Binding LazTwoPointExpectedDistance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="64" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol D" />
                            <TextBox Text="{Binding LazTwoPointDistanceTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="78" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp H" />
                            <TextBox Text="{Binding LazTwoPointExpectedHeightDelta, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="64" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol H" />
                            <TextBox Text="{Binding LazTwoPointHeightDeltaTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Recipe" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding RecipeSummary}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#b91c1c"
                           TextWrapping="Wrap"
                           Text="{Binding RecipeValidationSummary}" />
                <StackPanel Visibility="{Binding C3DRecipeEditorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
