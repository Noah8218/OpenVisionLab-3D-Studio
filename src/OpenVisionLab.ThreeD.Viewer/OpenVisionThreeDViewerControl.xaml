<UserControl x:Class="OpenVisionLab.ThreeD.Viewer.OpenVisionThreeDViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sharpgl="clr-namespace:SharpGL.WPF;assembly=SharpGL.WPF"
             Background="#f3f4f6">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#ffffff" BorderBrush="#d1d5db" BorderThickness="0,0,0,1">
            <Grid Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Fit All" Width="72" Margin="0,0,8,0" Click="FitAll_Click" />
                    <Button Content="Fit Selection" Width="112" Margin="0,0,8,0" Click="FitSelection_Click" />
                    <Button Content="Reset" Width="72" Margin="0,0,8,0" Click="Reset_Click" />
                    <Button Content="Screenshot" Width="104" Margin="0,0,8,0" Click="Screenshot_Click" />
                    <Button Content="Open Recipe" Width="104" Margin="0,0,8,0" Click="OpenRecipe_Click" />
                    <Button Content="Save Recipe" Width="104" Margin="0,0,12,0" Click="SaveRecipe_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Foreground="#6b7280"
                               Text="Mode" />
                    <ComboBox Width="150"
                              ItemsSource="{Binding SelectionModes}"
                              SelectedItem="{Binding SelectedSelectionMode, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           Foreground="#374151"
                           Text="{Binding ViewerStatus}" />

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#6b7280"
                           Text="SharpGL WPF MVP" />
            </Grid>
        </Border>

        <Border x:Name="LeftSidePanel"
                DockPanel.Dock="Left"
                Width="240"
                Background="#ffffff"
                BorderBrush="#d1d5db"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="12">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Entities" />
                <CheckBox Margin="0,12,0,0"
                          Content="Generated Unit Cube"
                          IsChecked="{Binding CubeVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Generated Point Cloud"
                          IsChecked="{Binding PointCloudVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="C3D Thickness Sample"
                          IsChecked="{Binding C3DSampleVisible, Mode=TwoWay}" />
                <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Point Color" />
                <ComboBox ItemsSource="{Binding ColorModes}"
                          SelectedItem="{Binding SelectedColorMode, Mode=TwoWay}" />
                <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Point Size" />
                <Slider Minimum="1"
                        Maximum="6"
                        TickFrequency="0.5"
                        IsSnapToTickEnabled="True"
                        Value="{Binding PointSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,2,0,0"
                           Text="{Binding PointSize, StringFormat=Point size: {0:F1}px}" />
                <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Render Density" />
                <ComboBox ItemsSource="{Binding RenderDensityModes}"
                          SelectedItem="{Binding SelectedRenderDensity, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#6b7280"
                           TextWrapping="Wrap"
                           Text="{Binding RenderDensitySummary}" />
                <CheckBox Margin="0,12,0,0"
                          Content="Measurement Overlay"
                          IsChecked="{Binding MeasurementVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Result Overlay"
                          IsChecked="{Binding ResultOverlayVisible, Mode=TwoWay}" />
                <Button Margin="0,8,0,0"
                        Content="Publish Result"
                        Click="PublishResult_Click" />
                <Separator Margin="0,16,0,12" />
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Selection" />
                <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="Mode" />
                <ComboBox ItemsSource="{Binding SelectionModes}"
                          SelectedItem="{Binding SelectedSelectionMode, Mode=TwoWay}" />
                <CheckBox Margin="0,12,0,0"
                          Content="Selection Overlay"
                          IsChecked="{Binding SelectionOverlayVisible, Mode=TwoWay}" />
                <Separator Margin="0,16,0,12" />
                <TextBlock Foreground="#6b7280" TextWrapping="Wrap">
                    Drag to orbit. Middle drag or Shift+drag pans. Mouse wheel zooms. Left click the cube to pick the nearest face.
                </TextBlock>
            </StackPanel>
        </Border>

        <Border x:Name="RightSidePanel"
                DockPanel.Dock="Right"
                Width="300"
                Background="#ffffff"
                BorderBrush="#d1d5db"
                BorderThickness="1,0,0,0">
            <StackPanel Margin="12">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Inspection" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Selected Entity" />
                <TextBlock FontWeight="SemiBold"
                           Text="{Binding SelectedEntity}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Pick Coordinate" />
                <TextBlock Text="{Binding PickCoordinate}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Measurement" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding MeasurementSummary}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Recipe" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding RecipeSummary}" />
                <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="Peak Tolerance" />
                <TextBox Text="{Binding RecipePeakTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />
                <Button Margin="0,8,0,0"
                        Content="Save Recipe"
                        Click="SaveRecipe_Click" />
                <TextBlock Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Text="{Binding RecipeSaveSummary}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Result Overlay" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding ResultSummary}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Published Result" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding PublishedResultSummary}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Point Cloud" />
                <TextBlock Text="{Binding PointCloudPointCount, StringFormat=Points: {0}}" />
                <TextBlock Text="{Binding SelectedColorMode, StringFormat=Color mode: {0}}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="C3D Sample" />
                <TextBlock Text="{Binding C3DSamplePointCount, StringFormat=Rendered points: {0}}" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding C3DSampleSummary}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Selection" />
                <TextBlock Text="{Binding SelectedSelectionMode, StringFormat=Mode: {0}}" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding SelectionSummary}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Last Screenshot" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding LastScreenshotPath}" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#111827" Padding="10,6">
            <TextBlock Foreground="#f9fafb"
                       Text="{Binding BottomStatus}" />
        </Border>

        <Grid>
            <sharpgl:OpenGLControl x:Name="Viewport"
                                   DrawFPS="False"
                                   FrameRate="30"
                                   OpenGLInitialized="Viewport_OpenGLInitialized"
                                   OpenGLDraw="Viewport_OpenGLDraw"
                                   Resized="Viewport_Resized"
                                   MouseDown="Viewport_MouseDown"
                                   MouseMove="Viewport_MouseMove"
                                   MouseUp="Viewport_MouseUp"
                                   MouseWheel="Viewport_MouseWheel" />
            <Border HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="330"
                    Margin="12"
                    Padding="10"
                    Background="#ee111827"
                    BorderBrush="#4b5563"
                    BorderThickness="1"
                    CornerRadius="4"
                    IsHitTestVisible="False">
                <StackPanel>
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#f9fafb"
                               Text="Viewer Measurement HUD" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold" Foreground="#ef4444" Text="X" />
                        <TextBlock Grid.Column="1" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="#22c55e" Text="Y height" />
                        <TextBlock Grid.Column="2" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="#60a5fa" Text="Z" />
                        <TextBlock Grid.Column="3"
                                   Margin="12,0,0,0"
                                   Foreground="#d1d5db"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding SelectedSelectionMode, StringFormat=Mode: {0}}" />
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="#d1d5db"
                               TextWrapping="Wrap"
                               Text="{Binding CoordinateFrameSummary}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#d1d5db"
                               TextWrapping="Wrap"
                               Text="{Binding PickCoordinate, StringFormat=Pick: {0}}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Text="{Binding TwoPointMeasurementSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#fbbf24"
                               TextWrapping="Wrap"
                               Text="{Binding TwoPointMeasurementDetails}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#d1d5db"
                               TextWrapping="Wrap"
                               Text="{Binding PerformanceSummary}" />
                </StackPanel>
            </Border>
            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="260"
                    Margin="0,0,12,12"
                    Padding="10"
                    Background="#eef9fafb"
                    BorderBrush="#9ca3af"
                    BorderThickness="1"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    Visibility="{Binding DeviationLegendVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Text="Deviation Color Scale" />
                    <Border Height="10" Margin="0,8,0,8" CornerRadius="2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#14b8a6" Offset="0.0" />
                                <GradientStop Color="#facc15" Offset="0.62" />
                                <GradientStop Color="#ef4444" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="10" Foreground="#374151" Text="Mean" />
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   FontSize="10"
                                   Foreground="#374151"
                                   Text="Tolerance" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   FontSize="10"
                                   Foreground="#374151"
                                   Text="Peak" />
                    </Grid>
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="10" Height="10" Fill="#14b8a6" />
                            <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="#111827" Text="Within tolerance" />
                        </StackPanel>
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <Rectangle Width="10" Height="10" Fill="#ef4444" />
                            <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="#111827" Text="Fail marker" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendStatus}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#111827"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendPeak}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#111827"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendTolerance}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendScale}" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
