                                       FontWeight="SemiBold"
                                       Foreground="#fbbf24"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedDeviationSummary}" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="10"
                                       Foreground="#d1d5db"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedDeviationDetails}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               TextWrapping="Wrap"
                               Visibility="{Binding HudDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding TransformSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#d1d5db"
                               TextWrapping="Wrap"
                               Visibility="{Binding HudDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding AlignmentSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#93c5fd"
                               TextWrapping="Wrap"
                               Visibility="{Binding HudDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding CoordinateMappingSummary}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#5eead4"
                               TextWrapping="Wrap"
                               Visibility="{Binding LineFitHudVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding LineFitHudSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#f9a8d4"
                               TextWrapping="Wrap"
                               Visibility="{Binding LineIntersectionHudVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding LineIntersectionHudSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#5eead4"
                               TextWrapping="Wrap"
                               Visibility="{Binding AffineApplyHudVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding AffineApplyHudSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#a7f3d0"
                               TextWrapping="Wrap"
                               Visibility="{Binding RegridHeightFieldHudVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding RegridHeightFieldHudSummary}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#d1d5db"
                               TextWrapping="Wrap"
                               Text="{Binding PickCoordinate, StringFormat=Pick: {0}}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding TwoPointMeasurementVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding TwoPointMeasurementSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#fbbf24"
                               TextWrapping="Wrap"
                               Visibility="{Binding TwoPointMeasurementVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding TwoPointMeasurementDetails}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding PointPairDimensionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PointPairDimensionsSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#7dd3fc"
                               TextWrapping="Wrap"
                               Visibility="{Binding PointPairDimensionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PointPairDimensionsDetails}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding ThicknessVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding ThicknessSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#67e8f9"
                               TextWrapping="Wrap"
                               Visibility="{Binding ThicknessVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding ThicknessDetails}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding PlaneReferenceMeasurementVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PlaneReferenceMeasurementSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#c4b5fd"
                               TextWrapping="Wrap"
                               Visibility="{Binding PlaneReferenceMeasurementVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PlaneReferenceMeasurementDetails}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding PlaneFlatnessVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PlaneFlatnessSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#c4b5fd"
                               TextWrapping="Wrap"
                               Visibility="{Binding PlaneFlatnessVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PlaneFlatnessDetails}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding GapFlushVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding GapFlushSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#fbbf24"
                               TextWrapping="Wrap"
                               Visibility="{Binding GapFlushVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding GapFlushDetails}" />
                    <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="#f9fafb" FontWeight="SemiBold"
                               TextWrapping="Wrap" Visibility="{Binding VolumeVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding VolumeSummary}" />
                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="#fbbf24"
                               TextWrapping="Wrap" Visibility="{Binding VolumeVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding VolumeDetails}" />
                    <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="#f9fafb" FontWeight="SemiBold"
                               TextWrapping="Wrap" Visibility="{Binding CrossSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding CrossSectionSummary}" />
                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="#fbbf24"
                               TextWrapping="Wrap" Visibility="{Binding CrossSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding CrossSectionDetails}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#f9fafb"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding RoiStepMeasurementVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding RoiStepMeasurementSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#7dd3fc"
                               TextWrapping="Wrap"
                               Visibility="{Binding RoiStepMeasurementVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding RoiStepMeasurementDetails}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#bfdbfe"
                               TextWrapping="Wrap"
                               Visibility="{Binding RoiStepMeasurementVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding RoiStepEditSummary}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#d1d5db"
                               TextWrapping="Wrap"
                               Visibility="{Binding HudDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PerformanceSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#fed7aa"
                               TextWrapping="Wrap"
                               Visibility="{Binding ImportedMeshHudDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding GlbSampleSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#fde68a"
                               TextWrapping="Wrap"
                               Visibility="{Binding LazHudDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding LazSampleSummary}" />
                </StackPanel>
            </Border>
            <Border x:Name="C3DHeightDistributionPanel"
                    Width="140"
                    Margin="0,8,8,0"
                    Padding="7"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#e6111827"
                    BorderBrush="#64748b"
                    BorderThickness="1"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    AutomationProperties.Name="C3D full-source height color and distribution legend"
                    Visibility="{Binding C3DHeightDistributionVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#f8fafc"
                               Text="HEIGHT / DISTRIBUTION" />
                    <Grid Height="118" Margin="0,4,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <Canvas Grid.Column="0"
                                Width="{x:Static viewModels:MainWindowViewModel.C3DHeightDistributionLabelColumnWidth}"
                                Height="118">
                            <TextBlock Canvas.Top="0"
                                       Canvas.Right="0"
                                       FontSize="9"
                                       Foreground="#e2e8f0"
                                       Text="{Binding C3DHeightDistributionHighLabel}" />
                            <TextBlock Canvas.Top="{Binding C3DHeightDistributionMeanLabelTop}"
                                       Canvas.Right="0"
                                       FontSize="9"
                                       Foreground="#cbd5e1"
                                       Text="{Binding C3DHeightDistributionMeanLabel}" />
                            <TextBlock Canvas.Right="0"
                                       Canvas.Bottom="0"
                                       FontSize="9"
                                       Foreground="#e2e8f0"
                                       Text="{Binding C3DHeightDistributionLowLabel}" />
                        </Canvas>
                        <Border Grid.Column="1"
                                Background="{Binding C3DHeightDistributionGradient}"
                                BorderBrush="#94a3b8"
                                BorderThickness="1"
                                CornerRadius="2" />
                        <Canvas Grid.Column="3"
                                Width="44"
                                Height="118"
                                ClipToBounds="True">
                            <Path Data="{Binding C3DHeightDistributionHistogramPathData}"
                                  Fill="#8be2e8f0" />
                            <Path Data="{Binding C3DHeightDistributionPeakPathData}"
                                  Fill="#fbbf24" />
                        </Canvas>
                    </Grid>
                    <TextBlock FontSize="8"
                               FontWeight="SemiBold"
                               Foreground="#fbbf24"
                               TextWrapping="Wrap"
                               Text="{Binding C3DHeightDistributionPeakLabel}" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="7.5"
                               Foreground="#cbd5e1"
                               Text="{Binding C3DHeightDistributionCountLabel}" />
                    <TextBlock Margin="0,1,0,0"
                               FontSize="7.5"
                               Foreground="#94a3b8"
                               Text="{Binding C3DHeightDistributionPaletteLabel}" />
                    <TextBlock Margin="0,1,0,0"
                               FontSize="7.5"
                               Foreground="#94a3b8"
                               Text="raw-height · display only" />
                </StackPanel>
            </Border>
            <Border x:Name="PointCloudColorLegendPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="260"
                    Margin="0,0,12,12"
                    Padding="10"
                    Background="#eef9fafb"
                    BorderBrush="#9ca3af"
                    BorderThickness="1"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Text="{Binding PointCloudColorLegendTitle}" />
                    <Border Height="10" Margin="0,8,0,8" CornerRadius="2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#0d59f2" Offset="0.0" />
                                <GradientStop Color="#0de6a6" Offset="0.5" />
                                <GradientStop Color="#ffb31a" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="10"
                                   Foreground="#374151"
                                   Text="{Binding PointCloudColorLegendLow}" />
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   FontSize="10"
                                   Foreground="#374151"
                                   Text="{Binding PointCloudColorLegendHigh}" />
                    </Grid>
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="10" Height="10" Fill="#0d59f2" />
                            <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="#111827" Text="Lower source Z" />
                        </StackPanel>
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <Rectangle Width="10" Height="10" Fill="#ffb31a" />
                            <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="#111827" Text="Higher source Z" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding PointCloudColorLegendScale}" />
                </StackPanel>
            </Border>
            <Border x:Name="DeviationLegendPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="260"
                    Margin="0,0,12,12"
                    Padding="10"
                    Background="#eef9fafb"
                    BorderBrush="#9ca3af"
                    BorderThickness="1"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Text="Deviation Color Scale" />
                    <Border Height="10" Margin="0,8,0,8" CornerRadius="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#14b8a6" Offset="0.0" />
                                            <GradientStop Color="#facc15" Offset="0.62" />
                                            <GradientStop Color="#ef4444" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlaneFlatnessVisible}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Color="#2563eb" Offset="0.0" />
                                                    <GradientStop Color="#ffffff" Offset="0.5" />
                                                    <GradientStop Color="#ef4444" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="10" Foreground="#374151" Text="{Binding DeviationLegendLowLabel}" />
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   FontSize="10"
                                   Foreground="#374151"
                                   Text="{Binding DeviationLegendMiddleLabel}" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   FontSize="10"
                                   Foreground="#374151"
                                   Text="{Binding DeviationLegendHighLabel}" />
                    </Grid>
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlaneFlatnessVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="10" Height="10" Fill="#14b8a6" />
                            <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="#111827" Text="Within tolerance" />
                        </StackPanel>
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <Rectangle Width="10" Height="10" Fill="#ef4444" />
                            <TextBlock Margin="6,0,0,0" FontSize="11" Foreground="#111827" Text="Fail marker" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#374151"
                               Text="Blue: below plane | Red: above plane"
                               Visibility="{Binding PlaneFlatnessVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendStatus}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#111827"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendPeak}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#111827"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendTolerance}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding DeviationLegendScale}" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
