<UserControl x:Class="OpenVisionLab.ThreeD.Viewer.OpenVisionThreeDViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sharpgl="clr-namespace:SharpGL.WPF;assembly=SharpGL.WPF"
             xmlns:viewModels="clr-namespace:OpenVisionLab.ThreeD.Viewer.ViewModels"
             Background="#f3f4f6">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="ViewerToolbarComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="#1f2937" />
            <Setter Property="Background" Value="#ffffff" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#e6fffb" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#ccfbf1" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ViewerToolbarComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Width" Value="152" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,0,8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1f2937" />
            <Setter Property="Background" Value="#ffffff" />
            <Setter Property="BorderBrush" Value="#94a3b8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ViewerToolbarComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Padding="{TemplateBinding Padding}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="28" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  RecognizesAccessKey="True" />
                                                <Border Grid.Column="1"
                                                        BorderBrush="#cbd5e1"
                                                        BorderThickness="1,0,0,0">
                                                    <Path Width="8"
                                                          Height="5"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Data="M 0,0 L 4,4 L 8,0"
                                                          Stroke="#475569"
                                                          StrokeThickness="1.5" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,3,0,0"
                                        Background="#ffffff"
                                        BorderBrush="#94a3b8"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                    <ScrollViewer Margin="2"
                                                  CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f8fafc" />
                    <Setter Property="BorderBrush" Value="#0f766e" />
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter Property="Background" Value="#f0fdfa" />
                    <Setter Property="BorderBrush" Value="#0f766e" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#0f766e" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#94a3b8" />
                    <Setter Property="Background" Value="#f1f5f9" />
                    <Setter Property="BorderBrush" Value="#cbd5e1" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#ffffff" BorderBrush="#d1d5db" BorderThickness="0,0,0,1">
            <Grid Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#6b7280"
                               Text="Geometry" />
                    <ComboBox Style="{StaticResource ViewerToolbarComboBoxStyle}"
                              ItemsSource="{Binding Display.AvailableGeometryStyles}"
                              SelectedItem="{Binding Display.SelectedGeometryStyle, Mode=TwoWay}"
                              IsEnabled="{Binding Display.CanSelectGeometryStyle, FallbackValue=False}"
                              ToolTip="Select viewer geometry"
                              AutomationProperties.Name="Select viewer geometry style" />
                    <CheckBox Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Content="HUD Details"
                              IsChecked="{Binding HudDetailsVisible, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           Foreground="#374151"
                           Text="{Binding ViewerStatus}" />

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#6b7280"
                               Text="R-drag: Pan" />
                    <Menu Margin="8,0,0,0"
                          Padding="0"
                          VerticalAlignment="Center"
                          Background="#f8fafc"
                          Foreground="#111827">
                        <MenuItem x:Name="ViewerViewMenuRoot"
                                  Padding="7,3"
                                  Header="View ▾"
                                  AutomationProperties.AutomationId="ViewerViewOverflowMenu"
                                  AutomationProperties.Name="Viewer view commands">
                            <MenuItem Header="Fit all"
                                      Command="{Binding FitAllCommand}" />
                            <MenuItem Header="Fit selection"
                                      Command="{Binding FitSelectionCommand}" />
                            <MenuItem Header="Reset view"
                                      Command="{Binding ResetCommand}" />
                            <Separator />
                            <MenuItem Header="Screenshot"
                                      Command="{Binding ScreenshotCommand}" />
                            <Separator />
                            <MenuItem Header="Profile"
                                      Command="{Binding ProfileCommand}"
                                      AutomationProperties.Name="Open height profile" />
                            <Separator />
                            <MenuItem Header="3D Line Fit overlay"
                                      AutomationProperties.Name="3D Line Fit overlay display options">
                                <MenuItem Header="Inlier points"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineFitInliersVisible, Mode=TwoWay}" />
                                <MenuItem Header="Outlier points"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineFitOutliersVisible, Mode=TwoWay}" />
                                <MenuItem Header="Fitted segment and direction"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineFitSegmentVisible, Mode=TwoWay}" />
                                <MenuItem Header="Selected residual"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineFitSelectedResidualVisible, Mode=TwoWay}" />
                            </MenuItem>
                            <MenuItem Header="Line Intersection overlay"
                                      AutomationProperties.Name="Line Intersection overlay display options">
                                <MenuItem Header="First fitted line"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineIntersectionFirstLineVisible, Mode=TwoWay}" />
                                <MenuItem Header="Second fitted line"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineIntersectionSecondLineVisible, Mode=TwoWay}" />
                                <MenuItem Header="Closest-approach connector"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineIntersectionClosestConnectorVisible, Mode=TwoWay}" />
                                <MenuItem Header="Corner anchor midpoint"
                                          IsCheckable="True"
                                          IsChecked="{Binding LineIntersectionCornerAnchorVisible, Mode=TwoWay}" />
                            </MenuItem>
                        </MenuItem>
                    </Menu>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="LeftSidePanel"
                DockPanel.Dock="Left"
                Width="240"
                Background="#ffffff"
                BorderBrush="#d1d5db"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Entities" />
                <CheckBox Margin="0,12,0,0"
                          Content="Generated Unit Cube"
                          IsChecked="{Binding CubeVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Generated Point Cloud"
                          IsChecked="{Binding PointCloudVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="C3D Thickness Sample"
                          IsChecked="{Binding C3DSampleVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="{Binding ImportedMeshLayerLabel}"
                          IsChecked="{Binding GlbSampleVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Public LAZ/LAS Point Cloud"
                          IsChecked="{Binding LazSampleVisible, Mode=TwoWay}" />
                <Separator Margin="0,14,0,10" />
                <StackPanel DataContext="{Binding NominalActual}">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="Nominal / Actual" />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding ActualSourceSummary, FallbackValue='Actual: not loaded'}" />
                    <TextBlock Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding NominalSourceSummary, FallbackValue='Nominal: not loaded'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding QuerySourceSummary, FallbackValue='Validation query: not loaded'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding FrameSummary, FallbackValue='Frame: not set | Units: not set'}" />
                    <WrapPanel Margin="0,7,0,0">
                        <CheckBox Margin="0,0,12,0"
                                  Content="Actual"
                                  IsChecked="{Binding ActualVisible, Mode=TwoWay, FallbackValue=False}"
                                  IsEnabled="{Binding InputsReady, FallbackValue=False}" />
                        <CheckBox Content="Nominal"
                                  IsChecked="{Binding NominalVisible, Mode=TwoWay, FallbackValue=False}"
                                  IsEnabled="{Binding InputsReady, FallbackValue=False}" />
                    </WrapPanel>
                </StackPanel>
                <Separator Margin="0,14,0,10" />
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Display" />
                <TextBlock Margin="0,10,0,4" Foreground="#6b7280" Text="Geometry Style" />
                <ComboBox ItemsSource="{Binding Display.AvailableGeometryStyles}"
                          SelectedItem="{Binding Display.SelectedGeometryStyle, Mode=TwoWay}"
                          IsEnabled="{Binding Display.CanSelectGeometryStyle, FallbackValue=False}">
                </ComboBox>
                <TextBlock Margin="0,10,0,4" Foreground="#6b7280" Text="Color Map" />
                <ComboBox ItemsSource="{Binding Display.AvailableColorMaps}"
                          SelectedItem="{Binding Display.SelectedColorMap, Mode=TwoWay}"
                          IsEnabled="{Binding Display.CanSelectColorMap}" />
                <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Point Size" />
                <Slider Minimum="1"
                        Maximum="6"
                        TickFrequency="0.5"
                        IsSnapToTickEnabled="True"
                        Value="{Binding PointSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="0,2,0,0"
                           Text="{Binding PointSize, StringFormat=Point size: {0:F1}px}" />
                <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Render Density" />
                <ComboBox ItemsSource="{Binding RenderDensityModes}"
                          SelectedItem="{Binding SelectedRenderDensity, Mode=TwoWay}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#6b7280"
                           TextWrapping="Wrap"
                           Text="{Binding RenderDensitySummary}" />
                <StackPanel Margin="0,5,0,0"
                            DataContext="{Binding NominalActual}"
                            Visibility="{Binding InputsReady, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                    <TextBlock Foreground="#374151"
                               TextWrapping="Wrap"
                               Text="{Binding CurrentDisplaySamplingSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding NextPreviewSamplingSummary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#6b7280" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                        <Setter Property="Foreground" Value="#b45309" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <CheckBox Margin="0,12,0,0"
                          Content="Measurement Overlay"
                          IsChecked="{Binding MeasurementVisible, Mode=TwoWay}" />
                <CheckBox Margin="0,8,0,0"
                          Content="Result Overlay"
                          IsChecked="{Binding ResultOverlayVisible, Mode=TwoWay}" />
                <Button Margin="0,8,0,0"
                        Content="Publish Result"
                        Command="{Binding PublishResultCommand}" />
                <Separator Margin="0,16,0,12" />
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Selection" />
                <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="Mode" />
                <ComboBox ItemsSource="{Binding SelectionModes}"
                          SelectedItem="{Binding SelectedSelectionMode, Mode=TwoWay}" />
                <CheckBox Margin="0,12,0,0"
                          Content="Selection Overlay"
                          IsChecked="{Binding SelectionOverlayVisible, Mode=TwoWay}" />
                <Separator Margin="0,16,0,12" />
                <TextBlock Foreground="#6b7280" TextWrapping="Wrap">
                    Drag to orbit. Middle drag or Shift+drag pans. Mouse wheel zooms. Left click the cube to pick the nearest face.
                </TextBlock>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <Border x:Name="RightSidePanel"
                DockPanel.Dock="Right"
                Width="300"
                Background="#ffffff"
                BorderBrush="#d1d5db"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="Inspection" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Selected Entity" />
                <TextBlock FontWeight="SemiBold"
                           Text="{Binding SelectedEntity}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Pick Coordinate" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding PickCoordinate}" />
                <TextBlock Margin="0,12,0,0" Foreground="#6b7280" Text="Measurement" />
                <TextBlock TextWrapping="Wrap"
                           Text="{Binding MeasurementSummary}" />
                <Button Margin="0,8,0,0"
                        Content="Fit C3D Plane"
                        Command="{Binding FitPlaneCommand}" />
                <Separator Margin="0,14,0,10" />
                <StackPanel DataContext="{Binding NominalActual}">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="Surface Deviation" />
                    <TextBlock Margin="0,5,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Text="{Binding StateSummary, FallbackValue='Status: No inputs'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding DirectionSummary, FallbackValue='Direction: Actual to Nominal'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding AlignmentSummary, FallbackValue='Alignment: not set'}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#374151"
                               TextWrapping="Wrap"
                               Text="{Binding CurrentDisplaySamplingSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding NextPreviewSamplingSummary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#6b7280" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                        <Setter Property="Foreground" Value="#b45309" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Lower tolerance" />
                            <TextBox Text="{Binding LowerTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, FallbackValue='-'}"
                                     IsEnabled="{Binding CanEdit, FallbackValue=False}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Upper tolerance" />
                            <TextBox Text="{Binding UpperTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, FallbackValue='-'}"
                                     IsEnabled="{Binding CanEdit, FallbackValue=False}" />
                        </StackPanel>
                    </Grid>
                    <ProgressBar Height="6"
                                 Margin="0,9,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressPercent, Mode=OneWay, FallbackValue=0}" />
                    <TextBlock Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding ProgressSummary, FallbackValue='Progress: not started'}" />
                    <WrapPanel Margin="0,8,0,0">
                        <Button Margin="0,0,6,0"
                                Content="Preview Comparison"
                                Command="{Binding PreviewCommand}"
                                IsEnabled="{Binding CanPreview, FallbackValue=False}" />
                        <Button Margin="0,0,6,0"
                                Content="Cancel"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding CanCancel, FallbackValue=False}" />
                        <Button Content="Publish"
                                Command="{Binding PublishCommand}"
                                IsEnabled="{Binding CanPublish, FallbackValue=False}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding ResultSummary, FallbackValue='No comparison preview.'}" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#6b7280"
                               Text="Selected Deviation Point" />
                    <TextBlock Margin="0,3,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedDeviationSummary, FallbackValue='Selected point: none'}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasSelectedDeviation, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                               Text="{Binding SelectedDeviationDetails}" />
                </StackPanel>
                <StackPanel Visibility="{Binding C3DSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="Thickness ROI Teaching" />
                    <WrapPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Row" />
                            <TextBox Text="{Binding ThicknessRoiRow, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Column" />
                            <TextBox Text="{Binding ThicknessRoiColumn, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Rows" />
                            <TextBox Text="{Binding ThicknessRoiRowCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Columns" />
                            <TextBox Text="{Binding ThicknessRoiColumnCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <StackPanel Width="82" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Lower" />
                            <TextBox Text="{Binding ThicknessMinimum, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="82" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Upper" />
                            <TextBox Text="{Binding ThicknessMaximum, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="82" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Min Samples" />
                            <TextBox Text="{Binding ThicknessMinimumValidSamples, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Margin="0,0,6,0"
                                Content="Teach Thickness ROI"
                                Command="{Binding TeachThicknessRoiCommand}" />
                        <Button Margin="0,0,6,0"
                                Content="Preview Thickness"
                                Command="{Binding PreviewThicknessCommand}" />
                        <Button Content="Publish Result"
                                Command="{Binding PublishResultCommand}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding ThicknessSummary}" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#6b7280"
                               TextWrapping="Wrap"
                               Text="{Binding ThicknessDetails}" />
                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="Point Pair Dimensions" />
                    <WrapPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp D" />
                            <TextBox Text="{Binding PointPairExpectedDistance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol D" />
                            <TextBox Text="{Binding PointPairDistanceTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp W" />
                            <TextBox Text="{Binding PointPairExpectedWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol W" />
                            <TextBox Text="{Binding PointPairWidthTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,6,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Exp A" />
                            <TextBox Text="{Binding PointPairExpectedAngleDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                        <StackPanel Width="58" Margin="0,0,0,6">
                            <TextBlock FontSize="11" Foreground="#6b7280" Text="Tol A" />
                            <TextBox Text="{Binding PointPairAngleToleranceDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Margin="0,0,6,0"
                                Content="Preview Dimensions"
                                Command="{Binding PreviewPointPairDimensionsCommand}" />
                        <Button Content="Publish Result"
                                Command="{Binding PublishResultCommand}" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding PointPairDimensionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
