                                           Foreground="#d1d5db"
                                           Text="{Binding LowerLegendLabel}" />
                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Center"
                                           FontSize="10"
                                           Foreground="#d1d5db"
                                           Text="{Binding ZeroLegendLabel}" />
                                <TextBlock Grid.Column="2"
