<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Workbench visual tokens: dark application chrome, cool light work surfaces, and teal state. -->
    <SolidColorBrush x:Key="ThreeD.AppBackgroundBrush" Color="#DDE7EE" />
    <SolidColorBrush x:Key="ThreeD.PanelBrush" Color="#F8FBFD" />
    <SolidColorBrush x:Key="ThreeD.PanelAlternateBrush" Color="#EEF4F8" />
    <SolidColorBrush x:Key="ThreeD.CommandBarBrush" Color="#F2F6F9" />
    <SolidColorBrush x:Key="ThreeD.ControlBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ThreeD.DividerBrush" Color="#BAC9D4" />
    <SolidColorBrush x:Key="ThreeD.TextBrush" Color="#132238" />
    <SolidColorBrush x:Key="ThreeD.PrimaryTextBrush" Color="#132238" />
    <SolidColorBrush x:Key="ThreeD.SecondaryTextBrush" Color="#3D5063" />
    <SolidColorBrush x:Key="ThreeD.MutedTextBrush" Color="#657789" />
    <SolidColorBrush x:Key="ThreeD.PanelHeaderBrush" Color="#14243A" />
    <SolidColorBrush x:Key="ThreeD.PanelHeaderBorderBrush" Color="#243C56" />
    <SolidColorBrush x:Key="ThreeD.PanelHeaderTextBrush" Color="#F3F8FC" />
    <SolidColorBrush x:Key="ThreeD.PanelHeaderMutedTextBrush" Color="#AABCCD" />
    <SolidColorBrush x:Key="ThreeD.AccentBrush" Color="#087E8B" />
    <SolidColorBrush x:Key="ThreeD.AccentHoverBrush" Color="#056571" />
    <SolidColorBrush x:Key="ThreeD.SelectedSurfaceBrush" Color="#D9F1EE" />
    <SolidColorBrush x:Key="ThreeD.FocusBrush" Color="#0D8DA0" />
    <SolidColorBrush x:Key="ThreeD.PassBrush" Color="#15803D" />
    <SolidColorBrush x:Key="ThreeD.WarningBrush" Color="#B45309" />
    <SolidColorBrush x:Key="ThreeD.FailBrush" Color="#B91C1C" />
    <SolidColorBrush x:Key="ThreeD.InfoBrush" Color="#0369A1" />
    <SolidColorBrush x:Key="ThreeD.DisabledBrush" Color="#9CA3AF" />
    <SolidColorBrush x:Key="ThreeD.ViewportBrush" Color="#101A2A" />
    <SolidColorBrush x:Key="ThreeD.ViewportGridBrush" Color="#526B83" />
    <SolidColorBrush x:Key="ThreeD.AxisXBrush" Color="#E05252" />
    <SolidColorBrush x:Key="ThreeD.AxisYBrush" Color="#2F9D62" />
    <SolidColorBrush x:Key="ThreeD.AxisZBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="ThreeD.WarningSurfaceBrush" Color="#FFF6E8" />
    <SolidColorBrush x:Key="ThreeD.InfoSurfaceBrush" Color="#E4F3F2" />
    <SolidColorBrush x:Key="ThreeD.PassSurfaceBrush" Color="#EAF7EE" />
    <SolidColorBrush x:Key="ThreeD.FailSurfaceBrush" Color="#FCEEEE" />
    <SolidColorBrush x:Key="ThreeD.DisabledSurfaceBrush" Color="#EDF1F4" />

    <Style x:Key="ThreeD.ModeRadioButtonStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="MinWidth" Value="82" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.SecondaryTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="ModeBorder"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ModeBorder" Property="Background" Value="{DynamicResource ThreeD.SelectedSurfaceBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ModeBorder" Property="Background" Value="{DynamicResource ThreeD.AccentBrush}" />
                            <Setter TargetName="ModeBorder" Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ModeBorder" Property="BorderBrush" Value="{DynamicResource ThreeD.FocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ThreeD.DisabledBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThreeD.PanelTitleTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="15.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.TextBrush}" />
    </Style>

    <Style x:Key="ThreeD.WindowHeaderTitleTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.PanelHeaderTextBrush}" />
    </Style>

    <Style x:Key="ThreeD.WindowHeaderSubtitleTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,3,0,0" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.PanelHeaderMutedTextBrush}" />
    </Style>

    <Style x:Key="ThreeD.WindowControlButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="2,0,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.PanelHeaderTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#203650" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ThreeD.WindowCloseButtonStyle"
           BasedOn="{StaticResource ThreeD.WindowControlButtonStyle}"
           TargetType="{x:Type Button}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ThreeD.FailBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ThreeD.FieldLabelTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,8,0,4" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.MutedTextBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="{DynamicResource ThreeD.ControlBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.TextBrush}" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Background" Value="{DynamicResource ThreeD.ControlBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.TextBrush}" />
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.TextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource ThreeD.SelectedSurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ThreeD.TextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ThreeD.CalibrationDataGridRowStyle" TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{DynamicResource ThreeD.PanelBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ThreeD.TextBrush}" />
        <Style.Triggers>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DFF5F2" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                <Setter Property="BorderThickness" Value="0,1,0,1" />
                <Setter Property="Foreground" Value="{DynamicResource ThreeD.TextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ThreeD.CalibrationDataGridStyle" TargetType="{x:Type DataGrid}">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource ThreeD.PanelBrush}" />
        <Setter Property="RowBackground" Value="{DynamicResource ThreeD.PanelBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
        <Setter Property="AlternationCount" Value="2" />
        <Setter Property="RowStyle" Value="{StaticResource ThreeD.CalibrationDataGridRowStyle}" />
        <Setter Property="IsReadOnly" Value="True" />
    </Style>
</ResourceDictionary>
