<Window x:Class="OpenVisionLab.ThreeD.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:OpenVisionLab.ThreeD.Docking.Controls;assembly=OpenVisionLab.ThreeD.Docking.Controls"
        Title="OpenVisionLab 3D Shell"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="620"
        Background="#f3f4f6">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#ffffff" BorderBrush="#d1d5db" BorderThickness="0,0,0,1">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Text="OpenVisionLab 3D Shell" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#6b7280"
                           Text="{Binding StatusText}" />
            </Grid>
        </Border>

        <dock:OpenVisionDockWorkspaceView x:Name="Workspace" />
    </DockPanel>
</Window>
