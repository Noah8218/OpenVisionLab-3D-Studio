<Window x:Class="OpenVisionLab.ThreeD.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:OpenVisionLab.ThreeD.Docking.Controls;assembly=OpenVisionLab.ThreeD.Docking.Controls"
        Title="OpenVisionLab 3D Shell"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="620"
        Background="#f3f4f6">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#ffffff" BorderBrush="#d1d5db" BorderThickness="0,0,0,1">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Text="OpenVisionLab 3D Shell" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#6b7280"
                           Text="{Binding StatusText}" />
            </Grid>
        </Border>

        <dock:OpenVisionDockWorkspaceView x:Name="Workspace">
            <dock:OpenVisionDockWorkspaceView.DataLayersContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,1,0"
                        Padding="12"
                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="Data &amp; Layers" />

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Display State" />
                            <TextBlock Text="{Binding SelectedColorMode, StringFormat=Color: {0}}" />
                            <TextBlock Margin="0,4,0,0" Text="Units: raw height" />
                            <TextBlock Margin="0,4,0,0" Text="Transform: Identity" />

                            <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Point Size" />
                            <Slider Minimum="1"
                                    Maximum="6"
                                    TickFrequency="0.5"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding PointSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding PointSize, StringFormat=Point size: {0:F1}px}" />

                            <TextBlock Margin="0,12,0,4" Foreground="#6b7280" Text="Render Density" />
                            <ComboBox ItemsSource="{Binding RenderDensityModes}"
                                      SelectedItem="{Binding SelectedRenderDensity, Mode=TwoWay}" />
                            <TextBlock Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding RenderDensitySummary}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding C3DSamplePointCount, StringFormat=Rendered C3D points: {0}}" />

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Source Geometry" />
                            <TextBlock FontWeight="SemiBold" Text="Generated Unit Cube" />
                            <TextBlock Margin="0,4,0,0" Text="Generated Point Cloud" />
                            <TextBlock Margin="0,4,0,0" Text="C3D Thickness Sample" />

                            <TextBlock Margin="0,16,0,4" Foreground="#6b7280" Text="Result Layers" />
                            <TextBlock FontWeight="SemiBold" Text="C3D Height Deviation Preview" />
                            <TextBlock Margin="0,4,0,0" Text="Published Result Layer" />

                            <TextBlock Margin="0,16,0,4" Foreground="#6b7280" Text="Contracts" />
                            <TextBlock Text="Source/result separation: active" />
                            <TextBlock Margin="0,4,0,0" Text="Unit metadata: visible" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </dock:OpenVisionDockWorkspaceView.DataLayersContent>

            <dock:OpenVisionDockWorkspaceView.ToolInspectorContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="1,1,0,0"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="Tool / Inspector" />

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Active Tool" />
                            <TextBlock FontWeight="SemiBold" Text="C3D Height Deviation Rule" />

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Rule Parameters" />
                            <TextBlock Text="Tolerance: 1200 raw-height" />
                            <TextBlock Margin="0,4,0,0" Text="Reference: C3D sample average" />
                            <TextBlock Margin="0,4,0,0" Text="Output: preview result layer" />

                            <StackPanel Margin="0,14,0,0"
                                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                                <TextBlock Foreground="#6b7280" Text="Recipe Edit" />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding RecipeSummary}" />
                                <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="Peak Tolerance" />
                                <TextBox Text="{Binding RecipePeakTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />
                                <Button Margin="0,8,0,0"
                                        Content="Save Recipe"
                                        Click="SaveRecipe_Click" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding RecipeSaveSummary}" />
                            </StackPanel>

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Latest Result" />
                            <TextBlock FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="{Binding RecipeComparisonSummary}" />

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Inspection Target" />
                            <TextBlock Text="Selection: current viewport pick" />
                            <TextBlock Margin="0,4,0,0" Text="Overlay: result and measurement evidence" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </dock:OpenVisionDockWorkspaceView.ToolInspectorContent>

            <dock:OpenVisionDockWorkspaceView.EvidenceContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,0,0"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="Evidence Workbench" />
                            <Button Grid.Column="1"
                                    MinWidth="78"
                                    Padding="10,4"
                                    Content="Refresh"
                                    Click="RefreshRecipeComparison_Click" />
                        </Grid>

                        <TabControl Grid.Row="1" Margin="0,8,0,0">
                            <TabItem Header="Result Summary">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock Foreground="#6b7280" Text="Latest Result" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding RecipeComparisonSummary}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Foreground="#6b7280"
                                                       Text="Persisted Evidence" />
                                            <TextBlock Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding RecipeComparisonHistory}" />
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Column="2"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <TextBlock FontFamily="Consolas"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding RecipeComparisonDetails}" />
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Runner Report">
                                <ScrollViewer Margin="10"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="{Binding RecipeComparisonDetails}" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="History">
                                <TextBlock Margin="10"
                                           TextWrapping="Wrap"
                                           Text="{Binding RecipeComparisonHistory}" />
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </dock:OpenVisionDockWorkspaceView.EvidenceContent>

            <dock:OpenVisionDockWorkspaceView.LinkedViewContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,0,0"
                        Padding="10"
                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Height Map" />
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="154" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="150"
                                        Height="54"
                                        HorizontalAlignment="Left"
                                        Background="#111827"
                                        BorderBrush="#d1d5db"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Image Source="{Binding HeightMapImageSource}"
                                           Width="150"
                                           Height="50"
                                           Stretch="Fill"
                                           SnapsToDevicePixels="True" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Foreground="#6b7280"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding HeightMapSummary}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding HeightMapRange}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Profile / Section" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#6b7280"
                                       TextWrapping="Wrap"
                                       Text="{Binding SectionProfileSummary}" />
                            <Border Height="58"
                                    Margin="0,6,0,0"
                                    Background="#f9fafb"
                                    BorderBrush="#d1d5db"
                                    BorderThickness="1"
                                    ClipToBounds="True">
                                <Canvas Width="240" Height="54" Margin="4,1">
                                    <Line X1="0" Y1="27" X2="240" Y2="27" Stroke="#d1d5db" StrokeThickness="1" />
                                    <Path Data="{Binding SectionProfilePathData}"
                                          Stroke="#f59e0b"
                                          StrokeThickness="2"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Canvas>
                            </Border>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#6b7280"
                                       TextWrapping="Wrap"
                                       Text="{Binding SectionProfileRange}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Camera / Pick State" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#6b7280"
                                       Text="{Binding SelectedSelectionMode, StringFormat=Mode: {0}}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#6b7280"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectionSummary}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </dock:OpenVisionDockWorkspaceView.LinkedViewContent>
        </dock:OpenVisionDockWorkspaceView>
    </DockPanel>
</Window>
