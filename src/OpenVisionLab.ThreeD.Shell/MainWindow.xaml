                                <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.ViewerEvidence, Korean='뷰어 증거', English='Viewer Evidence'}" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectionSummary}" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding ViewerStatus}" />
                            </StackPanel>

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.LatestResult, Korean='최근 결과', English='Latest Result'}" />
                            <TextBlock FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="{Binding RecipeComparisonSummary}" />

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.InspectionTarget, Korean='검사 대상', English='Inspection Target'}" />
                            <TextBlock Text="{views:ThreeDText Key=ThreeD.Expert.CurrentViewportSelection, Korean='선택: 현재 뷰포트 선택점', English='Selection: current viewport pick'}" />
                            <TextBlock Margin="0,4,0,0" Text="{views:ThreeDText Key=ThreeD.Expert.ResultMeasurementOverlay, Korean='오버레이: 결과 및 측정 증거', English='Overlay: result and measurement evidence'}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </dock:OpenVisionDockWorkspaceView.ToolInspectorContent>

            <dock:OpenVisionDockWorkspaceView.EvidenceContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,0,0"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="{views:ThreeDText Key=ThreeD.Expert.EvidenceWorkbench, Korean='검사 증거', English='Evidence Workbench'}" />
                            <Button Grid.Column="1"
                                    MinWidth="78"
                                    Padding="10,4"
                                    Content="{views:ThreeDText Key=ThreeD.Command.Refresh, Korean='새로고침', English='Refresh'}"
                                    Command="{Binding RefreshRecipeComparisonCommand}" />
                        </Grid>

                        <TabControl Grid.Row="1"
                                    Margin="0,8,0,0"
                                    SelectedIndex="{Binding SelectedEvidenceTabIndex, Mode=TwoWay}">
                            <TabItem Header="{views:ThreeDText Key=ThreeD.Expert.ResultSummary, Korean='결과 요약', English='Result Summary'}">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,12"
                                                        Visibility="{Binding ViewerContent.ViewModel.NominalActual.InputsReady, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                                <TextBlock Foreground="#6b7280"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding ViewerContent.ViewModel.NominalActual.EvidenceSummary, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}, FallbackValue='No comparison evidence.', TargetNullValue='No comparison evidence.'}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,12"
                                                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}"
                                                        Visibility="{Binding C3DSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.C3DThicknessEvidence, Korean='C3D 두께 증거', English='C3D Thickness Evidence'}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding ThicknessSummary}" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="#6b7280"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding ThicknessDetails}" />
                                                <Grid Margin="0,6,0,0"
                                                      Visibility="{Binding ThicknessVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Mean, Korean='평균', English='Mean'}" />
                                                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMean, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="1" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Minimum, Korean='최소', English='Minimum'}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMinimumMeasured, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="2" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Maximum, Korean='최대', English='Maximum'}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMaximumMeasured, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="3" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Range, Korean='범위', English='Range'}" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessRange, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.ValidSamples, Korean='유효 샘플', English='Valid samples'}" />
                                                    <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessValidSampleCount, StringFormat={}{0:N0}}" />
                                                </Grid>
                                            </StackPanel>
                                            <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.LatestResult, Korean='최근 결과', English='Latest Result'}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding RecipeComparisonSummary}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Foreground="#6b7280"
                                                       Text="{views:ThreeDText Key=ThreeD.Expert.PersistedEvidence, Korean='저장된 증거', English='Persisted Evidence'}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding RecipeComparisonHistory}" />
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Column="2"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <TextBlock FontFamily="Consolas"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding RecipeComparisonDetails}" />
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>
                            <TabItem Header="{views:ThreeDText Key=ThreeD.Expert.RunnerReport, Korean='러너 보고서', English='Runner Report'}">
                                <ScrollViewer Margin="10"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="{Binding RecipeComparisonDetails}" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="{views:ThreeDText Key=ThreeD.Expert.RunSnapshot, Korean='실행 스냅샷', English='Run Snapshot'}">
                                <ScrollViewer Margin="10"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding RunSnapshotSummary}" />
                                        <WrapPanel Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   HorizontalAlignment="Right">
                                            <Button MinWidth="90"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="{views:ThreeDText Key=ThreeD.Command.UiContract, Korean='UI 계약', English='UI Contract'}"
                                                    Command="{Binding OpenUiContractCommand}" />
                                            <Button MinWidth="90"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="{views:ThreeDText Key=ThreeD.Expert.RunnerReport, Korean='러너 보고서', English='Runner Report'}"
                                                    Command="{Binding OpenRunnerReportCommand}" />
                                            <Button MinWidth="86"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="{views:ThreeDText Key=ThreeD.Command.Screenshot, Korean='스크린샷', English='Screenshot'}"
                                                    Command="{Binding OpenShellScreenshotCommand}" />
                                            <Button MinWidth="82"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="{views:ThreeDText Key=ThreeD.Command.RunJson, Korean='실행 JSON', English='Run JSON'}"
                                                    Command="{Binding OpenRunRecordCommand}" />
                                            <Button MinWidth="90"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="{views:ThreeDText Key=ThreeD.Command.HtmlReport, Korean='HTML 보고서', English='HTML Report'}"
                                                    Command="{Binding OpenHtmlReportCommand}" />
                                            <Button MinWidth="86"
                                                    Margin="0,0,0,4"
                                                    Padding="6,3"
                                                    Content="{views:ThreeDText Key=ThreeD.Command.CsvReport, Korean='CSV 보고서', English='CSV Report'}"
                                                    Command="{Binding OpenCsvReportCommand}" />
                                        </WrapPanel>
                                        <TextBlock FontFamily="Consolas"
                                                   FontSize="12"
                                                   Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding RunSnapshotEvidence}" />
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="{views:ThreeDText Key=ThreeD.Expert.Steps, Korean='단계', English='Steps'}">
                                <DockPanel Margin="6,3">
                                    <TextBlock DockPanel.Dock="Top"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding InspectionStepSummary}" />
                                    <ScrollViewer Margin="0,2,0,0"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding InspectionSteps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border MinHeight="22"
                                                            Padding="2"
                                                            Background="#f9fafb"
                                                            BorderBrush="#d1d5db"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="26" />
                                                                <ColumnDefinition Width="150" />
                                                                <ColumnDefinition Width="70" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock FontWeight="SemiBold"
                                                                       Text="{Binding Order}" />
                                                            <TextBlock Grid.Column="1"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding Stage}" />
                                                            <TextBlock Grid.Column="2"
                                                                       Margin="6,0,0,0"
                                                                       Text="{Binding Status}" />
                                                            <TextBlock Grid.Column="3"
                                                                       Foreground="#374151"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding Evidence}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="{views:ThreeDText Key=ThreeD.Expert.History, Korean='이력', English='History'}">
                                <ItemsControl Margin="10"
                                              ItemsSource="{Binding RecipeRunHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="6"
                                                    Background="#f9fafb"
                                                    BorderBrush="#d1d5db"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="270" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding RunTime}" />
                                                    <TextBlock Grid.Column="1"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Status}" />
                                                    <TextBlock Grid.Column="2"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding KeyMetricSummary}" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding EvidenceState}" />
                                                    <TextBlock Grid.Column="4"
                                                               Foreground="#6b7280"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding ReportPath}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </dock:OpenVisionDockWorkspaceView.EvidenceContent>

            <dock:OpenVisionDockWorkspaceView.LinkedViewContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,0,0"
                        Padding="10"
                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,12,0">
                                <StackPanel Margin="0,0,0,8"
                                            DataContext="{Binding NominalActual}"
                                            Visibility="{Binding DistributionVisible, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Text="Deviation Distribution" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding DistributionSummary}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Foreground="#374151"
                                               TextWrapping="Wrap"
                                               Text="{Binding CurrentDisplaySamplingSummary}" />
                                    <TextBlock Margin="0,3,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding NextPreviewSamplingSummary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#6b7280" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                                        <Setter Property="Foreground" Value="#b45309" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding C3DSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Height Map" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="154" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="150"
                                                Height="54"
                                                HorizontalAlignment="Left"
                                                Background="#111827"
                                                BorderBrush="#d1d5db"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Image Source="{Binding HeightMapImageSource}"
                                                   Width="150"
                                                   Height="50"
                                                   Stretch="Fill"
                                                   SnapsToDevicePixels="True" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Foreground="#6b7280"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding HeightMapSummary}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#6b7280"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding HeightMapRange}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LazSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Point Cloud Sample" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding LazSampleName}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding LazSampleSummary}" />
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GlbSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Mesh Sample" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding GlbSampleName}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding GlbSampleSummary}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding C3DSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Profile / Section" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding SectionProfileSummary}" />
                                    <Border Height="58"
                                            Margin="0,6,0,0"
                                            Background="#f9fafb"
                                            BorderBrush="#d1d5db"
                                            BorderThickness="1"
                                            ClipToBounds="True">
                                        <Canvas Width="240" Height="54" Margin="4,1">
                                            <Line X1="0" Y1="27" X2="240" Y2="27" Stroke="#d1d5db" StrokeThickness="1" />
                                            <Path Data="{Binding SectionProfilePathData}"
                                                  Stroke="#f59e0b"
                                                  StrokeThickness="2"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Border>
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding SectionProfileRange}" />
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LazSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GlbSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Linked Measurement" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding MeasurementSummary}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding PickCoordinate, StringFormat=Pick: {0}}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Camera / Pick State" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#6b7280"
                                           Text="{Binding SelectedSelectionMode, StringFormat=Mode: {0}}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectionSummary}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </dock:OpenVisionDockWorkspaceView.LinkedViewContent>
            <dock:OpenVisionDockWorkspaceView.ProfileContent>
                <workbench:HeightProfileView />
            </dock:OpenVisionDockWorkspaceView.ProfileContent>
            <dock:OpenVisionDockWorkspaceView.IntersectionEvidenceContent>
                <workbench:LineIntersectionEvidenceView DataContext="{Binding Workbench}" />
            </dock:OpenVisionDockWorkspaceView.IntersectionEvidenceContent>
            <dock:OpenVisionDockWorkspaceView.CorrespondenceEvidenceContent>
                <workbench:LandmarkCorrespondenceEvidenceView DataContext="{Binding Workbench}" />
            </dock:OpenVisionDockWorkspaceView.CorrespondenceEvidenceContent>
        </dock:OpenVisionDockWorkspaceView>
        <views:CalibrationCenterView DataContext="{Binding Calibration}"
                                     Visibility="{Binding DataContext.IsCalibrationWorkspaceSelected, ElementName=ShellWindow, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </DockPanel>
</Window>
