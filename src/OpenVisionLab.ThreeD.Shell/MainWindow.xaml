                                        Content="Align From ROI"
                                        Command="{Binding DataContext.ApplyRoiAlignmentCommand, ElementName=ShellWindow}" />
                                <WrapPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="T X" />
                                        <TextBox Text="{Binding RecipeTransformTranslateX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="T Y" />
                                        <TextBox Text="{Binding RecipeTransformTranslateY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="T Z" />
                                        <TextBox Text="{Binding RecipeTransformTranslateZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="R X" />
                                        <TextBox Text="{Binding RecipeTransformRotateXDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F1}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="R Y" />
                                        <TextBox Text="{Binding RecipeTransformRotateYDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F1}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="R Z" />
                                        <TextBox Text="{Binding RecipeTransformRotateZDegrees, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F1}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="Scale" />
                                        <TextBox Text="{Binding RecipeTransformScale, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                </WrapPanel>
                                <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="ROI Left" />
                                <WrapPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="C X" />
                                        <TextBox Text="{Binding RecipeRoiLeftCenterX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="C Z" />
                                        <TextBox Text="{Binding RecipeRoiLeftCenterZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="Half W" />
                                        <TextBox Text="{Binding RecipeRoiLeftHalfWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="Half D" />
                                        <TextBox Text="{Binding RecipeRoiLeftHalfDepth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                </WrapPanel>
                                <TextBlock Margin="0,8,0,4" Foreground="#6b7280" Text="ROI Right" />
                                <WrapPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="C X" />
                                        <TextBox Text="{Binding RecipeRoiRightCenterX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="C Z" />
                                        <TextBox Text="{Binding RecipeRoiRightCenterZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="Half W" />
                                        <TextBox Text="{Binding RecipeRoiRightHalfWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                    <StackPanel Width="64" Margin="0,0,6,6">
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="Half D" />
                                        <TextBox Text="{Binding RecipeRoiRightHalfDepth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                    </StackPanel>
                                </WrapPanel>
                                <TextBlock Margin="0,2,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding RecipeParameterSummary}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding AlignmentWorkflowSummary}" />
                                <Button Margin="0,8,0,0"
                                        Content="Save Recipe"
                                        Command="{Binding DataContext.SaveRecipeCommand, ElementName=ShellWindow}" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding RecipeSaveSummary}" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0"
                                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                                <TextBlock Foreground="#6b7280" Text="Viewer Evidence" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectionSummary}" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding ViewerStatus}" />
                            </StackPanel>

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Latest Result" />
                            <TextBlock FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="{Binding RecipeComparisonSummary}" />

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="Inspection Target" />
                            <TextBlock Text="Selection: current viewport pick" />
                            <TextBlock Margin="0,4,0,0" Text="Overlay: result and measurement evidence" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </dock:OpenVisionDockWorkspaceView.ToolInspectorContent>

            <dock:OpenVisionDockWorkspaceView.EvidenceContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,0,0"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="Evidence Workbench" />
                            <Button Grid.Column="1"
                                    MinWidth="78"
                                    Padding="10,4"
                                    Content="Refresh"
                                    Command="{Binding RefreshRecipeComparisonCommand}" />
                        </Grid>

                        <TabControl Grid.Row="1"
                                    Margin="0,8,0,0"
                                    SelectedIndex="{Binding SelectedEvidenceTabIndex, Mode=TwoWay}">
                            <TabItem Header="Result Summary">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,12"
                                                        Visibility="{Binding ViewerContent.ViewModel.NominalActual.InputsReady, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                                <TextBlock Foreground="#6b7280"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding ViewerContent.ViewModel.NominalActual.EvidenceSummary, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}, FallbackValue='No comparison evidence.', TargetNullValue='No comparison evidence.'}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,12"
                                                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}"
                                                        Visibility="{Binding C3DSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Foreground="#6b7280" Text="C3D Thickness Evidence" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding ThicknessSummary}" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="#6b7280"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding ThicknessDetails}" />
                                                <Grid Margin="0,6,0,0"
                                                      Visibility="{Binding ThicknessVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Foreground="#6b7280" Text="Mean" />
                                                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMean, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="1" Foreground="#6b7280" Text="Minimum" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMinimumMeasured, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="2" Foreground="#6b7280" Text="Maximum" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMaximumMeasured, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="3" Foreground="#6b7280" Text="Range" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessRange, StringFormat={}{0:F3}}" />
                                                    <TextBlock Grid.Row="4" Foreground="#6b7280" Text="Valid samples" />
                                                    <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessValidSampleCount, StringFormat={}{0:N0}}" />
                                                </Grid>
                                            </StackPanel>
                                            <TextBlock Foreground="#6b7280" Text="Latest Result" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding RecipeComparisonSummary}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Foreground="#6b7280"
                                                       Text="Persisted Evidence" />
                                            <TextBlock Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding RecipeComparisonHistory}" />
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Column="2"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <TextBlock FontFamily="Consolas"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding RecipeComparisonDetails}" />
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Runner Report">
                                <ScrollViewer Margin="10"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="{Binding RecipeComparisonDetails}" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Run Snapshot">
                                <ScrollViewer Margin="10"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding RunSnapshotSummary}" />
                                        <WrapPanel Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   HorizontalAlignment="Right">
                                            <Button MinWidth="90"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="UI Contract"
                                                    Command="{Binding OpenUiContractCommand}" />
                                            <Button MinWidth="90"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="Runner Report"
                                                    Command="{Binding OpenRunnerReportCommand}" />
                                            <Button MinWidth="86"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="Screenshot"
                                                    Command="{Binding OpenShellScreenshotCommand}" />
                                            <Button MinWidth="82"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="Run JSON"
                                                    Command="{Binding OpenRunRecordCommand}" />
                                            <Button MinWidth="90"
                                                    Margin="0,0,6,4"
                                                    Padding="6,3"
                                                    Content="HTML Report"
                                                    Command="{Binding OpenHtmlReportCommand}" />
                                            <Button MinWidth="86"
                                                    Margin="0,0,0,4"
                                                    Padding="6,3"
                                                    Content="CSV Report"
                                                    Command="{Binding OpenCsvReportCommand}" />
                                        </WrapPanel>
                                        <TextBlock FontFamily="Consolas"
                                                   FontSize="12"
                                                   Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding RunSnapshotEvidence}" />
                                    </Grid>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Steps">
                                <DockPanel Margin="6,3">
                                    <TextBlock DockPanel.Dock="Top"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding InspectionStepSummary}" />
                                    <ScrollViewer Margin="0,2,0,0"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding InspectionSteps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border MinHeight="22"
                                                            Padding="2"
                                                            Background="#f9fafb"
                                                            BorderBrush="#d1d5db"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="26" />
                                                                <ColumnDefinition Width="150" />
                                                                <ColumnDefinition Width="70" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock FontWeight="SemiBold"
                                                                       Text="{Binding Order}" />
                                                            <TextBlock Grid.Column="1"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding Stage}" />
                                                            <TextBlock Grid.Column="2"
                                                                       Margin="6,0,0,0"
                                                                       Text="{Binding Status}" />
                                                            <TextBlock Grid.Column="3"
                                                                       Foreground="#374151"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding Evidence}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="History">
                                <ItemsControl Margin="10"
                                              ItemsSource="{Binding RecipeRunHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="6"
                                                    Background="#f9fafb"
                                                    BorderBrush="#d1d5db"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="270" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding RunTime}" />
                                                    <TextBlock Grid.Column="1"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Status}" />
                                                    <TextBlock Grid.Column="2"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding KeyMetricSummary}" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding EvidenceState}" />
                                                    <TextBlock Grid.Column="4"
                                                               Foreground="#6b7280"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding ReportPath}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </dock:OpenVisionDockWorkspaceView.EvidenceContent>

            <dock:OpenVisionDockWorkspaceView.LinkedViewContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,0,0"
                        Padding="10"
                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,12,0">
                                <StackPanel Margin="0,0,0,8"
                                            DataContext="{Binding NominalActual}"
                                            Visibility="{Binding DistributionVisible, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Text="Deviation Distribution" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding DistributionSummary}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Foreground="#374151"
                                               TextWrapping="Wrap"
                                               Text="{Binding CurrentDisplaySamplingSummary}" />
                                    <TextBlock Margin="0,3,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding NextPreviewSamplingSummary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#6b7280" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                                        <Setter Property="Foreground" Value="#b45309" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding C3DSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Height Map" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="154" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="150"
                                                Height="54"
                                                HorizontalAlignment="Left"
                                                Background="#111827"
                                                BorderBrush="#d1d5db"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Image Source="{Binding HeightMapImageSource}"
                                                   Width="150"
                                                   Height="50"
                                                   Stretch="Fill"
                                                   SnapsToDevicePixels="True" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Foreground="#6b7280"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding HeightMapSummary}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#6b7280"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding HeightMapRange}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LazSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Point Cloud Sample" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding LazSampleName}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding LazSampleSummary}" />
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GlbSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Mesh Sample" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding GlbSampleName}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding GlbSampleSummary}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding C3DSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Profile / Section" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding SectionProfileSummary}" />
                                    <Border Height="58"
                                            Margin="0,6,0,0"
                                            Background="#f9fafb"
                                            BorderBrush="#d1d5db"
                                            BorderThickness="1"
                                            ClipToBounds="True">
                                        <Canvas Width="240" Height="54" Margin="4,1">
                                            <Line X1="0" Y1="27" X2="240" Y2="27" Stroke="#d1d5db" StrokeThickness="1" />
                                            <Path Data="{Binding SectionProfilePathData}"
                                                  Stroke="#f59e0b"
                                                  StrokeThickness="2"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Border>
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding SectionProfileRange}" />
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LazSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GlbSampleVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Linked Measurement" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding MeasurementSummary}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding PickCoordinate, StringFormat=Pick: {0}}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Foreground="#111827" Text="Camera / Pick State" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#6b7280"
                                           Text="{Binding SelectedSelectionMode, StringFormat=Mode: {0}}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectionSummary}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </dock:OpenVisionDockWorkspaceView.LinkedViewContent>
            <dock:OpenVisionDockWorkspaceView.ProfileContent>
                <workbench:HeightProfileView />
            </dock:OpenVisionDockWorkspaceView.ProfileContent>
            <dock:OpenVisionDockWorkspaceView.IntersectionEvidenceContent>
                <workbench:LineIntersectionEvidenceView DataContext="{Binding Workbench}" />
            </dock:OpenVisionDockWorkspaceView.IntersectionEvidenceContent>
            <dock:OpenVisionDockWorkspaceView.CorrespondenceEvidenceContent>
                <workbench:LandmarkCorrespondenceEvidenceView DataContext="{Binding Workbench}" />
            </dock:OpenVisionDockWorkspaceView.CorrespondenceEvidenceContent>
        </dock:OpenVisionDockWorkspaceView>
        <views:CalibrationCenterView DataContext="{Binding Calibration}"
                                     Visibility="{Binding DataContext.IsCalibrationWorkspaceSelected, ElementName=ShellWindow, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </DockPanel>
</Window>
