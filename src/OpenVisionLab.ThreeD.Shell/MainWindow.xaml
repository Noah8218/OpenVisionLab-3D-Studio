<Window x:Name="ShellWindow"
        x:Class="OpenVisionLab.ThreeD.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:OpenVisionLab.ThreeD.Docking.Controls;assembly=OpenVisionLab.ThreeD.Docking.Controls"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shellChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:OpenVisionLab.ThreeD.Shell"
        xmlns:shellViews="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Shell"
        xmlns:workbench="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Workbench"
        xmlns:workspace="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Workspace"
        Title="OpenVisionLab 3D Studio"
        Width="1600"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource ThreeD.AppBackgroundBrush}">
    <shellChrome:WindowChrome.WindowChrome>
        <shellChrome:WindowChrome CaptionHeight="56"
                                  ResizeBorderThickness="6"
                                  GlassFrameThickness="0"
                                  UseAeroCaptionButtons="False" />
    </shellChrome:WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <DockPanel LastChildFill="True">
        <shellViews:StudioHeaderView DockPanel.Dock="Top"
                                     RecipeManagerRequested="OpenRecipeManagerRequested"
                                     FilterToolLabRequested="OpenFilterToolLabRequested"
                                     EdgeToolLabRequested="OpenEdgeToolLabRequested"
                                     TwoPointLineToolLabRequested="OpenTwoPointLineToolLabRequested"
                                     ThreePointPlaneToolLabRequested="OpenThreePointPlaneToolLabRequested"
                                     DatumPlaneDeviationToolLabRequested="OpenDatumPlaneDeviationToolLabRequested"
                                     LineIntersectionToolLabRequested="OpenLineIntersectionToolLabRequested"
                                     LandmarkCorrespondenceToolLabRequested="OpenLandmarkCorrespondenceToolLabRequested"
                                     XYZAffineSolveToolLabRequested="OpenXYZAffineSolveToolLabRequested"
                                     XYZAffineApplyToolLabRequested="OpenXYZAffineApplyToolLabRequested"
                                     RegridHeightMapToolLabRequested="OpenRegridHeightMapToolLabRequested" />

        <Grid>
        <workbench:ToolRecipeWorkbenchView x:Name="ToolWorkbench"
                                           Visibility="{Binding IsWorkbenchWorkspaceSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
        <workspace:ThicknessTaskWorkspaceView x:Name="TaskWorkspace"
                                               Visibility="{Binding IsTaskWorkspaceSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
        <dock:OpenVisionDockWorkspaceView x:Name="Workspace"
                                           ToolLibraryTitle="{Binding Localization.ToolLibrary}"
                                           ViewerTitle="{views:ThreeDText Key=ThreeD.Expert.ViewerPane, Korean='3D 검사 보기', English='3D Inspection View'}"
                                           DataLayersTitle="{views:ThreeDText Key=ThreeD.Expert.DataLayersPane, Korean='데이터 및 레이어', English='Data &amp; Layers'}"
                                           ToolInspectorTitle="{views:ThreeDText Key=ThreeD.Expert.ToolInspectorPane, Korean='도구 / 속성', English='Tool / Inspector'}"
                                           EvidenceTitle="{views:ThreeDText Key=ThreeD.Expert.EvidencePane, Korean='검사 증거', English='Evidence Workbench'}"
                                           OutputCompareTitle="{Binding Localization.OutputCompare}"
                                           DisplayedOutputsTitle="{Binding Localization.DisplayedOutputs}"
                                           LinkedViewTitle="{views:ThreeDText Key=ThreeD.Expert.LinkedView, Korean='연결 보기', English='Linked View'}"
                                           ProfileTitle="{Binding Localization.HeightProfile}"
                                           FitDiagnosticsTitle="{Binding Localization.FitDiagnostics}"
                                           IntersectionEvidenceTitle="{Binding Localization.IntersectionEvidence}"
                                           CorrespondenceEvidenceTitle="{Binding Localization.CorrespondenceEvidence}"
                                           Visibility="{Binding IsExpertWorkspaceSelected, Converter={StaticResource BoolToVisibilityConverter}}">
            <dock:OpenVisionDockWorkspaceView.ToolLibraryContent>
                <workbench:ToolLibraryView DataContext="{Binding Workbench}" />
            </dock:OpenVisionDockWorkspaceView.ToolLibraryContent>
            <dock:OpenVisionDockWorkspaceView.DataLayersContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="0,1,1,0"
                        Padding="12"
                        DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="{views:ThreeDText Key=ThreeD.Expert.DataLayers, Korean='데이터 및 레이어', English='Data &amp; Layers'}" />

                            <StackPanel Margin="0,12,0,0"
                                        Visibility="{Binding C3DSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.ActiveThicknessResult, Korean='현재 두께 결과', English='Active Thickness Result'}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding ThicknessSummary}" />
                                <TextBlock Margin="0,3,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding ThicknessDetails}" />
                                <Grid Margin="0,6,0,0"
                                      Visibility="{Binding ThicknessVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Mean, Korean='평균', English='Mean'}" />
                                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMean, StringFormat={}{0:F3}}" />
                                    <TextBlock Grid.Row="1" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Minimum, Korean='최소', English='Minimum'}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMinimumMeasured, StringFormat={}{0:F3}}" />
                                    <TextBlock Grid.Row="2" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Maximum, Korean='최대', English='Maximum'}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessMaximumMeasured, StringFormat={}{0:F3}}" />
                                    <TextBlock Grid.Row="3" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.Range, Korean='범위', English='Range'}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessRange, StringFormat={}{0:F3}}" />
                                    <TextBlock Grid.Row="4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Metric.ValidSamples, Korean='유효 샘플', English='Valid samples'}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding ThicknessValidSampleCount, StringFormat={}{0:N0}}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Margin="0,12,0,0"
                                        DataContext="{Binding NominalActual}">
                                <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.NominalActual, Korean='기준 / 실제', English='Nominal / Actual'}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding ActualSourceSummary, FallbackValue='Actual: not loaded'}" />
                                <TextBlock Margin="0,3,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding NominalSourceSummary, FallbackValue='Nominal: not loaded'}" />
                                <TextBlock Margin="0,3,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding QuerySourceSummary, FallbackValue='Validation query: not loaded'}" />
                                <TextBlock Margin="0,3,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding FrameSummary, FallbackValue='Frame: not set | Units: not set'}" />
                                <WrapPanel Margin="0,6,0,0">
                                    <CheckBox Margin="0,0,12,0"
                                              Content="{views:ThreeDText Key=ThreeD.Expert.Actual, Korean='실제', English='Actual'}"
                                              IsChecked="{Binding ActualVisible, Mode=TwoWay, FallbackValue=False}"
                                              IsEnabled="{Binding InputsReady, FallbackValue=False}" />
                                    <CheckBox Content="{views:ThreeDText Key=ThreeD.Expert.Nominal, Korean='기준', English='Nominal'}"
                                              IsChecked="{Binding NominalVisible, Mode=TwoWay, FallbackValue=False}"
                                              IsEnabled="{Binding InputsReady, FallbackValue=False}" />
                                </WrapPanel>
                            </StackPanel>

                            <Separator Margin="0,8,0,6" />
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="{views:ThreeDText Key=ThreeD.Expert.Display, Korean='표시', English='Display'}" />
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Margin="0,0,0,4" FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.GeometryStyle, Korean='형상 스타일', English='Geometry Style'}" />
                                    <ComboBox ItemsSource="{Binding Display.AvailableGeometryStyles}"
                                              SelectedItem="{Binding Display.SelectedGeometryStyle, Mode=TwoWay}"
                                              IsEnabled="{Binding Display.CanSelectGeometryStyle, FallbackValue=False}">
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Margin="0,0,0,4" FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.ColorMap, Korean='컬러 맵', English='Color Map'}" />
                                    <ComboBox ItemsSource="{Binding Display.AvailableColorMaps}"
                                              SelectedItem="{Binding Display.SelectedColorMap, Mode=TwoWay}"
                                              IsEnabled="{Binding Display.CanSelectColorMap}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Margin="0,0,0,2"
                                               FontSize="11"
                                               Foreground="#6b7280"
                                               Text="{Binding PointSize, StringFormat=Point Size ({0:F1}px)}" />
                                    <Slider Minimum="1"
                                            Maximum="6"
                                            TickFrequency="0.5"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding PointSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Margin="0,0,0,4" FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.RenderDensity, Korean='렌더 밀도', English='Render Density'}" />
                                    <ComboBox ItemsSource="{Binding RenderDensityModes}"
                                              SelectedItem="{Binding SelectedRenderDensity, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="11"
                                       Foreground="#6b7280"
                                       TextWrapping="Wrap"
                                       Text="{Binding RenderDensitySummary}" />
                            <StackPanel Margin="0,5,0,0"
                                        DataContext="{Binding NominalActual}"
                                        Visibility="{Binding InputsReady, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                <TextBlock Foreground="#374151"
                                           TextWrapping="Wrap"
                                           Text="{Binding CurrentDisplaySamplingSummary}" />
                                <TextBlock Margin="0,3,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding NextPreviewSamplingSummary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#6b7280" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                                    <Setter Property="Foreground" Value="#b45309" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.DisplayState, Korean='표시 상태', English='Display State'}" />
                            <TextBlock Text="{Binding SelectedEntity, StringFormat=Active: {0}}" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding CoordinateFrameSummary}" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding SceneContractSummary}" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding TransformSummary}" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding AlignmentSummary}" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding CoordinateMappingSummary}" />
                            <TextBlock Margin="0,4,0,0"
                                       Visibility="{Binding C3DSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding C3DSamplePointCount, StringFormat=Rendered C3D points: {0}}" />
                            <StackPanel Visibility="{Binding LazSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding LazSampleSummary}" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding LazSamplingSummary}" />
                            </StackPanel>

                            <TextBlock Margin="0,14,0,4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.EntityLayers, Korean='엔티티 레이어', English='Entity Layers'}" />
                            <ItemsControl ItemsSource="{Binding EntityLayers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Foreground="#6b7280"
                                                       Text="{Binding Kind, StringFormat=Kind: {0}}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Foreground="#6b7280"
                                                       Text="{Binding IsVisible, StringFormat=Visible: {0}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Margin="0,16,0,4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.Contracts, Korean='계약', English='Contracts'}" />
                            <TextBlock Text="{views:ThreeDText Key=ThreeD.Expert.SourceResultContract, Korean='원본/결과 분리: 적용', English='Source/result separation: active'}" />
                            <TextBlock Margin="0,4,0,0" Text="{views:ThreeDText Key=ThreeD.Expert.UnitMetadataContract, Korean='단위 메타데이터: 표시', English='Unit metadata: visible'}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </dock:OpenVisionDockWorkspaceView.DataLayersContent>

            <dock:OpenVisionDockWorkspaceView.ToolInspectorContent>
                <Border Background="#ffffff"
                        BorderBrush="#d1d5db"
                        BorderThickness="1,1,0,0"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="{views:ThreeDText Key=ThreeD.Expert.ToolInspector, Korean='도구 / 속성', English='Tool / Inspector'}" />

                            <StackPanel Margin="0,12,0,0"
                                        DataContext="{Binding ViewerContent.ViewModel.NominalActual, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}"
                                        Visibility="{Binding InputsReady, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                                <TextBlock Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.SurfaceDeviation, Korean='표면 편차', English='Surface Deviation'}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding StateSummary, FallbackValue='Status: No inputs'}" />
                                <TextBlock Margin="0,3,0,0"
                                           Foreground="#6b7280"
                                           TextWrapping="Wrap"
                                           Text="{Binding DirectionSummary, FallbackValue='Direction: Actual to Nominal'}" />
                                <TextBlock Margin="0,5,0,0"
                                           Foreground="#374151"
                                           TextWrapping="Wrap"
                                           Text="{Binding CurrentDisplaySamplingSummary}" />
                                <TextBlock Margin="0,3,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding NextPreviewSamplingSummary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#6b7280" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DisplaySamplingChangePending}" Value="True">
                                                    <Setter Property="Foreground" Value="#b45309" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ProgressBar Height="6"
                                             Margin="0,7,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding ProgressPercent, Mode=OneWay, FallbackValue=0}" />
                                <WrapPanel Margin="0,7,0,0">
                                    <Button Margin="0,0,6,4"
                                            Content="{views:ThreeDText Key=ThreeD.Command.PreviewComparison, Korean='비교 미리보기', English='Preview Comparison'}"
                                            Command="{Binding PreviewCommand}"
                                            IsEnabled="{Binding CanPreview, FallbackValue=False}" />
                                    <Button Margin="0,0,6,4"
                                            Content="{views:ThreeDText Key=ThreeD.Command.Cancel, Korean='취소', English='Cancel'}"
                                            Command="{Binding CancelCommand}"
                                            IsEnabled="{Binding CanCancel, FallbackValue=False}" />
                                    <Button Margin="0,0,0,4"
                                            Content="{views:ThreeDText Key=ThreeD.Command.Publish, Korean='게시', English='Publish'}"
                                            Command="{Binding PublishCommand}"
                                            IsEnabled="{Binding CanPublish, FallbackValue=False}" />
                                </WrapPanel>
                            </StackPanel>

                            <TextBlock Margin="0,0,0,4" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Expert.ActiveTool, Korean='현재 도구', English='Active Tool'}" />
                            <StackPanel DataContext="{Binding ViewerContent.ViewModel, RelativeSource={RelativeSource AncestorType=dock:OpenVisionDockWorkspaceView}}">
                                <TextBlock FontWeight="SemiBold" Text="{Binding SelectedEntity}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#6b7280"
                                           Text="{Binding SelectedSelectionMode, StringFormat=Mode: {0}}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#374151"
                                           TextWrapping="Wrap"
                                           Text="{Binding ViewerStatus}" />
                                <TextBlock Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding MeasurementSummary}" />
                                <Button Margin="0,8,0,0"
                                        Content="{views:ThreeDText Key=ThreeD.Expert.FitC3DPlane, Korean='C3D 평면 피팅', English='Fit C3D Plane'}"
                                        Command="{Binding DataContext.FitPlaneCommand, ElementName=ShellWindow}" />
                                <StackPanel Visibility="{Binding C3DSampleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Margin="0,12,0,4"
                                               FontWeight="SemiBold"
                                               Text="{views:ThreeDText Key=ThreeD.Expert.ThicknessRoiTeaching, Korean='두께 ROI 티칭', English='Thickness ROI Teaching'}" />
                                    <WrapPanel>
                                        <StackPanel Width="58" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.Row, Korean='행', English='Row'}" />
                                            <TextBox Text="{Binding ThicknessRoiRow, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        </StackPanel>
                                        <StackPanel Width="58" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.Column, Korean='열', English='Column'}" />
                                            <TextBox Text="{Binding ThicknessRoiColumn, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        </StackPanel>
                                        <StackPanel Width="58" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.Rows, Korean='행 수', English='Rows'}" />
                                            <TextBox Text="{Binding ThicknessRoiRowCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        </StackPanel>
                                        <StackPanel Width="58" Margin="0,0,0,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.Columns, Korean='열 수', English='Columns'}" />
                                            <TextBox Text="{Binding ThicknessRoiColumnCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        </StackPanel>
                                    </WrapPanel>
                                    <WrapPanel>
                                        <StackPanel Width="82" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.Lower, Korean='하한', English='Lower'}" />
                                            <TextBox Text="{Binding ThicknessMinimum, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                        </StackPanel>
                                        <StackPanel Width="82" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.Upper, Korean='상한', English='Upper'}" />
                                            <TextBox Text="{Binding ThicknessMaximum, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                        </StackPanel>
                                        <StackPanel Width="82" Margin="0,0,0,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.MinSamples, Korean='최소 샘플', English='Min Samples'}" />
                                            <TextBox Text="{Binding ThicknessMinimumValidSamples, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        </StackPanel>
                                    </WrapPanel>
                                    <WrapPanel>
                                        <Button Margin="0,0,6,0"
                                                Content="{views:ThreeDText Key=ThreeD.Command.TeachThicknessRoi, Korean='두께 ROI 티칭', English='Teach Thickness ROI'}"
                                                Command="{Binding TeachThicknessRoiCommand}" />
                                        <Button Margin="0,0,6,0"
                                                Content="{views:ThreeDText Key=ThreeD.Command.PreviewThickness, Korean='두께 미리보기', English='Preview Thickness'}"
                                                Command="{Binding PreviewThicknessCommand}" />
                                        <Button Content="{views:ThreeDText Key=ThreeD.Command.PublishResult, Korean='결과 게시', English='Publish Result'}"
                                                Command="{Binding PublishResultCommand}" />
                                    </WrapPanel>
                                    <TextBlock Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding ThicknessSummary}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Foreground="#6b7280"
                                               TextWrapping="Wrap"
                                               Text="{Binding ThicknessDetails}" />
                                    <TextBlock Margin="0,12,0,4"
                                               FontWeight="SemiBold"
                                               Text="{views:ThreeDText Key=ThreeD.Expert.PointPairDimensions, Korean='점 쌍 치수', English='Point Pair Dimensions'}" />
                                    <WrapPanel>
                                        <StackPanel Width="58" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.ExpectedDistance, Korean='기준 거리', English='Exp D'}" />
                                            <TextBox Text="{Binding PointPairExpectedDistance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                        </StackPanel>
                                        <StackPanel Width="58" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.DistanceTolerance, Korean='거리 공차', English='Tol D'}" />
                                            <TextBox Text="{Binding PointPairDistanceTolerance, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                        </StackPanel>
                                        <StackPanel Width="58" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" Foreground="#6b7280" Text="{views:ThreeDText Key=ThreeD.Field.ExpectedWidth, Korean='기준 폭', English='Exp W'}" />
                                            <TextBox Text="{Binding PointPairExpectedWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F3}}" />
                                        </StackPanel>
