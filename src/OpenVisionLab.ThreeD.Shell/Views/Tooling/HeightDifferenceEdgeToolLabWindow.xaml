<Window x:Class="OpenVisionLab.ThreeD.Shell.Views.Tooling.HeightDifferenceEdgeToolLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shell="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Shell"
        xmlns:shellChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:workbench="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Workbench"
        Title="Height Difference Edge Tool Lab | OpenVisionLab 3D Studio"
        Width="1600"
        Height="920"
        MinWidth="1120"
        MinHeight="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource ThreeD.AppBackgroundBrush}"
        AutomationProperties.AutomationId="HeightDifferenceEdgeToolLabWindow">
    <shellChrome:WindowChrome.WindowChrome>
        <shellChrome:WindowChrome CaptionHeight="56"
                                  ResizeBorderThickness="6"
                                  GlassFrameThickness="0"
                                  UseAeroCaptionButtons="False" />
    </shellChrome:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="280" />
        </Grid.RowDefinitions>

        <shell:StudioTitleBarView TitleText="OpenVisionLab 3D Studio"
                                  SubtitleText="Edge Tool Lab"
                                  StatusText="Input / overlay comparison" />

        <Border Grid.Row="1"
                Margin="16,16,16,0"
                Padding="16,12"
                Background="{DynamicResource ThreeD.PanelHeaderBrush}"
                BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}"
                BorderThickness="1"
                CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="24"
                                   Height="24"
                                   Margin="0,0,9,0"
                                   Foreground="{DynamicResource ThreeD.AccentBrush}"
                                   Symbol="PointScan24" />
                    <StackPanel>
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderTitleTextStyle}"
                                   Text="Height Difference Edge Tool Lab" />
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderSubtitleTextStyle}"
                                   Text="The input is the exact Published FilteredHeightField. The output is an EdgePointSet overlay, not a second surface." />
                    </StackPanel>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <ui:Button Margin="0,0,6,0"
                               Content="Preview Edge"
                               Icon="{ui:SymbolIcon Eye24}"
                               Command="{Binding PreviewSelectedStepCommand}"
                               ToolTip="Explicitly create an EdgePointSet from the published Filter output"
                               AutomationProperties.Name="Preview Height Difference Edge" />
                    <ui:Button Margin="0,0,6,0"
                               Content="Show Filter Input"
                               Icon="{ui:SymbolIcon DataFunnel24}"
                               Click="ShowFilterInputButton_Click"
                               ToolTip="Refresh the exact published FilteredHeightField input view"
                               AutomationProperties.Name="Show FilteredHeightField input" />
                    <ui:Button Content="Publish Edge"
                               Icon="{ui:SymbolIcon CheckmarkCircle24}"
                               Command="{Binding PublishSelectedStepCommand}"
                               ToolTip="Publish the current EdgePointSet Preview without running again"
                               AutomationProperties.Name="Publish Height Difference Edge output" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="1"
                    Background="{DynamicResource ThreeD.PanelBrush}"
                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="10,6"
                            Background="{DynamicResource ThreeD.CommandBarBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="DataFunnel24" />
                                <TextBlock FontWeight="SemiBold" Text="Input | Published FilteredHeightField" />
                            </StackPanel>
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding HeightDifferenceEdgeUpstreamSummary}" />
                        </StackPanel>
                    </Border>
                    <ContentControl x:Name="InputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
            <Border Grid.Column="2"
                    Padding="1"
                    Background="{DynamicResource ThreeD.PanelBrush}"
                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="10,6"
                            Background="{DynamicResource ThreeD.CommandBarBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="PointScan24" />
                                <TextBlock FontWeight="SemiBold" Text="Output | EdgePointSet Overlay" />
                            </StackPanel>
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding HeightDifferenceEdgeExecutionSummary}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding HeightDifferenceEdgeOutputHashSummary}" />
                        </StackPanel>
                    </Border>
                    <ContentControl x:Name="OutputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="16,0,16,16"
                Background="{DynamicResource ThreeD.PanelBrush}"
                BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                BorderThickness="1">
            <workbench:ToolInspectorView />
        </Border>
    </Grid>
</Window>
