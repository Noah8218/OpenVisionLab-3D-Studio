<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Tooling.ToolLabReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:workbench="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Workbench"
             AutomationProperties.AutomationId="ToolLabReview">
    <Border Background="{DynamicResource ThreeD.PanelBrush}"
            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="10,6"
                    Background="{DynamicResource ThreeD.CommandBarBrush}"
                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Width="16"
                                       Height="16"
                                       Margin="0,1,6,0"
                                       Foreground="{DynamicResource ThreeD.InfoBrush}"
                                       Symbol="WrenchScrewdriver24" />
                        <StackPanel>
                            <TextBlock FontSize="10.5"
                                       FontWeight="SemiBold"
                                       Text="{Binding Localization.ToolLabReview}" />
                            <TextBlock Margin="0,1,0,0"
                                       FontSize="9.5"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding Localization.ToolLabReviewDetail}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1"
                            DataContext="{Binding SelectedPipelineStep}"
                            Style="{DynamicResource ThreeD.WorkflowStateBadgeStyle}"
                            ToolTip="{Binding State, StringFormat=Pipeline step state: {0}}"
                            AutomationProperties.Name="{Binding State, StringFormat=Pipeline step state: {0}}">
                        <TextBlock MaxWidth="122"
                                   FontSize="9.5"
                                   FontWeight="SemiBold"
                                   Style="{DynamicResource ThreeD.WorkflowStateTextStyle}"
                                   Text="{Binding State}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </Border>
            <workbench:ToolInspectorView Grid.Row="1" />
        </Grid>
    </Border>
</UserControl>
