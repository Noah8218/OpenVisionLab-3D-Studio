<Window x:Class="OpenVisionLab.ThreeD.Shell.Views.Tooling.ThreePointPlaneToolLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:i18n="clr-namespace:OpenVisionLab.ThreeD.Shell"
        xmlns:shell="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Shell"
        xmlns:shellChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:tooling="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Tooling"
        Title="{i18n:ThreeDText Key=ThreeD.ToolLab.ThreePointPlane.WindowTitle, Korean='3포인트 평면 툴 랩 | OpenVisionLab 3D Studio', English='3-Point Plane Tool Lab | OpenVisionLab 3D Studio'}"
        Width="1600" Height="920" MinWidth="1120" MinHeight="700"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource ThreeD.AppBackgroundBrush}"
        AutomationProperties.AutomationId="ThreePointPlaneToolLabWindow">
    <shellChrome:WindowChrome.WindowChrome>
        <shellChrome:WindowChrome CaptionHeight="56" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shellChrome:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="280" />
        </Grid.RowDefinitions>
        <shell:StudioTitleBarView TitleText="OpenVisionLab 3D Studio"
                                  SubtitleText="{i18n:ThreeDText Key=ThreeD.ToolLab.ThreePointPlane.Subtitle, Korean='3포인트 평면 툴 랩', English='3-Point Plane Tool Lab'}"
                                  StatusText="{i18n:ThreeDText Key=ThreeD.ToolLab.ThreePointPlane.Status, Korean='순서가 있는 raw-C3D 포인트 / 기준 평면 구성 증거', English='Ordered raw-C3D picks / datum-plane construction evidence'}" />
        <Border Grid.Row="1" Margin="16,16,16,0" Padding="16,12" Background="{DynamicResource ThreeD.PanelHeaderBrush}" BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="24" Height="24" Margin="0,0,9,0" Foreground="{DynamicResource ThreeD.AccentBrush}" Symbol="PointScan24" />
                    <StackPanel>
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderTitleTextStyle}" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.ThreePointPlane.Title, Korean='전체 XYZ 3포인트 평면', English='Full-XYZ 3-Point Plane Tool Lab'}" />
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderSubtitleTextStyle}" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.ThreePointPlane.Detail, Korean='P1 → P2 → P3로 방향이 있는 기준 평면을 정의합니다. 현재 소스 높이만 해석하며 영역 피팅·어파인 적용·측정·OK/NG 판정은 수행하지 않습니다.', English='P1 → P2 → P3 define an oriented datum plane. The tool resolves current source height; it never fits a region, applies affine mapping, measures, or evaluates OK/NG.'}" />
                    </StackPanel>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <ui:Button Margin="0,0,6,0" Content="{i18n:ThreeDText Key=ThreeD.ToolLab.ShowPicks, Korean='포인트 보기', English='Show picks'}" Icon="{ui:SymbolIcon Eye24}" Click="ShowInputsButton_Click" ToolTip="Show the exact current source and support triangle" AutomationProperties.Name="Show 3-Point Plane inputs" />
                    <ui:Button Margin="0,0,6,0" Content="{Binding Localization.Preview}" Icon="{ui:SymbolIcon Play24}" Command="{Binding PreviewSelectedStepCommand}" ToolTip="Resolve current raw C3D values for the authored ordered picks" AutomationProperties.Name="Preview 3-Point Plane" />
                    <ui:Button Content="{Binding Localization.Publish}" Icon="{ui:SymbolIcon CheckmarkCircle24}" Command="{Binding PublishSelectedStepCommand}" ToolTip="Publish the current 3-Point Plane Preview without running again" AutomationProperties.Name="Publish 3-Point Plane" />
                </WrapPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="16,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Padding="1" Background="{DynamicResource ThreeD.PanelBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Padding="10,6" Background="{DynamicResource ThreeD.CommandBarBrush}"><StackPanel><StackPanel Orientation="Horizontal"><ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="PointScan24" /><TextBlock FontWeight="SemiBold" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.ThreePointPlane.Input, Korean='입력 | Raw C3D + 순서가 있는 PointSet(3)', English='Input | Raw C3D + ordered PointSet(3)'}" /></StackPanel><TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding ThreePointPlaneSelectionSummary}" /></StackPanel></Border>
                    <ContentControl x:Name="InputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
            <Border Grid.Column="2" Padding="1" Background="{DynamicResource ThreeD.PanelBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Padding="10,6" Background="{DynamicResource ThreeD.CommandBarBrush}"><StackPanel><StackPanel Orientation="Horizontal"><ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="Branch24" /><TextBlock FontWeight="SemiBold" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.ThreePointPlane.Output, Korean='출력 | 방향이 있는 전체 XYZ 기준 평면', English='Output | Oriented full-XYZ datum plane'}" /></StackPanel><TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding ThreePointPlaneExecutionSummary}" /><TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding ThreePointPlaneOutputHashSummary}" /></StackPanel></Border>
                    <ContentControl x:Name="OutputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>
        <tooling:ToolLabReviewView Grid.Row="3" Margin="16,0,16,16" />
    </Grid>
</Window>
