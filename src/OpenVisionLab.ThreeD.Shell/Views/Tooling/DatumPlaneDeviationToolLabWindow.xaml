<Window x:Class="OpenVisionLab.ThreeD.Shell.Views.Tooling.DatumPlaneDeviationToolLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shell="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Shell"
        xmlns:shellChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:tooling="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Tooling"
        Title="Datum Plane Deviation Tool Lab | OpenVisionLab 3D Studio"
        Width="1600" Height="920" MinWidth="1120" MinHeight="700"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource ThreeD.AppBackgroundBrush}"
        AutomationProperties.AutomationId="DatumPlaneDeviationToolLabWindow">
    <shellChrome:WindowChrome.WindowChrome>
        <shellChrome:WindowChrome CaptionHeight="56" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shellChrome:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="280" />
        </Grid.RowDefinitions>
        <shell:StudioTitleBarView TitleText="OpenVisionLab 3D Studio" SubtitleText="Datum Plane Deviation Tool Lab" StatusText="Published PlaneFeature + raw C3D ROI / explicit Preview and Publish" />
        <Border Grid.Row="1" Margin="16,16,16,0" Padding="16,12" Background="{DynamicResource ThreeD.PanelHeaderBrush}" BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="24" Height="24" Margin="0,0,9,0" Foreground="{DynamicResource ThreeD.AccentBrush}" Symbol="DataHistogram24" />
                    <StackPanel>
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderTitleTextStyle}" Text="Datum Plane Raw-Height Deviation" />
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderSubtitleTextStyle}" Text="A published manual plane predicts raw height at each ROI cell. The right view colors residual samples and reports P2V; it does not alter C3D or claim calibrated metrology." />
                    </StackPanel>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <ui:Button Margin="0,0,6,0" Content="Show input" Icon="{ui:SymbolIcon Eye24}" Click="ShowInputsButton_Click" ToolTip="Show the exact raw C3D and Published 3-Point Plane" AutomationProperties.Name="Show Datum Plane Deviation inputs" />
                    <ui:Button Margin="0,0,6,0" Content="{Binding Localization.Preview}" Icon="{ui:SymbolIcon Play24}" Command="{Binding PreviewSelectedStepCommand}" ToolTip="Evaluate only the current raw C3D, Published plane, and recipe-owned ROI" AutomationProperties.Name="Preview Datum Plane Deviation" />
                    <ui:Button Content="{Binding Localization.Publish}" Icon="{ui:SymbolIcon CheckmarkCircle24}" Command="{Binding PublishSelectedStepCommand}" ToolTip="Publish this exact Preview without running again" AutomationProperties.Name="Publish Datum Plane Deviation" />
                </WrapPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="16,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Padding="1" Background="{DynamicResource ThreeD.PanelBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Padding="10,6" Background="{DynamicResource ThreeD.CommandBarBrush}"><StackPanel><StackPanel Orientation="Horizontal"><ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="PointScan24" /><TextBlock FontWeight="SemiBold" Text="Input | raw C3D + Published PlaneFeature + GridRectangle" /></StackPanel><TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding DatumPlaneDeviationUpstreamSummary}" /></StackPanel></Border>
                    <ContentControl x:Name="InputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
            <Border Grid.Column="2" Padding="1" Background="{DynamicResource ThreeD.PanelBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Padding="10,6" Background="{DynamicResource ThreeD.CommandBarBrush}"><StackPanel><StackPanel Orientation="Horizontal"><ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="DataHistogram24" /><TextBlock FontWeight="SemiBold" Text="Output | read-only residual color overlay" /></StackPanel><TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding DatumPlaneDeviationEvidenceSummary}" /><TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding DatumPlaneDeviationOutputHashSummary}" /></StackPanel></Border>
                    <ContentControl x:Name="OutputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>
        <tooling:ToolLabReviewView Grid.Row="3" Margin="16,0,16,16" />
    </Grid>
</Window>
