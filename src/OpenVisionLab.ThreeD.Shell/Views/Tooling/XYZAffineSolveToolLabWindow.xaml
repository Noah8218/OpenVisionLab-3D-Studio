<Window x:Class="OpenVisionLab.ThreeD.Shell.Views.Tooling.XYZAffineSolveToolLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:i18n="clr-namespace:OpenVisionLab.ThreeD.Shell"
        xmlns:shell="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Shell"
        xmlns:shellChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:tooling="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Tooling"
        xmlns:propertyGrid="clr-namespace:OpenVisionLab.ThreeD.Shell.PropertyGrid"
        Title="{i18n:ThreeDText Key=ThreeD.ToolLab.AffineSolve.WindowTitle, Korean='XYZ 어파인 계산 툴 랩 | OpenVisionLab 3D Studio', English='XYZ Affine Solve Tool Lab | OpenVisionLab 3D Studio'}"
        Width="1680" Height="940" MinWidth="1200" MinHeight="720"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource ThreeD.AppBackgroundBrush}"
        AutomationProperties.AutomationId="XYZAffineSolveToolLabWindow">
    <shellChrome:WindowChrome.WindowChrome>
        <shellChrome:WindowChrome CaptionHeight="56" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shellChrome:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="300" />
        </Grid.RowDefinitions>
        <shell:StudioTitleBarView TitleText="OpenVisionLab 3D Studio"
                                  SubtitleText="{i18n:ThreeDText Key=ThreeD.ToolLab.AffineSolve.Subtitle, Korean='XYZ 어파인 계산 툴 랩', English='XYZ Affine Solve Tool Lab'}"
                                  StatusText="CorrespondenceSet → AffineTransform3D" />
        <Border Grid.Row="1" Margin="16,16,16,0" Padding="16,12"
                Background="{DynamicResource ThreeD.PanelHeaderBrush}"
                BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="24" Height="24" Margin="0,0,9,0" Foreground="{DynamicResource ThreeD.AccentBrush}" Symbol="ArrowSync24" />
                    <StackPanel>
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderTitleTextStyle}" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.AffineSolve.Title, Korean='전체 XYZ 어파인 계산', English='Full-XYZ Affine Solve'}" />
                        <TextBlock MaxWidth="760" TextWrapping="Wrap" Style="{DynamicResource ThreeD.WindowHeaderSubtitleTextStyle}" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.AffineSolve.Detail, Korean='현재 게시된 소스/기준 대응 네 쌍으로 행렬을 계산합니다. A1은 행렬 적용·C3D 포인트 변환·높이맵 생성을 수행하지 않습니다.', English='Solve exactly four current Published source/reference pairs with scaled partial pivoting. A1 does not apply the matrix, transform C3D points, or create a height map.'}" />
                    </StackPanel>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <ui:Button Margin="0,0,6,0" Content="{i18n:ThreeDText Key=ThreeD.ToolLab.PreviewMatrix, Korean='행렬 미리보기', English='Preview matrix'}" Icon="{ui:SymbolIcon Eye24}"
                               Command="{Binding PreviewSelectedStepCommand}" ToolTip="Explicitly calculate one temporary affine matrix from the routed Published CorrespondenceSet" AutomationProperties.Name="Preview XYZ Affine Solve" />
                    <ui:Button Margin="0,0,6,0" Content="{i18n:ThreeDText Key=ThreeD.ToolLab.RefreshInput, Korean='입력 새로고침', English='Refresh input'}" Icon="{ui:SymbolIcon ArrowSync24}"
                               Click="RefreshViewsButton_Click" ToolTip="Refresh the source viewer without solving" AutomationProperties.Name="Refresh XYZ Affine Solve input" />
                    <ui:Button Content="{i18n:ThreeDText Key=ThreeD.ToolLab.PublishMatrix, Korean='행렬 게시', English='Publish matrix'}" Icon="{ui:SymbolIcon CheckmarkCircle24}"
                               Command="{Binding PublishSelectedStepCommand}" ToolTip="Publish the current matrix Preview without recalculation or point-cloud application" AutomationProperties.Name="Publish XYZ Affine Solve output" />
                </WrapPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="16,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.12*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="0.88*" /></Grid.ColumnDefinitions>
            <Border Padding="1" Background="{DynamicResource ThreeD.PanelBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Padding="10,6" Background="{DynamicResource ThreeD.CommandBarBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="PointScan24" /><TextBlock FontWeight="SemiBold" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.AffineSolve.Input, Korean='입력 | 소스 프레임 랜드마크 증거', English='Input | source-frame landmark evidence'}" /></StackPanel>
                            <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding AffineSolveUpstreamSummary}" />
                        </StackPanel>
                    </Border>
                    <ContentControl x:Name="SourceViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
            <Border Grid.Column="2" Padding="14" Background="{DynamicResource ThreeD.PanelBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"><ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="Cube24" /><TextBlock FontWeight="SemiBold" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.AffineSolve.Output, Korean='출력 | AffineTransform3D 증거', English='Output | AffineTransform3D evidence'}" /></StackPanel>
                        <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding AffineSolveExecutionSummary}" />
                        <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding AffineSolveEvidenceSummary}" />
                        <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding AffineSolveOutputHashSummary}" />
                    </StackPanel>
                    <Border Grid.Row="1" Margin="0,12,0,12" Padding="10" Background="{DynamicResource ThreeD.PanelAlternateBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                        <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Text="{Binding AffineSolveMatrixSummary}" />
                    </Border>
                    <Border Grid.Row="2" Padding="10" Background="{DynamicResource ThreeD.InfoSurfaceBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="180" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ThreeD.InfoBrush}" Text="{Binding Localization.TypedParameters}" />
                                <TextBlock Grid.Column="1" FontSize="10" Foreground="{DynamicResource ThreeD.AccentBrush}" Text="{Binding SelectedStepAdapterStatus}" />
                            </Grid>
                            <propertyGrid:RecipeStepPropertyGridHost x:Name="AffineStepPropertyGrid" Grid.Row="1" Margin="0,7,0,0" SelectedObject="{Binding SelectedStepPropertyDraft}" PropertyValueChanged="OnPropertyGridValueChanged" />
                            <TextBlock Grid.Row="2" Margin="0,7,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" TextWrapping="Wrap" Text="{Binding StepParameterEditStatus}" />
                            <WrapPanel Grid.Row="3" Margin="0,7,0,0" HorizontalAlignment="Right">
                                <Button Margin="0,0,5,0" Content="{Binding Localization.Discard}" IsEnabled="{Binding HasPendingStepParameterChanges}" Click="OnDiscardParametersClick" AutomationProperties.Name="Discard XYZ Affine Solve parameter changes" />
                                <Button Content="{Binding Localization.ApplyParameters}" IsEnabled="{Binding HasPendingStepParameterChanges}" Click="OnApplyParametersClick" AutomationProperties.Name="Apply XYZ Affine Solve parameters without preview" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <tooling:ToolLabReviewView Grid.Row="3" Margin="16,0,16,16" />
    </Grid>
</Window>
