<Window x:Class="OpenVisionLab.ThreeD.Shell.Views.Tooling.FilterToolLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:i18n="clr-namespace:OpenVisionLab.ThreeD.Shell"
        xmlns:shell="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Shell"
        xmlns:shellChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:tooling="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Tooling"
        Title="{i18n:ThreeDText Key=ThreeD.ToolLab.Filter.WindowTitle, Korean='필터 툴 랩 | OpenVisionLab 3D Studio', English='Filter Tool Lab | OpenVisionLab 3D Studio'}"
        Width="1600"
        Height="920"
        MinWidth="1120"
        MinHeight="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource ThreeD.AppBackgroundBrush}"
        AutomationProperties.AutomationId="FilterToolLabWindow">
    <shellChrome:WindowChrome.WindowChrome>
        <shellChrome:WindowChrome CaptionHeight="56"
                                  ResizeBorderThickness="6"
                                  GlassFrameThickness="0"
                                  UseAeroCaptionButtons="False" />
    </shellChrome:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="280" />
        </Grid.RowDefinitions>

        <shell:StudioTitleBarView TitleText="OpenVisionLab 3D Studio"
                                  SubtitleText="{i18n:ThreeDText Key=ThreeD.ToolLab.Filter.Subtitle, Korean='필터 툴 랩', English='Filter Tool Lab'}"
                                  StatusText="{i18n:ThreeDText Key=ThreeD.ToolLab.Filter.Status, Korean='입력 / 미리보기 비교', English='Input / Preview comparison'}" />

        <Border Grid.Row="1"
                Margin="16,16,16,0"
                Padding="16,12"
                Background="{DynamicResource ThreeD.PanelHeaderBrush}"
                BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}"
                BorderThickness="1"
                CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="24"
                                   Height="24"
                                   Margin="0,0,9,0"
                                   Foreground="{DynamicResource ThreeD.AccentBrush}"
                                   Symbol="DataFunnel24" />
                    <StackPanel>
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderTitleTextStyle}"
                                   Text="{i18n:ThreeDText Key=ThreeD.ToolLab.Filter.Title, Korean='필터 툴 랩', English='Filter Tool Lab'}" />
                        <TextBlock Style="{DynamicResource ThreeD.WindowHeaderSubtitleTextStyle}"
                                   Text="{i18n:ThreeDText Key=ThreeD.ToolLab.Filter.Detail, Korean='입력과 미리보기 출력을 별도의 3D 보기로 비교합니다. 게시는 사용자가 명시적으로 선택할 때만 레시피 증거를 갱신합니다.', English='Input and Preview output are separate 3D views. Preview does not change the recipe until Publish is chosen.'}" />
                    </StackPanel>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <ui:Button Margin="0,0,6,0"
                               Content="{Binding Localization.Preview}"
                               Icon="{ui:SymbolIcon Eye24}"
                               Command="{Binding PreviewSelectedStepCommand}"
                               ToolTip="Explicitly create a temporary Filter Preview"
                               AutomationProperties.Name="Preview Filter" />
                    <ui:Button Margin="0,0,6,0"
                               Content="{Binding Localization.ShowInput}"
                               Icon="{ui:SymbolIcon DataBarVertical24}"
                               Command="{Binding ShowFilterSourceCommand}"
                               ToolTip="Restore the input view without changing the Preview artifact"
                               AutomationProperties.Name="Show Filter source" />
                    <ui:Button Content="{Binding Localization.Publish}"
                               Icon="{ui:SymbolIcon CheckmarkCircle24}"
                               Command="{Binding PublishSelectedStepCommand}"
                               ToolTip="Publish the current Preview without running again"
                               AutomationProperties.Name="Publish Filter output" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="1"
                    Background="{DynamicResource ThreeD.PanelBrush}"
                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="10,6"
                            Background="{DynamicResource ThreeD.CommandBarBrush}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="DataBarVertical24" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Localization.Input}" />
                                        <TextBlock FontWeight="SemiBold" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.Filter.SourceC3D, Korean=' | 원본 C3D', English=' | Source C3D'}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ContentControl x:Name="InputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
            <Border Grid.Column="2"
                    Padding="1"
                    Background="{DynamicResource ThreeD.PanelBrush}"
                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="10,6"
                            Background="{DynamicResource ThreeD.CommandBarBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="16" Height="16" Margin="0,0,5,0" Symbol="DataFunnel24" />
                                <TextBlock FontWeight="SemiBold" Text="{Binding Localization.Output}" />
                                        <TextBlock FontWeight="SemiBold" Text="{i18n:ThreeDText Key=ThreeD.ToolLab.Filter.Preview, Korean=' | 필터 미리보기', English=' | Filter Preview'}" />
                            </StackPanel>
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding CurrentFilterPreviewOutputSummary}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding FilterExecutionSummary}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding FilterOutputHashSummary}" />
                        </StackPanel>
                    </Border>
                    <ContentControl x:Name="OutputViewerHost" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>

        <tooling:ToolLabReviewView Grid.Row="3" Margin="16,0,16,16" />
    </Grid>
</Window>
