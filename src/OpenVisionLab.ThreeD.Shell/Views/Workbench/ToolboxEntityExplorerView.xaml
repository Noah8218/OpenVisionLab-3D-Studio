<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.ToolboxEntityExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:OpenVisionLab.ThreeD.Shell.ViewModels.Workbench"
             AutomationProperties.AutomationId="RecipeFlowExplorer">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Border Padding="12"
            Background="{DynamicResource ThreeD.PanelBrush}"
            TextElement.Foreground="{DynamicResource ThreeD.TextBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="20"
                                   Height="20"
                                   Margin="0,0,7,0"
                                   Foreground="{DynamicResource ThreeD.AccentBrush}"
                                   Symbol="Branch24" />
                    <TextBlock Style="{DynamicResource ThreeD.PanelTitleTextStyle}"
                               Text="{Binding Localization.RecipeFlow}" />
                </StackPanel>
                <TextBlock Margin="0,4,0,0"
                           FontSize="10.5"
                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding Localization.RecipeFlowHint}" />

                <Border Margin="0,9,0,0"
                        Padding="9"
                        ToolTip="{Binding LocalizedSourceReadinessSummary}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ThreeD.WarningSurfaceBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.WarningBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="CornerRadius" Value="4" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSourceReadyForRecipe}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ThreeD.PassSurfaceBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.PassBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Width="17"
                                       Height="17"
                                       Margin="0,1,7,0"
                                       Foreground="{DynamicResource ThreeD.PassBrush}"
                                       Symbol="CheckmarkCircle24" />
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Text="{Binding Localization.RecipeSource}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="9.5"
                                       Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                       Text="{Binding LocalizedSourceReadinessSummary}"
                                       TextWrapping="Wrap" />
                            <ui:Button Margin="0,7,0,0"
                                       HorizontalAlignment="Left"
                                       Content="{Binding Localization.LoadInputActionTitle}"
                                       Icon="{ui:SymbolIcon FolderOpen24}"
                                       Command="{Binding LoadC3DSourceCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSourceReadyForRecipe}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,8,0,0"
                        Padding="9"
                        Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                        BorderBrush="{DynamicResource ThreeD.InfoBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedPipelineStep}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Width="16"
                                           Height="16"
                                           Margin="0,1,6,0"
                                           Foreground="{DynamicResource ThreeD.InfoBrush}"
                                           Symbol="ArrowFlowUpRight24" />
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThreeD.InfoBrush}"
                                       Text="{Binding Localization.SelectedRoute}" />
                        </StackPanel>
                        <TextBlock Margin="22,4,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedPipelineStepTitle}"
                                   TextTrimming="CharacterEllipsis" />
                        <Grid Margin="22,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="9"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           Text="{Binding Localization.Input}" />
                                <TextBlock FontSize="9.5"
                                           Text="{Binding SelectedRouteInputIds}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <ui:SymbolIcon Grid.Column="1"
                                           Width="14"
                                           Height="14"
                                           Margin="7,7"
                                           Foreground="{DynamicResource ThreeD.InfoBrush}"
                                           Symbol="ArrowRight24" />
                            <StackPanel Grid.Column="2">
                                <TextBlock FontSize="9"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           Text="{Binding Localization.Output}" />
                                <TextBlock FontSize="9.5"
                                           Foreground="{DynamicResource ThreeD.AccentBrush}"
                                           Text="{Binding SelectedRouteOutputId}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                        <ui:Button Margin="22,7,0,0"
                                   HorizontalAlignment="Left"
                                   Content="{Binding Localization.OpenSelectedToolLab}"
                                   Icon="{ui:SymbolIcon WrenchScrewdriver24}"
                                   Command="{Binding OpenSelectedToolLabCommand}"
                                   Visibility="{Binding IsSelectedToolLabAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <Expander Margin="0,10,0,0"
                          Header="{Binding Localization.RecipeNavigator}"
                          IsExpanded="True">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock FontSize="9.5"
                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                   Text="{Binding ArtifactRegistrySummary}" />
                        <TreeView Margin="0,6,0,0"
                                  MaxHeight="390"
                                  Background="Transparent"
                                  BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                  BorderThickness="1"
                                  ItemsSource="{Binding NavigatorRoots}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type vm:ToolWorkbenchNavigatorItem}"
                                                          ItemsSource="{Binding Children}">
                                    <Button Padding="3"
                                            HorizontalContentAlignment="Stretch"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.SelectNavigatorItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Detail}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Width="15"
                                                           Height="15"
                                                           Margin="0,1,6,0"
                                                           Foreground="{DynamicResource ThreeD.AccentBrush}"
                                                           Symbol="FlowchartCircle24" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="9"
                                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                                           Text="{Binding Detail}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </StackPanel>
                </Expander>

                <Expander Margin="0,9,0,0"
                          Header="{Binding Localization.JourneyInput}"
                          IsExpanded="False">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Source.Name}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="9.5"
                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                   Text="{Binding Source.Path}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Source.Path}" />
                        <ui:Button Margin="0,7,0,0"
                                   HorizontalAlignment="Left"
                                   Content="{Binding Localization.LoadInputActionTitle}"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding LoadC3DSourceCommand}" />
                        <Grid Margin="0,7,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}" Text="Unit" />
                                <TextBox Text="{Binding Source.Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}" Text="Frame" />
                                <TextBox Text="{Binding Source.FrameId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander Margin="0,9,0,0"
                          Header="References &amp; frame"
                          IsExpanded="False">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}" Text="Source entity ID" />
                        <TextBox Text="{Binding Source.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}" Text="Declared reference" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Margin="0,0,4,0"
                                     ToolTip="Reference entity ID"
                                     Text="{Binding NewReferenceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="1"
                                     Margin="4,0,0,0"
                                     ToolTip="Reference name"
                                     Text="{Binding NewReferenceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <WrapPanel Margin="0,5,0,0">
                            <TextBox Width="145"
                                     ToolTip="Reference kind"
                                     Text="{Binding NewReferenceKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Margin="5,0,0,0"
                                       Content="{Binding Localization.AddCompatibleTool}"
                                       Icon="{ui:SymbolIcon AddCircle24}"
                                       Command="{Binding AddReferenceCommand}" />
                            <ui:Button Margin="5,0,0,0"
                                       Content="{Binding Localization.Remove}"
                                       Icon="{ui:SymbolIcon DeleteDismiss24}"
                                       Command="{Binding RemoveSelectedReferenceCommand}" />
                        </WrapPanel>
                        <ListBox Margin="0,5,0,0"
                                 MaxHeight="84"
                                 Background="Transparent"
                                 BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                 ItemsSource="{Binding References}"
                                 SelectedItem="{Binding SelectedReference, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,2">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Id}" />
                                        <TextBlock FontSize="9.5"
                                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                                   Text="{Binding Kind}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
