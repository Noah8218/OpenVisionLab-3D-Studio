<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.LineFitDiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Workbench"
             Background="{DynamicResource ThreeD.PanelBrush}"
             AutomationProperties.AutomationId="LineFitDiagnosticsView">
    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThreeD.PrimaryTextBrush}" Text="Fit Diagnostics / Orthogonal residual" />
                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="Residuals are full-XYZ source-coordinate values. Select a marker or row to link the 3D point." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="{DynamicResource ThreeD.AccentBrush}" />
                <TextBlock Margin="4,0,10,0" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="Inlier" />
                <Ellipse Width="9" Height="9" Fill="{DynamicResource ThreeD.WarningBrush}" />
                <TextBlock Margin="4,0,0,0" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="Outlier" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,8,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Border Padding="8" Background="{DynamicResource ThreeD.ViewportBrush}" BorderBrush="{DynamicResource ThreeD.DividerBrush}" BorderThickness="1" CornerRadius="3">
                <Viewbox Stretch="Fill">
                    <Canvas Width="288" Height="76">
                        <Line X1="8" Y1="64" X2="276" Y2="64" Stroke="#475569" StrokeThickness="0.8" />
                        <Line X1="8" Y1="10" X2="276" Y2="10" Stroke="{DynamicResource ThreeD.WarningBrush}" StrokeThickness="1.2" StrokeDashArray="3,2" />
                        <TextBlock Canvas.Left="9" Canvas.Top="0" FontSize="7" Foreground="{DynamicResource ThreeD.WarningBrush}" Text="Maximum residual" />
                        <ItemsControl ItemsSource="{Binding LineFitResidualPlotPoints}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding PlotX}" />
                                    <Setter Property="Canvas.Top" Value="{Binding PlotY}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="11" Height="11" Padding="0" BorderThickness="0" Command="{Binding DataContext.SelectLineFitDiagnosticCommand, RelativeSource={RelativeSource AncestorType=local:LineFitDiagnosticsView}}" CommandParameter="{Binding InputPointIndex}" ToolTip="{Binding ScanlineIndex, StringFormat=Scanline {0}}">
                                        <Button.Style>
                                            <Style TargetType="Button"><Setter Property="Background" Value="{DynamicResource ThreeD.WarningBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsInlier}" Value="True"><Setter Property="Background" Value="{DynamicResource ThreeD.AccentBrush}" /></DataTrigger></Style.Triggers></Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Viewbox>
            </Border>
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="48" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="9.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="Scanline" />
                    <TextBlock Grid.Column="1" FontSize="9.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="Residual" />
                    <TextBlock Grid.Column="2" FontSize="9.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="State" />
                </Grid>
                <ListBox Grid.Row="1" MinHeight="88" ItemsSource="{Binding LineFitPointDiagnostics}" SelectedValuePath="InputPointIndex" SelectedValue="{Binding SelectedLineFitDiagnostic.InputPointIndex}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Padding="4,2" HorizontalContentAlignment="Stretch" Command="{Binding DataContext.SelectLineFitDiagnosticCommand, RelativeSource={RelativeSource AncestorType=local:LineFitDiagnosticsView}}" CommandParameter="{Binding InputPointIndex}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontFamily="Consolas" FontSize="10" Text="{Binding ScanlineIndex}" />
                                <TextBlock Grid.Column="1" FontFamily="Consolas" FontSize="10" Text="{Binding OrthogonalResidual, StringFormat=F6}" />
                                <TextBlock Grid.Column="2" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="outlier" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInlier}" Value="True"><Setter Property="Text" Value="inlier" /></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
        <TextBlock Grid.Row="2" FontSize="10.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" TextWrapping="Wrap" Text="{Binding LineFitSelectedDiagnosticSummary}" />
    </Grid>
</UserControl>
