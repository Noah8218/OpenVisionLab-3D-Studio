<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.HeightProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             MinHeight="150"
             Background="{DynamicResource ThreeD.PanelBrush}"
             AutomationProperties.AutomationId="HeightProfileView">
    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource ThreeD.DockPanelTitleTextStyle}"
                           Text="P1–P2 Height Profile" />
                <TextBlock Style="{DynamicResource ThreeD.DockPanelCaptionTextStyle}"
                           Text="Drag either endpoint in the 3D View; the sampled height trace updates immediately." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Margin="0,0,10,0"
                        Style="{DynamicResource ThreeD.DockPanelStatusCardStyle}"
                        ToolTip="The trace reflects two explicit endpoints in the 3D View."
                        AutomationProperties.Name="Viewer-linked height profile">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Width="13" Height="13" Margin="0,0,4,0" Foreground="{DynamicResource ThreeD.InfoBrush}" Symbol="Link24" />
                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThreeD.InfoBrush}" Text="Viewer-linked" />
                    </StackPanel>
                </Border>
                <Ellipse Width="9" Height="9" Fill="#33e6ff" />
                <TextBlock Margin="4,0,10,0" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="P1" />
                <Ellipse Width="9" Height="9" Fill="#ff7338" />
                <TextBlock Margin="4,0,0,0" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="P2" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,8,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>
            <Border MinHeight="86"
                    Padding="7"
                    Background="{DynamicResource ThreeD.ViewportBrush}"
                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    ClipToBounds="True">
                <Viewbox Stretch="Fill">
                    <Canvas Width="240" Height="54">
                        <Line X1="0" Y1="13.5" X2="240" Y2="13.5" Stroke="#334155" StrokeThickness="0.8" />
                        <Line X1="0" Y1="27" X2="240" Y2="27" Stroke="#475569" StrokeThickness="0.8" />
                        <Line X1="0" Y1="40.5" X2="240" Y2="40.5" Stroke="#334155" StrokeThickness="0.8" />
                        <Path Data="{Binding ProfilePathData}"
                              Stroke="#fbbf24"
                              StrokeThickness="2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                </Viewbox>
            </Border>
            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock FontWeight="SemiBold"
                           Foreground="{DynamicResource ThreeD.PrimaryTextBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ProfileSummary}" />
                <TextBlock Margin="0,5,0,0"
                           FontFamily="Consolas"
                           FontSize="10.5"
                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding ProfileEndpointSummary}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2"
                   FontSize="10.5"
                   Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                   TextWrapping="Wrap"
                   Text="{Binding ProfileRange}" />
    </Grid>
</UserControl>
