<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.LineIntersectionEvidenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             AutomationProperties.AutomationId="LineIntersectionEvidenceView">
    <Grid Margin="12,8" Background="{DynamicResource ThreeD.PanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource ThreeD.DockPanelTitleTextStyle}" Text="Intersection Evidence" />
                <TextBlock Style="{DynamicResource ThreeD.DockPanelCaptionTextStyle}" Text="Published line inputs and the current closest-approach result." />
            </StackPanel>
            <Border Grid.Column="1"
                    Style="{DynamicResource ThreeD.DockPanelStatusCardStyle}"
                    ToolTip="This pane reports evidence only; it never runs the inspection."
                    AutomationProperties.Name="Read-only intersection evidence">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="13" Height="13" Margin="0,0,4,0" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Symbol="Document24" />
                    <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Read-only" />
                </StackPanel>
            </Border>
        </Grid>
        <Border Grid.Row="1"
                Margin="0,8,0,6"
                Padding="10,8"
                Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                BorderThickness="1"
                CornerRadius="3">
            <StackPanel>
                <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Current state" />
                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" TextWrapping="Wrap" Text="{Binding LineIntersectionExecutionSummary}" />
                <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Published inputs" />
                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" TextWrapping="Wrap" Text="{Binding LineIntersectionUpstreamSummary}" />
                <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Closest-approach result" />
                <TextBlock Margin="0,2,0,0" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThreeD.PrimaryTextBrush}" TextWrapping="Wrap" Text="{Binding LineIntersectionEvidenceSummary}" />
                <TextBlock Margin="0,8,0,0" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding LineIntersectionOutputHashSummary}" />
            </StackPanel>
        </Border>
        <TextBlock Grid.Row="2" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="Midpoint represents the accepted closest-pair anchor in source coordinates; it is not a calibrated physical intersection." />
    </Grid>
</UserControl>
