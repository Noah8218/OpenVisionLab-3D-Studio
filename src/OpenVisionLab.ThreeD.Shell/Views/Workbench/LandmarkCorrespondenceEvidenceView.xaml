<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.LandmarkCorrespondenceEvidenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="LandmarkCorrespondenceEvidenceView">
    <Border Padding="14" Background="{DynamicResource ThreeD.PanelBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Landmark Correspondence Evidence" />
                <TextBlock Margin="0,6,0,0" FontSize="10.5" TextWrapping="Wrap" Text="{Binding LandmarkCorrespondenceUpstreamSummary}" />
                <TextBlock Margin="0,10,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Current correspondence state" />
                <TextBlock FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding LandmarkCorrespondenceEvidenceSummary}" />
                <TextBlock Margin="0,8,0,0" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding LandmarkCorrespondenceOutputHashSummary}" />
                <TextBlock Margin="0,10,0,0" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="Exactly four current Published CornerAnchors and four explicit reference coordinates must form non-degenerate tetrahedra. This evidence does not calculate an affine matrix or claim calibration, metrology, or OK/NG." />
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
