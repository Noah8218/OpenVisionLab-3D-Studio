<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.ToolInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:propertyGrid="clr-namespace:OpenVisionLab.ThreeD.Shell.PropertyGrid"
             AutomationProperties.AutomationId="ToolInspector">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="{DynamicResource ThreeD.PanelBrush}"
            TextElement.Foreground="{DynamicResource ThreeD.TextBrush}"
            Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedPipelineStep}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Padding="10"
                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="18"
                                               Height="18"
                                               Margin="0,0,6,0"
                                               Foreground="{DynamicResource ThreeD.InfoBrush}"
                                               Symbol="FlowchartCircle24" />
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThreeD.TextBrush}"
                                           Text="{Binding Localization.NoRecipeStepSelected}" />
                            </StackPanel>
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding Localization.NoRecipeStepSelectedDetail}" />
                        </StackPanel>
                    </Border>
                    <Expander Margin="0,10,0,0"
                              Header="{Binding Localization.SelectedPaletteItem}"
                              IsExpanded="False">
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThreeD.AccentBrush}"
                                       Text="{Binding SelectedToolTitle}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedTool.Description}" />
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Text="{Binding Localization.Input}" />
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding SelectedTool.InputContract}" />
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Text="{Binding Localization.Output}" />
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding SelectedTool.OutputContract}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <StackPanel Visibility="{Binding HasSelectedPipelineStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Style="{DynamicResource ThreeD.PanelTitleTextStyle}"
                               Text="{Binding Localization.StepProperties}" />
                    <Grid Margin="0,3,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="10.5"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThreeD.AccentBrush}"
                                   Text="{Binding SelectedPipelineStepTitle}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SelectedPipelineStepTitle}"
                                   AutomationProperties.Name="{Binding SelectedPipelineStepTitle}" />
                        <Border Grid.Row="1"
                                Margin="0,3,0,0"
                                HorizontalAlignment="Left"
                                DataContext="{Binding SelectedPipelineStep}"
                                Style="{DynamicResource ThreeD.WorkflowStateBadgeStyle}"
                                ToolTip="{Binding State, StringFormat=Pipeline step state: {0}}"
                                AutomationProperties.Name="{Binding State, StringFormat=Pipeline step state: {0}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="14"
                                               Height="14"
                                               Margin="0,0,4,0"
                                               Style="{DynamicResource ThreeD.WorkflowStateIconStyle}" />
                                <TextBlock MaxWidth="122"
                                           FontSize="9.5"
                                           FontWeight="SemiBold"
                                           Style="{DynamicResource ThreeD.WorkflowStateTextStyle}"
                                           Text="{Binding State}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <TextBlock Margin="0,4,0,0"
                               FontSize="10.5"
                               Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding Localization.StepPropertiesEditDetail}" />
                    <Border Margin="0,7,0,0"
                            Padding="8"
                            ToolTip="{Binding SelectedStepAdapterStatus}"
                            AutomationProperties.Name="{Binding SelectedStepAdapterStatus, StringFormat=Step parameter adapter: {0}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ThreeD.InfoSurfaceBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.InfoBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="CornerRadius" Value="3" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedStepPropertyGridSupported}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource ThreeD.WarningSurfaceBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.WarningBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThreeD.InfoBrush}"
                                       Text="{Binding Localization.InputParameterOutputSummary}" />

                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Width="14" Height="14" Margin="0,1,4,0" Foreground="{DynamicResource ThreeD.InfoBrush}" Symbol="ArrowRight24" />
                                <TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold" Text="{Binding Localization.Inputs}" />
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="{Binding SelectedPipelineStep.InputContract}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.TextBrush}" Text="{Binding SelectedPipelineStep.InputSummary}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Width="14" Height="14" Margin="0,1,4,0" Foreground="{DynamicResource ThreeD.InfoBrush}" Symbol="WrenchScrewdriver24" />
                                <TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold" Text="{Binding Localization.TypedParameters}" />
                                <TextBlock Grid.Column="2" FontSize="10" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="{Binding SelectedStepAdapterStatus}" TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Width="14" Height="14" Margin="0,1,4,0" Foreground="{DynamicResource ThreeD.InfoBrush}" Symbol="Cube24" />
                                <TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold" Text="{Binding Localization.Output}" />
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="{Binding SelectedPipelineStep.OutputContract}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.TextBrush}" Text="{Binding SelectedPipelineStep.OutputEntityId}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Expander Margin="0,10,0,0"
                              Header="{Binding Localization.Inputs}">
                        <Expander.Style>
                            <Style TargetType="Expander">
                                <Setter Property="IsExpanded" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedStepFilter}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepHeightDifferenceEdge}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepPlaneFlatness}" Value="True">
                                        <Setter Property="IsExpanded" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepGapFlush}" Value="True">
                                        <Setter Property="IsExpanded" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Expander.Style>
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Margin="0,0,0,4"
                                       Text="{Binding Localization.ExpectedData}" />
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding SelectedPipelineStep.InputContract}" />
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Text="{Binding Localization.InputEntities}" />
                            <TextBox Text="{Binding SelectedPipelineStep.InputEntityIdsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding AvailableInputEntitiesSummary, StringFormat=Available now: {0}}" />
                        </StackPanel>
                    </Expander>

                    <Expander Margin="0,7,0,0"
                              Header="{Binding Localization.TeachingSelections}">
                        <Expander.Style>
                            <Style TargetType="Expander">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="IsExpanded" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedStepFilter}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepHeightDifferenceEdge}" Value="True">
                                        <Setter Property="IsExpanded" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Expander.Style>
                        <StackPanel Margin="0,6,0,0">
                            <Border Padding="8"
                                    Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.InfoBrush}"
                                               Text="{Binding SelectedStepSelectionRequirementTitle}" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedStepSelectionRequirementSummary}" />
                                </StackPanel>
                            </Border>

                            <StackPanel Margin="0,7,0,0"
                                        Visibility="{Binding IsSelectedStepDualRoiMeasurement, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding DualRoiTeachingTitle}" />
                                <TextBlock Margin="0,2,0,7"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding DualRoiTeachingDetail}" />

                                <Border Padding="8"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlaneFlatnessReferenceRoleActive}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ThreeD.SelectedSurfaceBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="22" Height="22" CornerRadius="11"
                                                    Background="{DynamicResource ThreeD.AccentBrush}">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="White" FontWeight="Bold" Text="1" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="7,0,4,0" VerticalAlignment="Center"
                                                       FontWeight="SemiBold" Text="{Binding DualRoiFirstLabel}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="10.5"
                                                       Foreground="{DynamicResource ThreeD.InfoBrush}"
                                                       Text="{Binding PlaneFlatnessReferenceState}" />
                                        </Grid>
                                        <TextBlock Margin="29,4,0,0" FontSize="10.5"
                                                   Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                   TextWrapping="Wrap" Text="{Binding PlaneFlatnessReferenceSummary}" />
                                        <Button Margin="29,7,0,0" HorizontalAlignment="Left"
                                                Command="{Binding CapturePlaneFlatnessReferenceRoiCommand}"
                                                ToolTip="{Binding DualRoiTeachingDetail}"
                                                AutomationProperties.Name="Capture or replace first ordered ROI">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Width="14" Height="14" Margin="0,0,5,0" Symbol="TargetArrow24" />
                                                <TextBlock Text="{Binding PlaneFlatnessReferenceActionText}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,6,0,0" Padding="8"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlaneFlatnessMeasurementRoleActive}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ThreeD.SelectedSurfaceBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CanTeachPlaneFlatnessMeasurementRoi}" Value="False">
                                                    <Setter Property="Opacity" Value="0.58" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="22" Height="22" CornerRadius="11"
                                                    Background="{DynamicResource ThreeD.InfoBrush}">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="White" FontWeight="Bold" Text="2" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="7,0,4,0" VerticalAlignment="Center"
                                                       FontWeight="SemiBold" Text="{Binding DualRoiSecondLabel}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="10.5"
                                                       Foreground="{DynamicResource ThreeD.InfoBrush}"
                                                       Text="{Binding PlaneFlatnessMeasurementState}" />
                                        </Grid>
                                        <TextBlock Margin="29,4,0,0" FontSize="10.5"
                                                   Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                   TextWrapping="Wrap" Text="{Binding PlaneFlatnessMeasurementSummary}" />
                                        <Button Margin="29,7,0,0" HorizontalAlignment="Left"
                                                Command="{Binding CapturePlaneFlatnessMeasurementRoiCommand}"
                                                ToolTip="{Binding DualRoiTeachingDetail}"
                                                AutomationProperties.Name="Capture or replace second ordered ROI">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Width="14" Height="14" Margin="0,0,5,0" Symbol="PointScan24" />
                                                <TextBlock Text="{Binding PlaneFlatnessMeasurementActionText}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,8,0,2" FontSize="10.5"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           Text="{Binding Localization.ExistingCompatibleRoi}" />
                                <ComboBox ItemsSource="{Binding AvailableCompatibleSelections}"
                                          SelectedItem="{Binding SelectedCompatibleSelection}"
                                          DisplayMemberPath="Name" />
                                <WrapPanel Margin="0,5,0,0">
                                    <Button Margin="0,0,5,0"
                                            Command="{Binding ReusePlaneFlatnessReferenceRoiCommand}"
                                            AutomationProperties.Name="Reuse compatible ROI as Plane Flatness reference">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Width="14" Height="14" Margin="0,0,5,0" Symbol="Link24" />
                                            <TextBlock>
                                                <TextBlock.Inlines>
                                                    <Run Text="{Binding DualRoiFirstLabel, Mode=OneWay}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{Binding Localization.ReuseRoi, Mode=OneWay}" />
                                                </TextBlock.Inlines>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ReusePlaneFlatnessMeasurementRoiCommand}"
                                            AutomationProperties.Name="Reuse compatible ROI as Plane Flatness measurement">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Width="14" Height="14" Margin="0,0,5,0" Symbol="Link24" />
                                            <TextBlock>
                                                <TextBlock.Inlines>
                                                    <Run Text="{Binding DualRoiSecondLabel, Mode=OneWay}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{Binding Localization.ReuseRoi, Mode=OneWay}" />
                                                </TextBlock.Inlines>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Margin="0,7,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility"
                                                Value="{Binding IsSelectedStepViewerCaptureSupported, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedStepPlaneFlatness}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelectedStepGapFlush}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock FontSize="10.5"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           Text="Recipe-owned selection" />
                                <TextBlock Margin="0,2,0,0"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedStepTeachingSelectionSummary}" />
                                <WrapPanel Margin="0,7,0,0">
                                    <Button Margin="0,0,5,5"
                                            Content="{Binding SelectionCaptureActionText}"
                                            Command="{Binding BeginTeachingSelectionCaptureCommand}"
                                            ToolTip="Capture C3D grid cells only; no inspection algorithm runs"
                                            AutomationProperties.Name="Capture teaching selection" />
                                    <Button Margin="0,0,0,5"
                                            Content="Remove selection"
                                            Command="{Binding RemoveSelectedTeachingSelectionCommand}"
                                            AutomationProperties.Name="Remove applied teaching selection" />
                                </WrapPanel>

                                <TextBlock Margin="0,5,0,2"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           Text="Use an existing compatible selection" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding AvailableCompatibleSelections}"
                                              SelectedItem="{Binding SelectedCompatibleSelection}"
                                              DisplayMemberPath="Name" />
                                    <Button Grid.Column="1"
                                            Margin="6,0,0,0"
                                            Content="Use"
                                            Command="{Binding UseExistingTeachingSelectionCommand}"
                                            AutomationProperties.Name="Use existing teaching selection" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Margin="0,7,0,0"
                                        Visibility="{Binding IsSelectedStepCorrespondence, Converter={StaticResource BoolToVisibilityConverter}}">
                                <DataGrid MinHeight="96"
                                          MaxHeight="150"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding SelectedCorrespondenceRows}"
                                          SelectedItem="{Binding SelectedCorrespondenceRow}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*" Header="Source" Binding="{Binding SourceEntityId}" />
                                        <DataGridTextColumn Width="*" Header="Landmark" Binding="{Binding ReferenceLandmarkId}" />
                                        <DataGridTextColumn Width="Auto" Header="X" Binding="{Binding ReferencePosition.X, StringFormat=F3}" />
                                        <DataGridTextColumn Width="Auto" Header="Y" Binding="{Binding ReferencePosition.Y, StringFormat=F3}" />
                                        <DataGridTextColumn Width="Auto" Header="Z" Binding="{Binding ReferencePosition.Z, StringFormat=F3}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                           Margin="0,7,0,3"
                                           Text="Source entity" />
                                <ComboBox IsEditable="True"
                                          ItemsSource="{Binding AvailableCorrespondenceSourceEntityIds}"
                                          Text="{Binding CorrespondenceSourceEntityId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                           Text="Reference landmark ID" />
                                <TextBox Text="{Binding CorrespondenceReferenceLandmarkId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid Margin="0,7,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="10.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Reference X" />
                                        <TextBox Text="{Binding CorrespondenceReferenceX, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock FontSize="10.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Reference Y" />
                                        <TextBox Text="{Binding CorrespondenceReferenceY, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock FontSize="10.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Reference Z" />
                                        <TextBox Text="{Binding CorrespondenceReferenceZ, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                           Text="Reference frame ID" />
                                <TextBox Text="{Binding CorrespondenceReferenceFrameId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid Margin="0,7,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="10.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Reference unit" />
                                        <TextBox Text="{Binding CorrespondenceReferenceUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock FontSize="10.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Reference revision" />
                                        <TextBox Text="{Binding CorrespondenceReferenceRevision, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                           Margin="0,7,0,0"
                                           Text="Reference provenance" />
                                <TextBox Text="{Binding CorrespondenceReferenceProvenance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                           Margin="0,7,0,0"
                                           Text="Minimum normalized tetrahedron volume" />
                                <TextBox Text="{Binding CorrespondenceMinimumNormalizedTetrahedronVolume, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                <WrapPanel Margin="0,7,0,0">
                                    <Button Margin="0,0,5,5"
                                            Content="{Binding CorrespondenceCommitActionText}"
                                            Command="{Binding AddOrUpdateCorrespondenceRowCommand}"
                                            AutomationProperties.Name="Add or update landmark correspondence" />
                                    <Button Margin="0,0,0,5"
                                            Content="Remove row"
                                            Command="{Binding RemoveSelectedCorrespondenceRowCommand}"
                                            AutomationProperties.Name="Remove landmark correspondence" />
                                </WrapPanel>
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource ThreeD.WarningBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding CorrespondenceSelectionSummary}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Border Margin="0,7,0,0"
                            Padding="9"
                            Background="{DynamicResource ThreeD.PanelBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Visibility="{Binding IsSelectedStepPropertyGridSupported, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThreeD.InfoBrush}"
                                           Text="{Binding Localization.TypedParameters}" />
                                <TextBlock Grid.Column="1"
                                           Margin="8,0,0,0"
                                           FontSize="10"
                                           Foreground="{DynamicResource ThreeD.AccentBrush}"
                                           Text="{Binding SelectedStepAdapterStatus}" />
                            </Grid>
                            <propertyGrid:RecipeStepPropertyGridHost x:Name="StepPropertyGrid"
                                                                     Height="150"
                                                                     SelectedObject="{Binding SelectedStepPropertyDraft}"
                                                                     PropertyValueChanged="OnPropertyGridValueChanged" />
                            <TextBlock Margin="0,7,0,0"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding StepParameterEditStatus}" />
                            <WrapPanel Margin="0,7,0,0" HorizontalAlignment="Right">
                                <Button Margin="0,0,5,0"
                                        Content="{Binding Localization.Discard}"
                                        IsEnabled="{Binding HasPendingStepParameterChanges}"
                                        Click="OnDiscardParametersClick"
                                        AutomationProperties.Name="Discard selected step parameter changes" />
                                <Button Content="{Binding Localization.ApplyParameters}"
                                        IsEnabled="{Binding HasPendingStepParameterChanges}"
                                        Click="OnApplyParametersClick"
                                        AutomationProperties.Name="Apply selected step parameters without running inspection" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,7,0,0"
                            Padding="9"
                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Visibility="{Binding IsSelectedStepLineFit, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Fit evidence" />
                            <TextBlock Margin="0,4,0,0" FontSize="10.5" TextWrapping="Wrap" Text="{Binding LineFitExecutionSummary}" />
                            <TextBlock Margin="0,5,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Published input" />
                            <TextBlock FontSize="10.5" TextWrapping="Wrap" Text="{Binding LineFitUpstreamSummary}" />
                            <TextBlock Margin="0,5,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Selected diagnostic" />
                            <TextBlock FontSize="10.5" TextWrapping="Wrap" Text="{Binding LineFitSelectedDiagnosticSummary}" />
                            <TextBlock Margin="0,4,0,0" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding LineFitOutputHashSummary}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,7,0,0"
                            Padding="9"
                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Visibility="{Binding IsSelectedStepLineIntersection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Corner evidence" />
                            <TextBlock Margin="0,4,0,0" FontSize="10.5" TextWrapping="Wrap" Text="{Binding LineIntersectionExecutionSummary}" />
                            <TextBlock Margin="0,5,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Published inputs" />
                            <TextBlock FontSize="10.5" TextWrapping="Wrap" Text="{Binding LineIntersectionUpstreamSummary}" />
                            <TextBlock Margin="0,5,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Closest-approach evidence" />
                            <TextBlock FontSize="10.5" TextWrapping="Wrap" Text="{Binding LineIntersectionEvidenceSummary}" />
                            <TextBlock Margin="0,4,0,0" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding LineIntersectionOutputHashSummary}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,7,0,0"
                            Padding="9"
                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Visibility="{Binding IsSelectedStepFilter, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Execution evidence" />
                            <TextBlock Margin="0,4,0,0" FontSize="10.5" TextWrapping="Wrap" Text="{Binding FilterExecutionSummary}" />
                            <TextBlock Margin="0,4,0,0" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding FilterOutputHashSummary}" />
                            <Button Margin="0,7,0,0" HorizontalAlignment="Left" Content="Show source" Command="{Binding ShowFilterSourceCommand}" AutomationProperties.Name="Show original Filter source" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,7,0,0"
                            Padding="9"
                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Visibility="{Binding IsSelectedStepHeightDifferenceEdge, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Execution evidence" />
                            <TextBlock Margin="0,4,0,0" FontSize="10.5" TextWrapping="Wrap" Text="{Binding HeightDifferenceEdgeExecutionSummary}" />
                            <TextBlock Margin="0,5,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Published input" />
                            <TextBlock FontSize="10.5" TextWrapping="Wrap" Text="{Binding HeightDifferenceEdgeUpstreamSummary}" />
                            <TextBlock Margin="0,5,0,0" FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Search band" />
                            <TextBlock FontSize="10.5" TextWrapping="Wrap" Text="{Binding HeightDifferenceEdgeBandSummary}" />
                            <TextBlock Margin="0,4,0,0" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" TextWrapping="Wrap" Text="{Binding HeightDifferenceEdgeOutputHashSummary}" />
                        </StackPanel>
                    </Border>

                    <Expander Margin="0,7,0,0"
                              Header="Unadapted parameters (read-only)"
                              IsExpanded="True">
                        <Expander.Style>
                            <Style TargetType="Expander">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedStepFilter}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepHeightDifferenceEdge}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepLineFit}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepLineIntersection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Expander.Style>
                        <ItemsControl Margin="0,6,0,0"
                                      ItemsSource="{Binding SelectedPipelineStep.Parameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,7">
                                        <TextBlock FontSize="10.5"
                                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                                   Text="{Binding Name}" />
                                        <TextBox IsReadOnly="True" Text="{Binding Value}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Expander Margin="0,7,0,0"
                              Header="{Binding Localization.Output}"
                              IsExpanded="True">
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Margin="0,0,0,4"
                                       Text="{Binding Localization.Produces}" />
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThreeD.AccentBrush}"
                                       Text="{Binding SelectedPipelineStep.OutputContract}" />
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Text="{Binding Localization.OutputEntity}" />
                            <TextBox Text="{Binding SelectedPipelineStep.OutputEntityId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>

                    <Expander Margin="0,7,0,0"
                              Header="Evidence"
                              IsExpanded="True">
                        <Expander.Style>
                            <Style TargetType="Expander">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedStepFilter}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepHeightDifferenceEdge}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepLineFit}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedStepLineIntersection}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Expander.Style>
                        <Border Margin="0,6,0,0"
                                Padding="8"
                                Background="{DynamicResource ThreeD.WarningSurfaceBrush}"
                                BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThreeD.WarningBrush}"
                                           Text="{Binding SelectedPipelineStep.State}" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ValidationSummary}" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="No Preview, Run, or result evidence exists for this generic teaching step." />
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Margin="0,7,0,0"
                              Header="Advanced identity &amp; order"
                              IsExpanded="False">
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Margin="0,0,0,4"
                                       Text="Step ID" />
                            <TextBox Text="{Binding SelectedPipelineStep.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel Margin="0,7,0,0">
                                <Button Margin="0,0,5,5"
                                        Content="Move up"
                                        Command="{Binding MoveSelectedStepUpCommand}" />
                                <Button Margin="0,0,5,5"
                                        Content="Move down"
                                        Command="{Binding MoveSelectedStepDownCommand}" />
                                <Button Margin="0,0,0,5"
                                        Content="Remove step"
                                        Command="{Binding RemoveSelectedStepCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
