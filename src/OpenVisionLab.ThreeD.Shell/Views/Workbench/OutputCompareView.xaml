<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.OutputCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             MinHeight="390"
             AutomationProperties.AutomationId="OutputCompareView">
    <Border Background="{DynamicResource ThreeD.PanelBrush}"
            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
            BorderThickness="0,1,0,0"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Width="18"
                                   Height="18"
                                   Margin="0,0,7,0"
                                   Foreground="{DynamicResource ThreeD.AccentBrush}"
                                   Symbol="Document24" />
                    <StackPanel>
                        <TextBlock Style="{DynamicResource ThreeD.DockPanelTitleTextStyle}"
                                   Text="{Binding Localization.OutputCompareTitle}" />
                        <TextBlock Style="{DynamicResource ThreeD.DockPanelCaptionTextStyle}"
                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                   FontSize="10"
                                   Text="{Binding Localization.OutputCompareDetail}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="7,3"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="3">
                    <TextBlock FontSize="9.5"
                               Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                               Text="{Binding ArtifactRegistrySummary}" />
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,8,0,0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <Grid Width="1700">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="560" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="560" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="560" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="1"
                            ClipToBounds="True"
                            Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Padding="8,6"
                                    Background="{DynamicResource ThreeD.CommandBarBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="5,2"
                                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                            CornerRadius="2">
                                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThreeD.InfoBrush}" Text="A" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                        <ComboBox
                                                  ItemsSource="{Binding CompareCandidates}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding CompareSlotAArtifactId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  AutomationProperties.Name="Compare slot A output" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                                   Text="{Binding CompareSlotASummary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="1">
                                <ContentControl x:Name="SlotAViewerHost" />
                                <TextBlock x:Name="SlotAEmptyText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="1"
                            ClipToBounds="True"
                            Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Padding="8,6"
                                    Background="{DynamicResource ThreeD.CommandBarBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="5,2"
                                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                            CornerRadius="2">
                                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThreeD.InfoBrush}" Text="B" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                        <ComboBox
                                                  ItemsSource="{Binding CompareCandidates}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding CompareSlotBArtifactId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  AutomationProperties.Name="Compare slot B output" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                                   Text="{Binding CompareSlotBSummary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="1">
                                <ContentControl x:Name="SlotBViewerHost" />
                                <TextBlock x:Name="SlotBEmptyText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4"
                            Padding="1"
                            ClipToBounds="True"
                            Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Padding="8,6"
                                    Background="{DynamicResource ThreeD.CommandBarBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="5,2"
                                            Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                            CornerRadius="2">
                                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThreeD.InfoBrush}" Text="C" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                        <ComboBox
                                                  ItemsSource="{Binding CompareCandidates}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding CompareSlotCArtifactId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  AutomationProperties.Name="Compare slot C output" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                                   Text="{Binding CompareSlotCSummary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="1">
                                <ContentControl x:Name="SlotCViewerHost" />
                                <TextBlock x:Name="SlotCEmptyText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
