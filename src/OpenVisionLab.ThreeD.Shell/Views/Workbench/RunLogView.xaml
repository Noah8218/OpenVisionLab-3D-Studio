<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.RunLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:logView="clr-namespace:OpenVisionLab.Logging.Controls.View;assembly=OpenVisionLab.Logging.Controls"
             AutomationProperties.AutomationId="WorkbenchRunLog">
    <TabControl>
        <TabItem Header="Application Log">
            <logView:LogPanelView />
        </TabItem>
        <TabItem Header="Workbench Session">
            <ListBox Margin="8"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding RunLog}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,3"
                                Padding="6,4"
                                Background="#f9fafb"
                                BorderBrush="#e5e7eb"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="74" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="#6b7280" Text="{Binding Time}" />
                                <TextBlock Grid.Column="1" Foreground="#0f766e" Text="{Binding Category}" />
                                <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>
    </TabControl>
</UserControl>
