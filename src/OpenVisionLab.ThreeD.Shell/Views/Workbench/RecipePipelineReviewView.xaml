<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.RecipePipelineReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             AutomationProperties.AutomationId="RecipePipelineReview">
    <UserControl.Resources>
        <Style x:Key="PipelineStateBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThreeD.DisabledSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="6,2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Ready">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.InfoSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview running">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.InfoSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview ready">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.InfoSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Published">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.PassSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.PassBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview stale">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.WarningSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Waiting for upstream">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.WarningSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Taught / needs correction">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.WarningSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Taught incomplete">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.WarningSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Error">
                    <Setter Property="Background" Value="{DynamicResource ThreeD.FailSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.FailBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PipelineStateIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="Symbol" Value="Clock24" />
            <Setter Property="Foreground" Value="{DynamicResource ThreeD.MutedTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Ready">
                    <Setter Property="Symbol" Value="CheckmarkCircle24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview running">
                    <Setter Property="Symbol" Value="ArrowClockwise24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview ready">
                    <Setter Property="Symbol" Value="Eye24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Published">
                    <Setter Property="Symbol" Value="CheckmarkCircle24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.PassBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview stale">
                    <Setter Property="Symbol" Value="ArrowClockwise24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Waiting for upstream">
                    <Setter Property="Symbol" Value="Warning24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Taught / needs correction">
                    <Setter Property="Symbol" Value="Warning24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Taught incomplete">
                    <Setter Property="Symbol" Value="Warning24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Error">
                    <Setter Property="Symbol" Value="ErrorCircle24" />
                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.FailBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PipelineStateTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ThreeD.MutedTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Ready"><Setter Property="Foreground" Value="{DynamicResource ThreeD.AccentBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview running"><Setter Property="Foreground" Value="{DynamicResource ThreeD.InfoBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview ready"><Setter Property="Foreground" Value="{DynamicResource ThreeD.AccentBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Published"><Setter Property="Foreground" Value="{DynamicResource ThreeD.PassBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Preview stale"><Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Waiting for upstream"><Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Taught / needs correction"><Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Taught incomplete"><Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" /></DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Error"><Setter Property="Foreground" Value="{DynamicResource ThreeD.FailBrush}" /></DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource ThreeD.PanelBrush}"
            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
            BorderThickness="0,1,0,0"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThreeD.TextBrush}"
                               Text="Recipe Pipeline / Teach Review" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding ValidationSummary}" />
                </StackPanel>
                <WrapPanel Grid.Column="1"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center">
                    <Button Margin="0,0,4,0" Content="Validate" Command="{Binding ValidateTeachingRecipeCommand}" />
                    <Button Margin="0,0,4,0" Content="Up" Command="{Binding MoveSelectedStepUpCommand}" />
                    <Button Margin="0,0,4,0" Content="Down" Command="{Binding MoveSelectedStepDownCommand}" />
                    <Button Content="Remove" Command="{Binding RemoveSelectedStepCommand}" />
                </WrapPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="5,0,5,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="145" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="#" />
                    <TextBlock Grid.Column="1" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Tool" />
                    <TextBlock Grid.Column="2" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Inputs" />
                    <TextBlock Grid.Column="3" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="Typed output" />
                    <TextBlock Grid.Column="4" HorizontalAlignment="Right" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="State" />
                </Grid>
                <ListBox Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding PipelineSteps}"
                         SelectedItem="{Binding SelectedPipelineStep, Mode=TwoWay}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,3"
                                    Padding="6,4"
                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource ThreeD.SelectedSurfaceBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontSize="10.5" FontWeight="SemiBold" Text="{Binding Order}" />
                                    <TextBlock Grid.Column="1" FontSize="10.5" FontWeight="SemiBold" Text="{Binding ToolName}" />
                                    <TextBlock Grid.Column="2"
                                               Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                               FontSize="10.5"
                                               Text="{Binding InputSummary}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3"
                                               Foreground="{DynamicResource ThreeD.AccentBrush}"
                                               FontSize="10.5"
                                               Text="{Binding OutputEntityId}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="4"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource PipelineStateBadgeStyle}"
                                            ToolTip="{Binding State, StringFormat=Pipeline step state: {0}}"
                                            AutomationProperties.Name="{Binding State, StringFormat=Pipeline step state: {0}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Width="14"
                                                           Height="14"
                                                           Margin="0,0,4,0"
                                                           Style="{StaticResource PipelineStateIconStyle}" />
                                            <TextBlock MaxWidth="122"
                                                       FontSize="9.5"
                                                       FontWeight="SemiBold"
                                                       Style="{StaticResource PipelineStateTextStyle}"
                                                       Text="{Binding State}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Grid.Row="1"
                           IsHitTestVisible="False"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                           Text="{Binding PipelineEmptyHint}"
                           TextWrapping="Wrap" />
            </Grid>

            <ItemsControl Grid.Row="2" Margin="0,6,0,0" ItemsSource="{Binding ValidationMessages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,1,0,0"
                                   Foreground="{DynamicResource ThreeD.WarningBrush}"
                                   FontSize="10.5"
                                   Text="{Binding Message, StringFormat=• {0}}"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
