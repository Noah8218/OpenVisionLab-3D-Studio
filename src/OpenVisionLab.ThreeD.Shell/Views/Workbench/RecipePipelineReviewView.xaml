<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.RecipePipelineReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:shell="clr-namespace:OpenVisionLab.ThreeD.Shell"
             AutomationProperties.AutomationId="RecipePipelineReview">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="{DynamicResource ThreeD.PanelBrush}"
            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
            BorderThickness="0,1,0,0"
            Padding="12">
        <Grid>
            <TabControl x:Name="ReviewTabs"
                        Margin="0"
                        AutomationProperties.AutomationId="RecipePipelineReviewTabs">
                <TabItem Header="{Binding Localization.PipelineValidation}">
                    <Grid Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{DynamicResource ThreeD.DockPanelTitleTextStyle}"
                                           Text="{Binding Localization.RecipePipelineTeachReview}" />
                                <TextBlock Style="{DynamicResource ThreeD.DockPanelCaptionTextStyle}"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding ValidationSummary}" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center">
                                <Button Margin="0,0,4,0" Content="{Binding Localization.Validate}" Command="{Binding ValidateTeachingRecipeCommand}" />
                                <Button Margin="0,0,4,0" Content="{Binding Localization.MoveUp}" Command="{Binding MoveSelectedStepUpCommand}" />
                                <Button Margin="0,0,4,0" Content="{Binding Localization.MoveDown}" Command="{Binding MoveSelectedStepDownCommand}" />
                                <Button Content="{Binding Localization.Remove}" Command="{Binding RemoveSelectedStepCommand}" />
                            </WrapPanel>
                        </Grid>
                        <Grid Grid.Row="1" Margin="5,4,5,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnNumber}" />
                            <TextBlock Grid.Column="1" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnTool}" />
                            <TextBlock Grid.Column="2" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnInputs}" />
                            <TextBlock Grid.Column="3" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnTypedOutput}" />
                            <TextBlock Grid.Column="4" HorizontalAlignment="Right" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnState}" />
                        </Grid>
                        <ListBox Grid.Row="2"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemsSource="{Binding PipelineSteps}"
                                 SelectedItem="{Binding SelectedPipelineStep, Mode=TwoWay}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,3"
                                            Padding="6,4"
                                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ThreeD.SelectedSurfaceBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="145" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="10.5" FontWeight="SemiBold" Text="{Binding Order}" />
                                            <TextBlock Grid.Column="1" FontSize="10.5" FontWeight="SemiBold" Text="{Binding ToolName}" />
                                            <TextBlock Grid.Column="2" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" FontSize="10.5" Text="{Binding InputSummary}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" Foreground="{DynamicResource ThreeD.AccentBrush}" FontSize="10.5" Text="{Binding OutputEntityId}" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="4"
                                                    HorizontalAlignment="Right"
                                                    Style="{DynamicResource ThreeD.WorkflowStateBadgeStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Width="14" Height="14" Margin="0,0,4,0" Style="{DynamicResource ThreeD.WorkflowStateIconStyle}" />
                                                    <TextBlock MaxWidth="122" FontSize="9.5" FontWeight="SemiBold" Style="{DynamicResource ThreeD.WorkflowStateTextStyle}" Text="{Binding State}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Grid.Row="2"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                   Text="{Binding PipelineEmptyHint}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding IsPipelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ItemsControl Grid.Row="3" Margin="0,6,0,0" ItemsSource="{Binding ValidationMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,1,0,0"
                                               Foreground="{DynamicResource ThreeD.WarningBrush}"
                                               FontSize="10.5"
                                               Text="{Binding Message, StringFormat=??{0}}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Localization.FlowMap}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="4,0,4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding Localization.FlowMapTitle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           FontSize="10"
                                           Text="{Binding Localization.FlowMapDetail}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="7,3"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <TextBlock FontSize="9.5" Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" Text="{Binding Localization.FlowMapReadOnly}" />
                            </Border>
                        </Grid>
                        <ListBox Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemsSource="{Binding PipelineSteps}"
                                 SelectedItem="{Binding SelectedPipelineStep, Mode=TwoWay}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="{Binding Localization.FlowMapTitle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,5"
                                            Padding="8,6"
                                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ThreeD.PanelAlternateBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ThreeD.SelectedSurfaceBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="1.3*" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="145" />
                                            </Grid.ColumnDefinitions>
                                            <Border Padding="6,4"
                                                    Background="{DynamicResource ThreeD.PanelBrush}"
                                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                <StackPanel>
                                                    <TextBlock FontSize="9" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding DataContext.Localization.FlowMapInput, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    <TextBlock Margin="0,2,0,0" FontSize="10" FontWeight="SemiBold" Text="{Binding InputContract}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Foreground="{DynamicResource ThreeD.SecondaryTextBrush}" FontSize="9.5" Text="{Binding InputSummary}" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Margin="0,3,0,0"
                                                                Orientation="Horizontal"
                                                                ToolTip="{Binding InputPortDetail}">
                                                        <ui:SymbolIcon Width="12" Height="12" Margin="0,0,3,0" Symbol="Warning24">
                                                            <ui:SymbolIcon.Style>
                                                                <Style TargetType="ui:SymbolIcon">
                                                                    <Setter Property="Symbol" Value="Warning24" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding InputPortHasIssue}" Value="False">
                                                                            <Setter Property="Symbol" Value="CheckmarkCircle24" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource ThreeD.PassBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:SymbolIcon.Style>
                                                        </ui:SymbolIcon>
                                                        <TextBlock MaxWidth="142"
                                                                   FontSize="8.8"
                                                                   Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                                   Text="{Binding InputPortState}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ThreeD.AccentBrush}" FontSize="18" Text="→" />
                                            <Border Grid.Column="2"
                                                    Padding="7,4"
                                                    Background="{DynamicResource ThreeD.SelectedSurfaceBrush}"
                                                    BorderBrush="{DynamicResource ThreeD.AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Margin="0,0,6,0" Foreground="{DynamicResource ThreeD.AccentBrush}" FontSize="10" FontWeight="Bold" Text="{Binding Order}" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontSize="10.5" FontWeight="SemiBold" Text="{Binding ToolName}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Foreground="{DynamicResource ThreeD.MutedTextBrush}" FontSize="9" Text="{Binding Id}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <TextBlock Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ThreeD.AccentBrush}" FontSize="18" Text="→" />
                                            <Border Grid.Column="4"
                                                    Padding="6,4"
                                                    Background="{DynamicResource ThreeD.PanelBrush}"
                                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                <StackPanel>
                                                    <TextBlock FontSize="9" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding DataContext.Localization.FlowMapOutput, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    <TextBlock Margin="0,2,0,0" FontSize="10" FontWeight="SemiBold" Text="{Binding OutputContract}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Foreground="{DynamicResource ThreeD.AccentBrush}" FontSize="9.5" Text="{Binding OutputEntityId}" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Margin="0,3,0,0"
                                                                Orientation="Horizontal"
                                                                ToolTip="{Binding OutputPortDetail}">
                                                        <ui:SymbolIcon Width="12" Height="12" Margin="0,0,3,0" Symbol="Warning24">
                                                            <ui:SymbolIcon.Style>
                                                                <Style TargetType="ui:SymbolIcon">
                                                                    <Setter Property="Symbol" Value="Warning24" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource ThreeD.WarningBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding OutputPortHasIssue}" Value="False">
                                                                            <Setter Property="Symbol" Value="CheckmarkCircle24" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource ThreeD.PassBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:SymbolIcon.Style>
                                                        </ui:SymbolIcon>
                                                        <TextBlock MaxWidth="142"
                                                                   FontSize="8.8"
                                                                   Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                                   Text="{Binding OutputPortState}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="5"
                                                    Margin="8,0,0,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Style="{DynamicResource ThreeD.WorkflowStateBadgeStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Width="14" Height="14" Margin="0,0,4,0" Style="{DynamicResource ThreeD.WorkflowStateIconStyle}" />
                                                    <TextBlock MaxWidth="108" FontSize="9.5" FontWeight="SemiBold" Style="{DynamicResource ThreeD.WorkflowStateTextStyle}" Text="{Binding State}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Grid.Row="1"
                                   IsHitTestVisible="False"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                   Text="{Binding Localization.FlowMapEmptyHint}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding IsPipelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Localization.Problems}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="4,0,4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding Localization.ProblemsTitle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           FontSize="10"
                                           Text="{Binding Localization.ProblemsDetail}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="7,3"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <TextBlock FontSize="9.5"
                                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                           Text="{Binding FlowProblemsSummary}" />
                            </Border>
                        </Grid>
                        <Grid Grid.Row="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Visibility="{Binding HasFlowProblems, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding FlowPortDiagnostics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="4,0,4,4"
                                                        Padding="7,5"
                                                        Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                                        BorderBrush="{DynamicResource ThreeD.WarningBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        AutomationProperties.Name="{Binding AccessibleName}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ui:SymbolIcon Width="15"
                                                                       Height="15"
                                                                       Margin="0,1,6,0"
                                                                       Foreground="{DynamicResource ThreeD.WarningBrush}"
                                                                       Symbol="Warning24" />
                                                        <StackPanel Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding StepTitle}" />
                                                                <TextBlock Margin="6,0,0,0"
                                                                           FontSize="9.5"
                                                                           Foreground="{DynamicResource ThreeD.WarningBrush}"
                                                                           Text="{Binding Status}" />
                                                            </StackPanel>
                                                            <TextBlock Margin="0,1,0,0"
                                                                       FontSize="9.5"
                                                                       Foreground="{DynamicResource ThreeD.AccentBrush}"
                                                                       Text="{Binding EntityId}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Margin="0,1,0,0"
                                                                       FontSize="9"
                                                                       Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                                       Text="{Binding Detail}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <ui:Button Grid.Column="2"
                                                                   Margin="8,0,0,0"
                                                                   Padding="7,2"
                                                                   VerticalAlignment="Center"
                                                                   Content="{Binding DataContext.Localization.FocusStep, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   Icon="{ui:SymbolIcon TargetArrow24}"
                                                                   Command="{Binding DataContext.FocusFlowProblemStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   CommandParameter="{Binding}"
                                                                   ToolTip="{Binding DataContext.Localization.FocusStep, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Margin="4,6,4,4"
                                               FontSize="9.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                               Text="{Binding Localization.ProblemsValidationMessages}" />
                                    <ItemsControl ItemsSource="{Binding ValidationMessages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="4,0,4,4"
                                                        Padding="7,5"
                                                        Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="3">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Width="14"
                                                                       Height="14"
                                                                       Margin="0,0,5,0"
                                                                       Foreground="{DynamicResource ThreeD.WarningBrush}"
                                                                       Symbol="Warning24" />
                                                        <TextBlock FontSize="9.5"
                                                                   Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                                   Text="{Binding Message}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding Localization.ProblemsEmptyHint}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFlowProblems}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Localization.RunRecord}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="4,0,4,6">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="{Binding Localization.RunRecordTitle}" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       FontSize="10"
                                       Text="{Binding Localization.RunRecordDetail}" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="{DynamicResource ThreeD.AccentBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Text="{Binding RunRecordSummary, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="4,1,4,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <WrapPanel VerticalAlignment="Center">
                                <ui:Button x:Name="RunRecordOpenButton"
                                           Margin="0,0,5,0"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon FolderOpen24}"
                                           Content="{Binding Localization.RunRecordOpen}"
                                           Command="{Binding RunRecordContext.SelectRunRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           AutomationProperties.AutomationId="RunRecordOpenButton"
                                           AutomationProperties.Name="{Binding Localization.RunRecordOpen}" />
                                <ui:Button x:Name="RunRecordOpenJsonButton"
                                           Margin="0,0,5,0"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Document24}"
                                           Content="{Binding Localization.RunRecordOpenCurrent}"
                                           Command="{Binding RunRecordContext.OpenRunRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           AutomationProperties.AutomationId="RunRecordOpenJsonButton"
                                           AutomationProperties.Name="{Binding Localization.RunRecordOpenCurrent}" />
                                <ui:Button Margin="0,0,5,0"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon DocumentText24}"
                                           Content="{Binding Localization.RunRecordOpenHtml}"
                                           Command="{Binding RunRecordContext.OpenHtmlReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           AutomationProperties.AutomationId="RunRecordOpenHtmlButton"
                                           AutomationProperties.Name="{Binding Localization.RunRecordOpenHtml}" />
                                <ui:Button Margin="0,0,5,0"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Table24}"
                                           Content="{Binding Localization.RunRecordOpenCsv}"
                                           Command="{Binding RunRecordContext.OpenCsvReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           AutomationProperties.AutomationId="RunRecordOpenCsvButton"
                                           AutomationProperties.Name="{Binding Localization.RunRecordOpenCsv}" />
                                <ui:Button x:Name="RunRecordExportButton"
                                           Margin="0,0,5,0"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon SaveCopy24}"
                                           Content="{Binding Localization.RunRecordExport}"
                                           Command="{Binding RunRecordContext.ExportRunRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           AutomationProperties.AutomationId="RunRecordExportButton"
                                           AutomationProperties.Name="{Binding Localization.RunRecordExport}" />
                                <ui:Button Margin="0,0,10,0"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Folder24}"
                                           Content="{Binding Localization.RunRecordOpenFolder}"
                                           Command="{Binding RunRecordContext.OpenRunRecordFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           AutomationProperties.AutomationId="RunRecordOpenFolderButton"
                                           AutomationProperties.Name="{Binding Localization.RunRecordOpenFolder}" />
                            </WrapPanel>
                            <ComboBox x:Name="RecentRunRecordCombo"
                                      Grid.Column="1"
                                      MinWidth="260"
                                      Margin="0,0,5,0"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding RunRecordContext.RecentRunRecords, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding RunRecordContext.SelectedRecentRunRecord, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                      AutomationProperties.AutomationId="RunRecordRecentCombo"
                                      AutomationProperties.Name="{Binding Localization.RunRecordRecent}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding RecordedAt}" />
                                            <Run Text=" | " />
                                            <Run FontWeight="SemiBold" Text="{Binding Status}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding StepCount}" />
                                            <Run Text=" steps | " />
                                            <Run Text="{Binding Name}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <ui:Button x:Name="RunRecordOpenRecentButton"
                                       Grid.Column="2"
                                       Appearance="Primary"
                                       Icon="{ui:SymbolIcon ArrowRight24}"
                                       Content="{Binding Localization.RunRecordOpenRecent}"
                                       Command="{Binding RunRecordContext.OpenRecentRunRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       CommandParameter="{Binding SelectedItem, ElementName=RecentRunRecordCombo}"
                                       AutomationProperties.AutomationId="RunRecordOpenRecentButton"
                                       AutomationProperties.Name="{Binding Localization.RunRecordOpenRecent}" />
                        </Grid>
                        <Grid Grid.Row="2" Margin="8,2,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnNumber}" />
                            <TextBlock Grid.Column="1" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnTool}" />
                            <TextBlock Grid.Column="2" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnState}" />
                            <TextBlock Grid.Column="3" FontSize="9.5" Foreground="{DynamicResource ThreeD.MutedTextBrush}" Text="{Binding Localization.ColumnEvidence}" />
                        </Grid>
                        <ListBox Grid.Row="3"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemsSource="{Binding RunRecordSteps, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="{Binding Localization.RunRecordTitle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,3"
                                            Padding="7,5"
                                            Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                            BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="10.5" FontWeight="SemiBold" Text="{Binding Order}" />
                                            <TextBlock Grid.Column="1" FontSize="10.5" FontWeight="SemiBold" Text="{Binding Stage}" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="2"
                                                    Margin="0,0,8,0"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource ThreeD.InfoSurfaceBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.DividerBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pass">
                                                                <Setter Property="Background" Value="{DynamicResource ThreeD.PassSurfaceBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.PassBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Fail">
                                                                <Setter Property="Background" Value="{DynamicResource ThreeD.FailSurfaceBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.FailBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                                <Setter Property="Background" Value="{DynamicResource ThreeD.WarningSurfaceBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource ThreeD.WarningBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="9.5" FontWeight="SemiBold" Text="{Binding Status}" />
                                            </Border>
                                            <TextBlock Grid.Column="3"
                                                       Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                       FontSize="10"
                                                       Text="{Binding Evidence}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Evidence}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Localization.ValidationSet}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="4,0,4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="{Binding Localization.ValidationSetTitle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           FontSize="10"
                                           Text="{Binding Localization.ValidationSetDetail}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center">
                                <Button Margin="0,0,5,0"
                                        Click="SelectValidationSetSources_Click"
                                        IsEnabled="{Binding IsValidationSetIdle}"
                                        ToolTip="{Binding Localization.ValidationSetAddSamples}"
                                        AutomationProperties.Name="{Binding Localization.ValidationSetAddSamples}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Width="15" Height="15" Margin="0,0,5,0" Symbol="DocumentAdd24" />
                                        <TextBlock Text="{Binding Localization.ValidationSetAddSamples}" />
                                    </StackPanel>
                                </Button>
                                <Button Margin="0,0,5,0"
                                        Command="{Binding RunValidationSetCommand}"
                                        ToolTip="{Binding Localization.ValidationSetRunAll}"
                                        AutomationProperties.Name="{Binding Localization.ValidationSetRunAll}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Width="15" Height="15" Margin="0,0,5,0" Symbol="Play24" />
                                        <TextBlock Text="{Binding Localization.ValidationSetRunAll}" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ClearValidationSetCommand}"
                                        ToolTip="{Binding Localization.ValidationSetClear}"
                                        AutomationProperties.Name="{Binding Localization.ValidationSetClear}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Width="15" Height="15" Margin="0,0,5,0" Symbol="Dismiss24" />
                                        <TextBlock Text="{Binding Localization.ValidationSetClear}" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="4,0,4,6"
                                Padding="8,5"
                                Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Margin="0,0,8,0"
                                           FontSize="9.5"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThreeD.AccentBrush}"
                                           Text="{Binding Localization.ValidationSetCoverage}" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontSize="9.5"
                                               Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                               Text="{Binding ValidationSetCapability}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding ValidationSetCapability}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="9.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.AccentBrush}"
                                               Text="{Binding ValidationSetSummary}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.45*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Border Padding="6"
                                    Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Margin="2,0,2,5"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Text="{Binding Localization.ValidationSetSamples}" />
                                    <DataGrid Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserReorderColumns="False"
                                              CanUserResizeRows="False"
                                              HeadersVisibility="Column"
                                              IsReadOnly="True"
                                              ItemsSource="{Binding ValidationSetSamples}"
                                              SelectedItem="{Binding SelectedValidationSetSample, Mode=TwoWay}"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              AutomationProperties.Name="{Binding Localization.ValidationSetSamples}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="34" Header="#" Binding="{Binding Order}" />
                                            <DataGridTextColumn Width="1.5*" Header="{Binding ValidationSetFile, Source={x:Static shell:ThreeDLocalization.Shared}}" Binding="{Binding FileName}" />
                                            <DataGridTextColumn Width="72" Header="{Binding ColumnState, Source={x:Static shell:ThreeDLocalization.Shared}}" Binding="{Binding StatusText}" />
                                            <DataGridTextColumn Width="76" Header="{Binding ValidationSetDuration, Source={x:Static shell:ThreeDLocalization.Shared}}" Binding="{Binding Duration}" />
                                            <DataGridTextColumn Width="2*" Header="{Binding ColumnEvidence, Source={x:Static shell:ThreeDLocalization.Shared}}" Binding="{Binding Message}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Grid.Row="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                               Text="{Binding Localization.ValidationSetNoSamples}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasValidationSetSamples}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="6"
                                    Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                    BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Margin="2,0,2,5"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Text="{Binding Localization.ValidationSetSelectedRecord}" />
                                    <ListBox Grid.Row="1"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemsSource="{Binding SelectedValidationSetSteps}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,3"
                                                        Padding="7,5"
                                                        Background="{DynamicResource ThreeD.PanelBrush}"
                                                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="64" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="10" FontWeight="SemiBold" Text="{Binding Order}" />
                                                        <TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold" Text="{Binding ToolName}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2" FontSize="9.5" FontWeight="SemiBold" Text="{Binding StatusText}" />
                                                        <TextBlock Grid.Column="3"
                                                                   FontSize="9.5"
                                                                   Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                                                   Text="{Binding Evidence}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding Evidence}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Grid.Row="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                               Text="{Binding Localization.ValidationSetNoSelection}"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSelectedValidationSetSample}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
