<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Workbench.ToolRecipeWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dock="clr-namespace:OpenVisionLab.ThreeD.Docking.Controls;assembly=OpenVisionLab.ThreeD.Docking.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:workbench="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Workbench"
             AutomationProperties.AutomationId="ToolRecipeWorkbench">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Key="Escape"
                    Command="{Binding Workbench.CancelTeachingSelectionCaptureCommand}" />
    </UserControl.InputBindings>

    <dock:OpenVisionDockWorkspaceView x:Name="DockWorkspace"
                                      DataLayersTitle="{Binding Localization.ToolboxAndEntities}"
                                      ViewerTitle="{Binding Localization.Viewer}"
                                      ToolInspectorTitle="{Binding Localization.StepParameters}"
                                      EvidenceTitle="{Binding Localization.PipelineValidation}"
                                      OutputCompareTitle="{Binding Localization.OutputCompare}"
                                      DisplayedOutputsTitle="{Binding Localization.DisplayedOutputs}"
                                      LinkedViewTitle="{Binding Localization.SessionLog}"
                                      ProfileTitle="{Binding Localization.HeightProfile}"
                                      FitDiagnosticsTitle="{Binding Localization.FitDiagnostics}"
                                      IntersectionEvidenceTitle="{Binding Localization.IntersectionEvidence}"
                                      CorrespondenceEvidenceTitle="{Binding Localization.CorrespondenceEvidence}"
                                      IsBottomPaneExpanded="{Binding Workbench.IsPipelineReviewExpanded}">
        <dock:OpenVisionDockWorkspaceView.DataLayersContent>
            <workbench:ToolboxEntityExplorerView DataContext="{Binding Workbench}" />
        </dock:OpenVisionDockWorkspaceView.DataLayersContent>

        <dock:OpenVisionDockWorkspaceView.ViewerContent>
            <Grid Background="{DynamicResource ThreeD.PanelBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Padding="16,10"
                        Background="{DynamicResource ThreeD.CommandBarBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="10.5"
                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                   Text="{Binding Workbench.ViewerSourceSummary}" />
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    AutomationProperties.Name="Explicit inspection workflow stages">
                            <Border Padding="8,4"
                                    Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                    CornerRadius="3">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Width="14" Height="14" Margin="0,0,4,0" Foreground="{DynamicResource ThreeD.InfoBrush}" Symbol="WrenchScrewdriver24" />
                                    <TextBlock FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.InfoBrush}"
                                               Text="{Binding Localization.Teach}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Margin="6,0" VerticalAlignment="Center" Foreground="{DynamicResource ThreeD.DisabledBrush}" Text="→" />
                            <ui:Button Padding="8,3"
                                       Content="{Binding Localization.Preview}"
                                       Icon="{ui:SymbolIcon Eye24}"
                                       Command="{Binding Workbench.PreviewSelectedStepCommand}"
                                       ToolTip="Execute only the selected typed step"
                                       AutomationProperties.Name="Preview selected inspection step" />
                            <TextBlock Margin="6,0" VerticalAlignment="Center" Foreground="{DynamicResource ThreeD.DisabledBrush}" Text="→" />
                            <ui:Button Padding="8,3"
                                       Content="{Binding Localization.Run}"
                                       Icon="{ui:SymbolIcon PlayCircle24}"
                                       Command="{Binding Workbench.RunTeachingRecipeCommand}"
                                       ToolTip="Enabled only when every taught step has a typed adapter"
                                       AutomationProperties.Name="Run complete inspection recipe" />
                            <TextBlock Margin="6,0" VerticalAlignment="Center" Foreground="{DynamicResource ThreeD.DisabledBrush}" Text="→" />
                            <ui:Button Padding="8,3"
                                       Content="{Binding Localization.Publish}"
                                       Icon="{ui:SymbolIcon CheckmarkCircle24}"
                                       Command="{Binding Workbench.PublishSelectedStepCommand}"
                                       ToolTip="Publish the current non-stale Preview without re-running"
                                       AutomationProperties.Name="Publish selected inspection output" />
                            <ui:Button Margin="5,0,0,0"
                                       Padding="8,3"
                                       Content="{Binding Localization.Cancel}"
                                       Icon="{ui:SymbolIcon ArrowUndo24}"
                                       Command="{Binding Workbench.CancelSelectedPreviewCommand}"
                                       Visibility="{Binding Workbench.IsSelectedStepPreviewRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                                       AutomationProperties.Name="Cancel selected Preview" />
                        </StackPanel>
                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,7,0,0"
                                Padding="9,7"
                                Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                AutomationProperties.Name="Selected step work context">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Workbench.HasSelectedPipelineStep}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Width="16"
                                                       Height="16"
                                                       Margin="0,0,6,0"
                                                       Foreground="{DynamicResource ThreeD.AccentBrush}"
                                                       Symbol="FlowchartCircle24" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThreeD.TextBrush}"
                                                   Text="{Binding Workbench.SelectedPipelineStepTitle}" />
                                    </StackPanel>
                                    <TextBlock Margin="22,3,0,0"
                                               FontSize="10"
                                               Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="Input: {0}  /  Output: {1}">
                                                <Binding Path="Workbench.SelectedPipelineStep.InputEntityIdsText" />
                                                <Binding Path="Workbench.SelectedPipelineStep.OutputEntityId" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Margin="22,2,0,0"
                                               FontSize="10"
                                               Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Workbench.StepParameterEditStatus}" />
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Workbench.HasSelectedPipelineStep}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.TextBrush}"
                                               Text="{Binding Localization.NoRecipeStepSelected}" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="10"
                                               Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                               Text="{Binding Localization.NoRecipeStepSelectedDetail}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Margin="12,0,0,0"
                                        Padding="7,4"
                                        MaxWidth="220"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.InfoBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Workbench.SelectedStepAdapterStatus}" />
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Margin="0,7,0,0"
                                Padding="8,6"
                                Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                BorderBrush="{DynamicResource ThreeD.InfoBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Visibility="{Binding Workbench.IsTeachingSelectionCaptureActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                AutomationProperties.AutomationId="TeachingSelectionCaptureRibbon">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.InfoBrush}"
                                               Text="{Binding Workbench.TeachingSelectionCaptureTitle}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="10"
                                               Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                               Text="{Binding Workbench.TeachingSelectionCaptureProgress}" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center">
                                    <Button Margin="0,0,5,0"
                                            Content="Undo last point"
                                            Command="{Binding Workbench.UndoTeachingSelectionCaptureCommand}"
                                            AutomationProperties.Name="Undo last teaching point" />
                                    <Button Margin="0,0,5,0"
                                            Content="Cancel"
                                            Command="{Binding Workbench.CancelTeachingSelectionCaptureCommand}"
                                            AutomationProperties.Name="Cancel teaching selection capture" />
                                    <Button Content="Apply selection"
                                            Command="{Binding Workbench.ApplyTeachingSelectionCaptureCommand}"
                                            AutomationProperties.Name="Apply teaching selection" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="1"
                        Margin="12"
                        Background="{DynamicResource ThreeD.ViewportBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="3">
                    <ContentPresenter Content="{Binding ViewerContent, RelativeSource={RelativeSource AncestorType=workbench:ToolRecipeWorkbenchView}}" />
                </Border>
            </Grid>
        </dock:OpenVisionDockWorkspaceView.ViewerContent>

        <dock:OpenVisionDockWorkspaceView.ToolInspectorContent>
            <workbench:ToolInspectorView DataContext="{Binding Workbench}" />
        </dock:OpenVisionDockWorkspaceView.ToolInspectorContent>

        <dock:OpenVisionDockWorkspaceView.EvidenceContent>
            <workbench:RecipePipelineReviewView DataContext="{Binding Workbench}"
                                                RunRecordSteps="{Binding DataContext.InspectionSteps, RelativeSource={RelativeSource AncestorType=workbench:ToolRecipeWorkbenchView}}"
                                                RunRecordSummary="{Binding DataContext.InspectionStepSummary, RelativeSource={RelativeSource AncestorType=workbench:ToolRecipeWorkbenchView}}"
                                                AutomationProperties.AutomationId="WorkbenchBottomPanel" />
        </dock:OpenVisionDockWorkspaceView.EvidenceContent>

        <dock:OpenVisionDockWorkspaceView.OutputCompareContent>
            <workbench:OutputCompareView DataContext="{Binding Workbench}" />
        </dock:OpenVisionDockWorkspaceView.OutputCompareContent>

        <dock:OpenVisionDockWorkspaceView.DisplayedOutputsContent>
            <workbench:DisplayedOutputsView DataContext="{Binding Workbench}" />
        </dock:OpenVisionDockWorkspaceView.DisplayedOutputsContent>

        <dock:OpenVisionDockWorkspaceView.LinkedViewContent>
            <workbench:RunLogView DataContext="{Binding Workbench}" />
        </dock:OpenVisionDockWorkspaceView.LinkedViewContent>

        <dock:OpenVisionDockWorkspaceView.ProfileContent>
            <workbench:HeightProfileView />
        </dock:OpenVisionDockWorkspaceView.ProfileContent>

        <dock:OpenVisionDockWorkspaceView.FitDiagnosticsContent>
            <workbench:LineFitDiagnosticsView />
        </dock:OpenVisionDockWorkspaceView.FitDiagnosticsContent>

        <dock:OpenVisionDockWorkspaceView.IntersectionEvidenceContent>
            <workbench:LineIntersectionEvidenceView />
        </dock:OpenVisionDockWorkspaceView.IntersectionEvidenceContent>
        <dock:OpenVisionDockWorkspaceView.CorrespondenceEvidenceContent>
            <workbench:LandmarkCorrespondenceEvidenceView />
        </dock:OpenVisionDockWorkspaceView.CorrespondenceEvidenceContent>
    </dock:OpenVisionDockWorkspaceView>
</UserControl>
