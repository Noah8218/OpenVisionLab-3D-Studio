<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Shell.StudioHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:shell="clr-namespace:OpenVisionLab.ThreeD.Shell.Views.Shell">
    <DockPanel LastChildFill="True">
        <shell:StudioTitleBarView DockPanel.Dock="Top"
                                  TitleText="OpenVisionLab 3D Studio"
                                  SubtitleText="{Binding Localization.StudioSubtitle}"
                                  RecipeText="{Binding Workbench.RecipeName}"
                                  SourceContextText="{Binding Workbench.SourceContextSummary}"
                                  AlignmentStatusText="{Binding Workbench.AlignmentStatusSummary}"
                                  RecipeStateText="{Binding Workbench.RecipeStateSummary}"
                                  IsRecipeContextVisible="{Binding IsWorkbenchWorkspaceSelected}"
                                  StatusText="{Binding StatusText}" />
        <Border Background="{DynamicResource ThreeD.CommandBarBrush}"
                BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Padding="3"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="WorkbenchModeButton"
                                     GroupName="WorkspaceMode"
                                     IsChecked="{Binding IsWorkbenchWorkspaceSelected, Mode=TwoWay}"
                                     Style="{DynamicResource ThreeD.ModeRadioButtonStyle}"
                                     AutomationProperties.AutomationId="WorkbenchModeButton"
                                     AutomationProperties.Name="Teach workspace">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="16" Height="16" Margin="0,0,4,0" Symbol="WrenchScrewdriver24" />
                                <TextBlock Text="{Binding Localization.Teach}" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="CalibrateModeButton"
                                     GroupName="WorkspaceMode"
                                     IsChecked="{Binding IsCalibrationWorkspaceSelected, Mode=TwoWay}"
                                     Style="{DynamicResource ThreeD.ModeRadioButtonStyle}"
                                     AutomationProperties.AutomationId="CalibrateModeButton"
                                     AutomationProperties.Name="Calibration workspace">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="16" Height="16" Margin="0,0,4,0" Symbol="TargetArrow24" />
                                <TextBlock Text="{Binding Localization.Calibrate}" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="1"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding WorkspaceSummary}" />

                <ui:Button Grid.Column="2"
                           Margin="0,0,8,0"
                           Padding="10,5"
                           Content="{Binding Localization.RecipeManager}"
                           Icon="{ui:SymbolIcon DocumentBulletList24}"
                           Click="OpenRecipeManagerButton_Click"
                           ToolTip="{Binding Localization.OpenRecipeManagerToolTip}"
                           AutomationProperties.AutomationId="OpenRecipeManagerButton"
                           AutomationProperties.Name="Open Recipe Manager" />

                <ui:Button x:Name="ToolLabsMenuButton"
                           Grid.Column="3"
                           Margin="0,0,8,0"
                           Padding="10,5"
                           Content="{Binding Localization.ToolLabs}"
                           Icon="{ui:SymbolIcon WrenchScrewdriver24}"
                           Click="OpenToolLabsMenuButton_Click"
                           ToolTip="{Binding Localization.OpenToolLabsToolTip}"
                           AutomationProperties.AutomationId="ToolLabsMenu"
                           AutomationProperties.Name="Open Tool Labs menu">
                    <ui:Button.ContextMenu>
                        <ContextMenu Placement="Bottom"
                                     Background="{DynamicResource ThreeD.PanelBrush}"
                                     Foreground="{DynamicResource ThreeD.TextBrush}">
                            <MenuItem Header="{Binding PlacementTarget.DataContext.Localization.Filter, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Click="OpenFilterToolLabButton_Click"
                                      ToolTip="Open the Filter input/output 3D comparison view"
                                      AutomationProperties.AutomationId="OpenFilterToolLabButton"
                                      AutomationProperties.Name="Open Filter Tool Lab">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Width="16" Height="16" Symbol="DataFunnel24" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding PlacementTarget.DataContext.Localization.HeightDifferenceEdge, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Click="OpenEdgeToolLabButton_Click"
                                      ToolTip="Open the FilteredHeightField and EdgePointSet comparison view"
                                      AutomationProperties.AutomationId="OpenEdgeToolLabButton"
                                      AutomationProperties.Name="Open Height Difference Edge Tool Lab">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Width="16" Height="16" Symbol="PointScan24" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding PlacementTarget.DataContext.Localization.LineIntersection, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Click="OpenLineIntersectionToolLabButton_Click"
                                      ToolTip="Open the two-LineFeature to corner-anchor comparison view"
                                      AutomationProperties.AutomationId="OpenLineIntersectionToolLabButton"
                                      AutomationProperties.Name="Open Line Intersection Tool Lab">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Width="16" Height="16" Symbol="Branch24" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding PlacementTarget.DataContext.Localization.LandmarkCorrespondence, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Click="OpenLandmarkCorrespondenceToolLabButton_Click"
                                      ToolTip="Open the four CornerAnchor to reference-coordinate teaching view"
                                      AutomationProperties.AutomationId="OpenLandmarkCorrespondenceToolLabButton"
                                      AutomationProperties.Name="Open Landmark Correspondence Tool Lab">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Width="16" Height="16" Symbol="TargetArrow24" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="XYZ Affine Solve"
                                      Click="OpenXYZAffineSolveToolLabButton_Click"
                                      ToolTip="Open the Published CorrespondenceSet to AffineTransform3D matrix-evidence view"
                                      AutomationProperties.AutomationId="OpenXYZAffineSolveToolLabButton"
                                      AutomationProperties.Name="Open XYZ Affine Solve Tool Lab">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Width="16" Height="16" Symbol="ArrowSync24" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ui:Button.ContextMenu>
                </ui:Button>

                <RadioButton x:Name="AdvancedModeButton"
                             Grid.Column="4"
                             GroupName="WorkspaceMode"
                             IsChecked="{Binding IsExpertWorkspaceSelected, Mode=TwoWay}"
                             Style="{DynamicResource ThreeD.ModeRadioButtonStyle}"
                             ToolTip="{Binding Localization.OpenAdvancedToolTip}"
                             AutomationProperties.AutomationId="AdvancedModeButton"
                             AutomationProperties.Name="Advanced layout">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Width="16" Height="16" Margin="0,0,4,0" Symbol="SettingsCogMultiple24" />
                        <TextBlock Text="{Binding Localization.AdvancedLayout}" />
                    </StackPanel>
                </RadioButton>

                <ComboBox Grid.Column="5"
                          Width="106"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding LanguageOptions}"
                          SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          ToolTip="{Binding Localization.Language}"
                          AutomationProperties.AutomationId="StudioLanguageSelector"
                          AutomationProperties.Name="Select Korean or English" />
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
