<UserControl x:Name="Root"
             x:Class="OpenVisionLab.ThreeD.Shell.Views.Shell.StudioTitleBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             Height="56"
             MinHeight="56"
             shell:WindowChrome.IsHitTestVisibleInChrome="True"
             MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
             AutomationProperties.AutomationId="StudioTitleBar">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="{DynamicResource ThreeD.PanelHeaderBrush}"
            BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}"
            BorderThickness="0,0,0,1">
        <Grid Margin="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:SymbolIcon Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThreeD.AccentBrush}"
                           Symbol="TargetArrow24" />

            <StackPanel Grid.Column="1"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ThreeD.PanelHeaderTextBrush}"
                           Text="{Binding TitleText, ElementName=Root}" />
                <TextBlock Margin="0,1,0,0"
                           FontSize="10.5"
                           Foreground="{DynamicResource ThreeD.PanelHeaderMutedTextBrush}"
                           Text="{Binding SubtitleText, ElementName=Root}" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="0,0,12,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="{Binding IsRecipeContextVisible, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"
                        AutomationProperties.Name="Active teaching recipe context">
                <Border MaxWidth="230"
                        Padding="8,4"
                        Background="#203650"
                        BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock FontSize="10.5"
                               Foreground="{DynamicResource ThreeD.PanelHeaderTextBrush}"
                               Text="{Binding RecipeText, ElementName=Root, StringFormat=Recipe: {0}}"
                               TextTrimming="CharacterEllipsis" />
                </Border>
                <Border MaxWidth="300"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        Background="#203650"
                        BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock FontSize="10.5"
                               Foreground="{DynamicResource ThreeD.PanelHeaderMutedTextBrush}"
                               Text="{Binding SourceContextText, ElementName=Root}"
                               TextTrimming="CharacterEllipsis" />
                </Border>
                <Border Margin="6,0,0,0"
                        Padding="8,4"
                        Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock FontSize="10.5"
                               Foreground="{DynamicResource ThreeD.InfoBrush}"
                               Text="{Binding AlignmentStatusText, ElementName=Root}" />
                </Border>
                <Border Margin="6,0,0,0"
                        Padding="8,4"
                        Background="{DynamicResource ThreeD.WarningSurfaceBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock FontSize="10.5"
                               Foreground="{DynamicResource ThreeD.WarningBrush}"
                               Text="{Binding RecipeStateText, ElementName=Root}" />
                </Border>
            </StackPanel>

            <Border Grid.Column="3"
                    MaxWidth="250"
                    Padding="9,4"
                    VerticalAlignment="Center"
                    Background="#203650"
                    BorderBrush="{DynamicResource ThreeD.PanelHeaderBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecipeContextVisible, ElementName=Root}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource ThreeD.PanelHeaderMutedTextBrush}"
                           Text="{Binding StatusText, ElementName=Root}"
                           TextTrimming="CharacterEllipsis" />
            </Border>

            <StackPanel Grid.Column="4"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        AutomationProperties.Name="Window controls">
                <Button Content="−"
                        Style="{DynamicResource ThreeD.WindowControlButtonStyle}"
                        Click="MinimizeButton_Click"
                        ToolTip="Minimize"
                        AutomationProperties.Name="Minimize window" />
                <Button Content="□"
                        Style="{DynamicResource ThreeD.WindowControlButtonStyle}"
                        Click="MaximizeRestoreButton_Click"
                        ToolTip="Maximize or restore"
                        AutomationProperties.Name="Maximize or restore window" />
                <Button Content="×"
                        Style="{DynamicResource ThreeD.WindowCloseButtonStyle}"
                        Click="CloseButton_Click"
                        ToolTip="Close"
                        AutomationProperties.Name="Close window" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
