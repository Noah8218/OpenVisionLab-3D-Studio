<UserControl x:Class="OpenVisionLab.ThreeD.Shell.Views.Recipe.RecipeManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             MinWidth="720"
             AutomationProperties.AutomationId="RecipeCenterView">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Border Padding="18"
            Background="{DynamicResource ThreeD.PanelBrush}"
            TextElement.Foreground="{DynamicResource ThreeD.TextBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding Localization.RecipeCenter}" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="10.5"
                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                           Text="{Binding Localization.RecipeCenterDetail}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,14,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:Button Height="64"
                           Margin="0,0,6,0"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           Padding="16,10"
                           Content="{Binding Localization.NewRecipe}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Icon="{ui:SymbolIcon DocumentAdd24}"
                           Command="{Binding NewTeachingRecipeCommand}"
                           AutomationProperties.Name="{Binding Localization.NewRecipe}" />
                <ui:Button Grid.Column="1"
                           Height="64"
                           Margin="6,0,0,0"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           Padding="16,10"
                           Content="{Binding Localization.OpenExistingRecipe}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Icon="{ui:SymbolIcon FolderOpen24}"
                           Command="{Binding OpenTeachingRecipeCommand}"
                           AutomationProperties.Name="{Binding Localization.OpenExistingRecipe}" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.92*" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,7,0"
                        Padding="14"
                        Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Width="18"
                                           Height="18"
                                           Margin="0,1,7,0"
                                           Foreground="{DynamicResource ThreeD.AccentBrush}"
                                           Symbol="DocumentEdit24" />
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="{Binding Localization.CurrentRecipe}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,13,0,0">
                            <TextBlock Style="{DynamicResource ThreeD.FieldLabelTextStyle}"
                                       Text="{Binding Localization.RecipeNameLabel}" />
                            <TextBox Margin="0,4,0,0"
                                     FontWeight="SemiBold"
                                     AutomationProperties.Name="{Binding Localization.RecipeNameLabel}"
                                     Text="{Binding RecipeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Margin="0,11,0,0"
                                Padding="10"
                                Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                BorderBrush="{DynamicResource ThreeD.InfoBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel>
                                <TextBlock FontSize="9.5"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                           Text="{Binding Localization.RecipeStatusLabel}" />
                                <TextBlock Margin="0,3,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThreeD.InfoBrush}"
                                           Text="{Binding LocalizedRecipeStateSummary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="9.5"
                                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                           Text="{Binding RecipeSchemaVersion, StringFormat=Schema {0}}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding Localization.SourceLabel}" />
                            <TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold"
                                       Text="{Binding LocalizedSourceReadinessSummary}" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding LocalizedSourceReadinessSummary}" />
                        </Grid>
                        <Grid Grid.Row="4" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding Localization.StepsLabel}" />
                            <TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold"
                                       Text="{Binding PipelineSteps.Count}" />
                        </Grid>
                        <Grid Grid.Row="5" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="10" Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding Localization.RecipePathLabel}" />
                            <TextBlock Grid.Column="1" FontSize="10"
                                       Text="{Binding LocalizedRecipePathSummary}" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding LocalizedRecipePathSummary}" />
                        </Grid>

                        <Border Grid.Row="6"
                                Margin="0,13,0,0"
                                Padding="10"
                                Background="{DynamicResource ThreeD.WarningSurfaceBrush}"
                                BorderBrush="{DynamicResource ThreeD.WarningBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsRecipeSaveBlocked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Width="15"
                                                   Height="15"
                                                   Margin="0,1,6,0"
                                                   Foreground="{DynamicResource ThreeD.WarningBrush}"
                                                   Symbol="Warning24" />
                                    <TextBlock FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThreeD.WarningBrush}"
                                               Text="{Binding Localization.RecipeSaveBlockedTitle}" />
                                </StackPanel>
                                <TextBlock Margin="21,5,0,0"
                                           FontSize="9.5"
                                           Foreground="{DynamicResource ThreeD.SecondaryTextBrush}"
                                           Text="{Binding LocalizedRecipeSaveBlocker}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Grid.Row="7" Margin="0,14,0,0">
                            <ui:Button Margin="0,0,6,0"
                                       Content="{Binding Localization.Save}"
                                       Icon="{ui:SymbolIcon DocumentCheckmark24}"
                                       Command="{Binding SaveTeachingRecipeCommand}"
                                       AutomationProperties.Name="{Binding Localization.Save}" />
                            <ui:Button Content="{Binding Localization.SaveAs}"
                                       Icon="{ui:SymbolIcon SaveCopy24}"
                                       Command="{Binding SaveTeachingRecipeAsCommand}"
                                       AutomationProperties.Name="{Binding Localization.SaveAs}" />
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="7,0,0,0"
                        Padding="14"
                        Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                        BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="18"
                                               Height="18"
                                               Margin="0,1,7,0"
                                               Foreground="{DynamicResource ThreeD.AccentBrush}"
                                               Symbol="History24" />
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Text="{Binding Localization.RecentRecipes}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       FontSize="10"
                                       Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                       Text="{Binding RecentRecipes.Count}" />
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,12,0,0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentRecipes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6"
                                                Padding="9,7"
                                                Background="{DynamicResource ThreeD.PanelBrush}"
                                                BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Padding="0"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.OpenRecentTeachingRecipeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{Binding Path}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="10.5"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Name}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   FontSize="9"
                                                                   Foreground="{DynamicResource ThreeD.MutedTextBrush}"
                                                                   Text="{Binding Path}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Button>
                                                <Border Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource ThreeD.InfoSurfaceBrush}"
                                                        CornerRadius="3">
                                                    <TextBlock FontSize="9"
                                                               Foreground="{DynamicResource ThreeD.InfoBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding DataContext.Localization.Unavailable, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                                        <Setter Property="Text" Value="{Binding DataContext.Localization.Available, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <ui:Button Grid.Column="2"
                                                           Margin="7,0,0,0"
                                                           Padding="5"
                                                           VerticalAlignment="Center"
                                                           Icon="{ui:SymbolIcon DismissCircle24}"
                                                           Command="{Binding DataContext.RemoveRecentTeachingRecipeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding}"
                                                           ToolTip="{Binding DataContext.Localization.RemoveFromRecentToolTip, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           AutomationProperties.Name="{Binding DataContext.Localization.RemoveFromRecent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
