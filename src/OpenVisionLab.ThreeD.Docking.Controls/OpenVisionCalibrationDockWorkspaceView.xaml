<UserControl x:Class="OpenVisionLab.ThreeD.Docking.Controls.OpenVisionCalibrationDockWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
             xmlns:local="clr-namespace:OpenVisionLab.ThreeD.Docking.Controls">
    <Grid>
        <avalonDock:DockingManager Background="{DynamicResource ThreeD.PanelAlternateBrush}"
                                   Foreground="{DynamicResource ThreeD.TextBrush}"
                                   BorderBrush="{DynamicResource ThreeD.DividerBrush}"
                                   BorderThickness="1">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Vertical">
                    <avalonDock:LayoutPanel x:Name="workbenchPane" Orientation="Horizontal">
                        <avalonDock:LayoutAnchorablePane x:Name="explorerPane" DockWidth="245">
                            <avalonDock:LayoutAnchorable Title="Calibration Explorer"
                                                         ContentId="calibration-explorer"
                                                         CanClose="False"
                                                         CanFloat="False">
                                <ContentPresenter Content="{Binding ExplorerContent, RelativeSource={RelativeSource AncestorType=local:OpenVisionCalibrationDockWorkspaceView}}" />
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                        <avalonDock:LayoutDocumentPane x:Name="workspacePane">
                            <avalonDock:LayoutDocument Title="Calibration Workspace"
                                                       ContentId="calibration-workspace"
                                                       CanClose="False"
                                                       CanFloat="False">
                                <ContentPresenter Content="{Binding WorkspaceContent, RelativeSource={RelativeSource AncestorType=local:OpenVisionCalibrationDockWorkspaceView}}" />
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                        <avalonDock:LayoutAnchorablePane x:Name="inspectorPane" DockWidth="320">
                            <avalonDock:LayoutAnchorable Title="Calibration Inspector"
                                                         ContentId="calibration-inspector"
                                                         CanClose="False"
                                                         CanFloat="False">
                                <ContentPresenter Content="{Binding InspectorContent, RelativeSource={RelativeSource AncestorType=local:OpenVisionCalibrationDockWorkspaceView}}" />
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutPanel>
                    <avalonDock:LayoutAnchorablePane x:Name="evidencePane" DockHeight="175">
                        <avalonDock:LayoutAnchorable Title="Calibration Evidence"
                                                     ContentId="calibration-evidence"
                                                     CanClose="False"
                                                     CanFloat="False">
                            <ContentPresenter Content="{Binding EvidenceContent, RelativeSource={RelativeSource AncestorType=local:OpenVisionCalibrationDockWorkspaceView}}" />
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
    </Grid>
</UserControl>
