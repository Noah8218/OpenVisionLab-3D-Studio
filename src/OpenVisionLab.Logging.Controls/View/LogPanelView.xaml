<UserControl x:Class="OpenVisionLab.Logging.Controls.View.LogPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converter="clr-namespace:OpenVisionLab.Logging.Controls.Converter"
             MinWidth="280"
             MinHeight="80">
    <UserControl.Resources>
        <converter:BooleanToInverseConverter x:Key="BooleanToInverseConverter" />
        <converter:LogToneBrushConverter x:Key="LogToneBrushConverter" />

        <SolidColorBrush x:Key="ShellBrush" Color="#111821" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1D2532" />
        <SolidColorBrush x:Key="ListBrush" Color="#0D1219" />
        <SolidColorBrush x:Key="RowBrush" Color="#121A25" />
        <SolidColorBrush x:Key="LineBrush" Color="#2B3645" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#EEF3F8" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AEB9C7" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#78879A" />
        <SolidColorBrush x:Key="ActionBrush" Color="#285A70" />
        <SolidColorBrush x:Key="ActionBorderBrush" Color="#4B8DA4" />
        <SolidColorBrush x:Key="InputBrush" Color="#101722" />
        <SolidColorBrush x:Key="BadgeBrush" Color="#263348" />
        <SolidColorBrush x:Key="ComboArrowBrush" Color="#AEB9C7" />
        <SolidColorBrush x:Key="ComboHoverBrush" Color="#172332" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="25" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Margin" Value="5,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="#3B4654" />
            <Setter Property="Padding" Value="8,2,28,2" />
            <Setter Property="ToolTip" Value="{Binding FilterComboToolTip}" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                        <Setter Property="Background" Value="{StaticResource InputBrush}" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                    <Border x:Name="itemChrome"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="itemChrome" Property="Background" Value="{StaticResource ActionBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemChrome" Property="Background" Value="{StaticResource BadgeBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="comboChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False" />
                            <ToggleButton HorizontalAlignment="Right"
                                          Width="24"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Path Width="8"
                                      Height="5"
                                      Data="M 0 0 L 4 5 L 8 0 Z"
                                      Fill="{StaticResource ComboArrowBrush}"
                                      Stretch="Fill" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{StaticResource InputBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="comboChrome" Property="Background" Value="{StaticResource ComboHoverBrush}" />
                                <Setter TargetName="comboChrome" Property="BorderBrush" Value="{StaticResource ActionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="comboChrome" Property="BorderBrush" Value="{StaticResource ActionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="comboChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.38" />
                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                    <Setter Property="Background" Value="#182130" />
                    <Setter Property="BorderBrush" Value="#596779" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="25" />
            <Setter Property="Padding" Value="10,1" />
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ActionBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="25" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="#3B4654" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="7,2" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource ListBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{StaticResource ListBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="DetailedOnlyVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDetailedMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailedOnlyTextVisibilityStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsDetailedMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogMessageTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsCompactLayout, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                    <Setter Property="TextWrapping" Value="Wrap" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmptyLogTextVisibilityStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasVisibleLogs}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmptyLogVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasVisibleLogs}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowEntireStream}" Value="True">
                    <Setter Property="Opacity" Value="0.42" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            MinWidth="62"
                            Content="{Binding ModeButtonText}"
                            Command="{Binding ToggleDetailCommand}"
                            ToolTip="{Binding ModeToolTip}" />
                    <Border DockPanel.Dock="Right"
                            Background="{StaticResource BadgeBrush}"
                            BorderBrush="#34445C"
                            BorderThickness="1"
                            MinWidth="54"
                            Height="22"
                            Margin="8,0,0,0"
                            Padding="8,0">
                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding ActiveFilterText}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11"
                               Margin="10,0,2,0" />
                    <TextBlock Text="{Binding HeaderText}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </DockPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding LatestSummaryText}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="11"
                           Margin="0,5,0,0"
                           TextTrimming="CharacterEllipsis" />

                <DockPanel Grid.Row="2"
                           LastChildFill="True"
                           Style="{StaticResource DetailedOnlyVisibilityStyle}"
                           Margin="0,5,0,0">
                    <Button DockPanel.Dock="Right"
                            MinWidth="58"
                            Content="{Binding ClearText}"
                            Command="{Binding ResetCommand}"
                            ToolTip="{Binding ClearToolTip}" />
                    <Button DockPanel.Dock="Right"
                            MinWidth="58"
                            Content="{Binding FolderText}"
                            Command="{Binding OpenDirectoryCommand}"
                            ToolTip="{Binding FolderToolTip}" />
                    <CheckBox DockPanel.Dock="Right"
                              Content="{Binding AutoScrollText}"
                              IsChecked="{Binding AutoScroll}"
                              ToolTip="{Binding AutoScrollToolTip}" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding SearchToolTip}" />
                </DockPanel>

                <WrapPanel Grid.Row="3"
                           Margin="0,6,0,0"
                           Style="{StaticResource DetailedOnlyVisibilityStyle}">
                    <CheckBox Content="{Binding AllLogsText}"
                              IsChecked="{Binding ShowEntireStream}"
                              ToolTip="{Binding AllLogsToolTip}" />
                    <TextBlock Text="{Binding LevelText}"
                               Style="{StaticResource FilterLabelTextStyle}" />
                    <ComboBox IsEnabled="{Binding IsFilterControlsEnabled}"
                              ItemsSource="{Binding Levels}"
                              SelectedItem="{Binding SelectedLevel}" />
                    <TextBlock Text="{Binding AreaText}"
                               Style="{StaticResource FilterLabelTextStyle}" />
                    <ComboBox IsEnabled="{Binding IsFilterControlsEnabled}"
                              ItemsSource="{Binding Types}"
                              SelectedItem="{Binding SelectedType}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ListBox x:Name="LogList"
                     ItemsSource="{Binding FilteredLogs}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource RowBrush}"
                                BorderBrush="#1F2A36"
                                BorderThickness="0,0,0,1"
                                ToolTip="{Binding RawText}">
                            <Grid MinHeight="26">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{Binding Level, Converter={StaticResource LogToneBrushConverter}}" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayTime}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="8,0,6,0"
                                           FontSize="10.5" />

                                <StackPanel Grid.Column="2"
                                            Orientation="Vertical"
                                            Margin="0,3,7,3">
                                    <TextBlock Text="{Binding Level}"
                                               Foreground="{Binding Level, Converter={StaticResource LogToneBrushConverter}}"
                                               FontWeight="SemiBold"
                                               FontSize="10.5" />
                                    <TextBlock Text="{Binding Category}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="9.5" />
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            Orientation="Vertical"
                                            Margin="0,3,10,3">
                                    <TextBlock Text="{Binding Source}"
                                               Foreground="#7FD6E7"
                                               FontSize="9.5"
                                               Style="{StaticResource DetailedOnlyTextVisibilityStyle}" />
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="{Binding Level, Converter={StaticResource LogToneBrushConverter}}"
                                               Style="{StaticResource LogMessageTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border AutomationProperties.AutomationId="LogPanelEmptyState"
                    Style="{StaticResource EmptyLogVisibilityStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="520"
                    MaxWidth="620"
                    Padding="14,10"
                    Background="#141F2A"
                    BorderBrush="#3A6572"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="28"
                            Height="28"
                            Background="#20333D"
                            BorderBrush="#4B8DA4"
                            BorderThickness="1">
                        <TextBlock Text="i"
                                   Foreground="#8AD7DA"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="2">
                        <TextBlock AutomationProperties.AutomationId="LogPanelEmptyTitle"
                                   Text="{Binding EmptyTitleText}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12.5" />
                        <TextBlock Text="{Binding EmptyDetailText}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   Margin="0,3,0,0" />
                        <TextBlock AutomationProperties.AutomationId="LogPanelEmptyActionHint"
                                   Text="{Binding EmptyActionHintText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="10.5"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
